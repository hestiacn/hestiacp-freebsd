{
	"name": "hestia",
	"private": true,
	"version": "1.9.6",
	"description": "An open-source Linux web server control panel.",
	"repository": "https://github.com/hestiacn/hestiacp-freebsd",
	"license": "GPL-3.0-or-later",
	"type": "module",
	"scripts": {
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:serve": "vitepress serve docs",
		"docs:test": "vitest run --config docs/.vitepress/vitest.config.js",
		"build": "node build.js",
		"lint": "prettier --cache --check . && eslint --cache . && stylelint web/css/src/**/*.css && markdownlint-cli2 *.md docs/**/*.md",
		"lint-staged": "lint-staged",
		"format": "prettier --cache --write .",
		"preinstall": "npx only-allow npm",
		"prepare": "husky"
	},
	"dependencies": {
		"@alpinejs/collapse": "^3.15.12",
		"@fortawesome/fontawesome-free": "^7.2.0",
		"@xterm/xterm": "^6.0.0",
		"alpinejs": "^3.15.12",
		"chart.js": "^4.5.1",
		"check-password-strength": "^3.0.0",
		"floating-vue": "^5.2.2",
		"nanoid": "^5.1.11",
		"normalize.css": "^8.0.1"
	},
	"devDependencies": {
		"@prettier/plugin-php": "^0.25.0",
		"@testing-library/vue": "^8.1.0",
		"@vitejs/plugin-vue": "^6.0.7",
		"browserslist": "^4.28.2",
		"esbuild": "^0.28.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-editorconfig": "^4.0.3",
		"eslint-plugin-import": "^2.32.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lightningcss": "^1.32.0",
		"lint-staged": "^17.0.7",
		"markdownlint-cli2": "^0.22.1",
		"prettier": "^3.8.3",
		"prettier-plugin-nginx": "^1.0.3",
		"prettier-plugin-sh": "^0.18.1",
		"prettier-plugin-sql": "^0.20.0",
		"stylelint": "^17.13.0",
		"stylelint-config-standard": "^40.0.0",
		"vite": "^8.0.16",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.8",
		"vue": "^3.5.35"
	},
	"browserslist": [
		"defaults"
	]
}
