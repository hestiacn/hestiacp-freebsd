name: "hestia-nginx"
version: "1.31.1"
origin: "www/hestia-nginx"
comment: "HestiaCP Nginx backend for FreeBSD"
maintainer: "HestiaCP <info@hestiacp.com>"
www: "https://www.hestiacp.com"
categories: [ "www" ]
architectures: [ "amd64", "arm64" ]
prefix: "/usr/local"
licenses: [ "BSD" ]

deps: {
    hestia: {
        origin: "sysutils/hestia",
        version: "1.9.6"
    }
}

desc: "hestia is an open source hosting control panel. hestia has a clean and focused interface without the clutter. hestia has the latest of very innovative technologies. hestia is a fork from VestaCP, special thanks to vestacp.com and Serghey Rodin. This package provides the custom compiled Nginx backend for Hestia Control Panel."