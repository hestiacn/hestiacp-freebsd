#!/bin/sh

# Run triggers only on updates
if [ ! -e "/usr/local/hestia/data/users/admin" ]; then
    exit
fi

# FreeBSD: 配置文件位置 - 保持 hestiacp 名称
if [ ! -e "/usr/local/etc/hestiacp/hestia.conf" ]; then
    mkdir -p /usr/local/etc/hestiacp
    cat > /usr/local/etc/hestiacp/hestia.conf << 'EOF'
# Do not edit this file, will get overwritten on next upgrade, use /usr/local/etc/hestiacp/local.conf instead

export HESTIA='/usr/local/hestia'

[[ -f /usr/local/etc/hestiacp/local.conf ]] && source /usr/local/etc/hestiacp/local.conf
EOF
fi

# FreeBSD: 不需要配置 apt，pkg 有自己的重试机制

# Validate version number and replace if different
# FreeBSD: 使用 pkg info 获取版本号
HESTIA_V=$(pkg info hestia 2>/dev/null | grep Version | awk '{print $3}')
if [ -z "$HESTIA_V" ]; then
    HESTIA_V=$(grep "VERSION=" "/usr/local/etc/hestiacp/hestia.conf" 2>/dev/null | cut -d"'" -f2)
fi

exit 0