#!/bin/bash

#-------------------------------------------------------------#
#                Initialize functions/variables               #
#-------------------------------------------------------------#

if [ -z "$HESTIA" ]; then
    export HESTIA='/usr/local/hestia'
    PATH=$PATH:/usr/local/hestia/bin
    export PATH
fi


if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
source "$HESTIA_CONF"
source /usr/local/hestia/func/main.sh
source /usr/local/hestia/func/upgrade.sh
source /usr/local/hestia/conf/hestia.conf
source /usr/local/hestia/install/upgrade/upgrade.conf
#-------------------------------------------------------------#
#                    Install dependencies                     #
#-------------------------------------------------------------#

cd /usr/local/hestia/web-terminal || exit 1

if ! command -v node > /dev/null 2>&1; then
    echo "Node.js not found, installing..."
    pkg install -y node
fi

if command -v npm > /dev/null 2>&1; then
    if [ ! -d "node_modules" ]; then
        echo "Installing Node.js dependencies for web-terminal..."
        npm install --omit=dev --no-package-lock --production
    fi
else
    echo "Error: npm not found after Node.js installation"
    exit 1
fi

#-------------------------------------------------------------#
#                   Restart service                           #
#-------------------------------------------------------------#

if [ -f "/usr/local/etc/rc.d/hestia-web-terminal" ]; then
    if ! sysrc -q hestia_web_terminal_enable 2>/dev/null; then
        sysrc hestia_web_terminal_enable="YES"
    fi
    
    if ! service hestia-web-terminal restart; then
        service hestia-web-terminal start
    fi
fi

exit 0