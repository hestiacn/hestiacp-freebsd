name: hestia-php
version: "8.5.7"
origin: lang/hestia-php
comment: HestiaCP PHP-FPM backend for FreeBSD
maintainer: HestiaCP <info@hestiacp.com>
www: https://www.hestiacp.com
categories: [ lang ]
architectures: amd64 arm64
prefix: /usr/local
licenses: [ PHP ]

deps: {
    hestia: { origin: sysutils/hestia, version: "1.9.6" },
    libzip: { origin: archivers/libzip, version: "1.10.1" },
