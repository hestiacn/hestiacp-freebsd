#!/bin/bash
# info: list user notifications
# options: USER [FORMAT]
#
# example: v-list-user-notifications admin
#
# This function for getting the notifications list

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "NID" "$USER_DATA/notifications.conf")
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		if [ -z "$PRIORITY" ]; then
			PRIORITY='0'
		fi
		TOPIC=$(echo "$TOPIC" | sed -e "s/%quote%/'/g")
		NOTICE=$(echo "$NOTICE" | sed -e "s/%quote%/'/g")
		# 转义双引号
		NOTICE_ESCAPED=$(echo "$NOTICE" | sed 's/"/\\"/g')
		echo -n "    \"$NID\": {"
		echo -n "\"TOPIC\": \"$TOPIC\", "
		echo -n "\"NOTICE\": \"$NOTICE_ESCAPED\", "
		echo -n "\"TYPE\": \"$TYPE\", "
		echo -n "\"ACK\": \"$ACK\", "
		echo -n "\"PRIORITY\": \"$PRIORITY\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$USER_DATA/notifications.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		TOPIC=$(echo "$TOPIC" | sed -e "s/%quote%/'/g")
		NOTICE=$(echo "$NOTICE" | sed -e "s/%quote%/'/g")
		echo "$TOPIC"
		echo "$NOTICE"
		echo "$DATE $TIME"
		echo "--"
		echo
	done < "$USER_DATA/notifications.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		TOPIC=$(echo "$TOPIC" | sed -e "s/%quote%/'/g")
		NOTICE=$(echo "$NOTICE" | sed -e "s/%quote%/'/g")
		printf "%s\t%s\t%s\t%s\t%s\n" \
			"$NID" "$TOPIC" "$NOTICE" "$TIME" "$DATE"
	done < "$USER_DATA/notifications.conf"
}

# CSV list function
csv_list() {
	echo "NID,TOPIC,NOTICE,ACK,TIME,DATE"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		TOPIC=$(echo "$TOPIC" | sed -e "s/%quote%/'/g")
		NOTICE=$(echo "$NOTICE" | sed -e "s/%quote%/'/g")
		echo "$NID,\"$TOPIC\",\"$NOTICE\",$ACK,$TIME,$DATE"
	done < "$USER_DATA/notifications.conf"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Checking args
check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Check if notifications file exists
if [ ! -f "$USER_DATA/notifications.conf" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No notifications found" ;;
		plain) ;;
		csv) echo "NID,TOPIC,NOTICE,ACK,TIME,DATE" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
