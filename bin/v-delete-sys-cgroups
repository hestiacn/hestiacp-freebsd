#!/bin/sh
# info: delete all cgroups
# options: NONE
#
# example: v-delete-sys-cgroups
#
# This function disables cgroups

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ "$OS" = "freebsd" ]; then
    if command -v rctl > /dev/null 2>&1; then
        for user in $("$BIN/v-list-users" list); do
            rctl -h -u "$user" 2>/dev/null
        done
    fi
else
    for user in $("$BIN/v-list-users" list); do
        user_id=$(id -u "$user")
        user_slice="user-${user_id}.slice"
        systemctl revert "$user_slice"
    done
    # Reload daemon
    systemctl daemon-reload
fi

# Updating hestia.conf value
$BIN/v-change-sys-config-value "RESOURCES_LIMIT" "no"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Info" "Plugins" "System resource enforcement disabled."
log_event "$OK" "$ARGUMENTS"

exit 0
