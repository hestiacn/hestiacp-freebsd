#!/bin/bash
# info: list system users
# options: [FORMAT]
#
# example: v-list-sys-users
#
# This function for obtaining the list of system users without
# detailed information.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	objects=$("$BIN/v-list-users" 'list' | wc -w)
	i=1
	echo '['
	while read -r user; do
		if [ "$i" -lt "$objects" ]; then
			printf '    "%s",\n' "$user"
		else
			printf '    "%s"\n' "$user"
		fi
		i=$((i + 1))
	done < <("$BIN/v-list-users" 'list')
	echo ']'
}

# SHELL list function
shell_list() {
	echo "USER"
	echo "----"
	while read -r user; do
		echo "$user"
	done < <("$BIN/v-list-users" 'list')
}

# PLAIN list function
plain_list() {
	while read -r user; do
		echo "$user"
	done < <("$BIN/v-list-users" 'list')
}

# CSV list function
csv_list() {
	echo "USER"
	while read -r user; do
		echo "$user"
	done < <("$BIN/v-list-users" 'list')
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
