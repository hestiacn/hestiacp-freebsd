#!/bin/sh
# info: List firewall ipset
# options: [FORMAT]
#
# example: v-list-firewall-ipset json
#
# This function prints defined ipset lists

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

is_system_enabled "$FIREWALL_SYSTEM" 'FIREWALL_SYSTEM'

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "LISTNAME" "$HESTIA/data/firewall/ipset.conf")
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo -n "    \"$LISTNAME\": {"
		echo -n "\"IP_VERSION\": \"$IP_VERSION\", "
		echo -n "\"AUTOUPDATE\": \"$AUTOUPDATE\", "
		echo -n "\"SUSPENDED\": \"$SUSPENDED\", "
		echo -n "\"SOURCE\": \"$SOURCE\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$HESTIA/data/firewall/ipset.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-20s %-12s %-10s %-10s %-20s %-10s %-12s\n" "LISTNAME" "IP_VERSION" "AUTOUPDATE" "SUSPENDED" "SOURCE" "TIME" "DATE"
	printf "%-20s %-12s %-10s %-10s %-20s %-10s %-12s\n" "--------" "----------" "----------" "---------" "------" "----" "----"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%-20s %-12s %-10s %-10s %-20s %-10s %-12s\n" \
			"$LISTNAME" "$IP_VERSION" "$AUTOUPDATE" "$SUSPENDED" "$SOURCE" "$TIME" "$DATE"
	done < "$HESTIA/data/firewall/ipset.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$LISTNAME" "$IP_VERSION" "$AUTOUPDATE" "$SUSPENDED" "$SOURCE" "$TIME" "$DATE"
	done < "$HESTIA/data/firewall/ipset.conf"
}

# CSV list function
csv_list() {
	echo "LISTNAME,IP_VERSION,AUTOUPDATE,SUSPENDED,SOURCE,TIME,DATE"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo "$LISTNAME,$IP_VERSION,$AUTOUPDATE,$SUSPENDED,\"$SOURCE\",$TIME,$DATE"
	done < "$HESTIA/data/firewall/ipset.conf"
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ ! -f "$HESTIA/data/firewall/ipset.conf" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No ipset lists found" ;;
		plain) ;;
		csv) echo "LISTNAME,IP_VERSION,AUTOUPDATE,SUSPENDED,SOURCE,TIME,DATE" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
