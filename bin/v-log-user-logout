#!/bin/bash
# info: Log User logout event
# options: USER FINGERPRINT

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
session_id=$2

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER SESSION_ID'
is_format_valid 'user'
is_common_format_valid "$session_id" "Session ID"
is_object_valid 'user' 'USER' "$user"

if [ ! -f "$USER_DATA/auth.log" ]; then
	touch "$USER_DATA/auth.log"
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

tmp_file="$USER_DATA/auth.log.tmp"
sed "s/SESSION='$session_id' ACTIVE='yes'/SESSION='$session_id' ACTIVE='no'/g" "$USER_DATA/auth.log" > "$tmp_file"
mv "$tmp_file" "$USER_DATA/auth.log"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
