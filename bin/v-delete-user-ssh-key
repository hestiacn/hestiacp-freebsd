#!/bin/sh
# info: delete user ssh key
# options: USER KEYID
#
# example: v-delete-user-ssh-key user unique_id
#
# Delete user ssh key from authorized_keys

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
keyid=$2

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER KEYID'
is_format_valid 'user'
is_no_new_line_format "$key_id"
is_object_valid 'user' 'USER' "$user"

source "$USER_DATA/user.conf"

AUTHKEY_FILE="$HOMEDIR/$user/.ssh/authorized_keys"

if command -v realpath > /dev/null 2>&1; then
    real_path=$(realpath "$AUTHKEY_FILE" 2>/dev/null)
else
    real_path=$(readlink -f "$AUTHKEY_FILE" 2>/dev/null)
fi

expected_prefix="$HOMEDIR/$user/.ssh/"
case "$real_path" in
    ${expected_prefix}*)
        ;;
    *)
        check_result "$E_FORBIDEN" "Invalid authorized keys path"
        ;;
esac

if [ ! -f "$AUTHKEY_FILE" ]; then
    exit 0
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

sed -i "" "/${keyid}/d" "$AUTHKEY_FILE"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "$user" "Info" "SSH" "SSH key deleted (Key ID: $keyid)."
log_event "$OK" "$ARGUMENTS"

exit 0
