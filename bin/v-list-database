#!/bin/sh
# info: list database
# options: USER DATABASE [FORMAT]
#
# example: v-list-database admin wp_db

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
database=$2
format=${3:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	echo '{'
	echo "    \"$database\": {"
	echo "        \"DATABASE\": \"$DB\","
	echo "        \"DBUSER\": \"$DBUSER\","
	echo "        \"HOST\": \"$HOST\","
	echo "        \"TYPE\": \"$TYPE\","
	echo "        \"CHARSET\": \"$CHARSET\","
	echo "        \"U_DISK\": \"$U_DISK\","
	echo "        \"SUSPENDED\": \"$SUSPENDED\","
	echo "        \"TIME\": \"$TIME\","
	echo "        \"DATE\": \"$DATE\""
	echo "    }"
	echo '}'
}

# SHELL list function
shell_list() {
	echo "DATABASE:       $DB"
	echo "DB USER:        $DBUSER"
	echo "HOST:           $HOST"
	echo "TYPE:           $TYPE"
	echo "CHARSET:        $CHARSET"
	echo "DISK:           $U_DISK"
	echo "SUSPENDED:      $SUSPENDED"
	echo "TIME:           $TIME"
	echo "DATE:           $DATE"
}

# PLAIN list function
plain_list() {
	printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
		"$DB" "$DBUSER" "$HOST" "$TYPE" "$CHARSET" "$U_DISK" "$SUSPENDED" "$TIME" "$DATE"
}

# CSV list function
csv_list() {
	echo "DATABASE,DBUSER,HOST,TYPE,CHARSET,U_DISK,SUSPENDED,TIME,DATE"
	echo "$DB,$DBUSER,$HOST,$TYPE,$CHARSET,$U_DISK,$SUSPENDED,$TIME,$DATE"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER DATABASE [FORMAT]'
is_format_valid 'user' 'database'
is_object_valid 'user' 'USER' "$user"
is_object_valid 'db' 'DB' "$database"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing database
db_line=$(grep "DB='$database'" "$USER_DATA/db.conf")
if [ -z "$db_line" ]; then
	echo "Error: Database $database not found for user $user"
	exit 3
fi
parse_object_kv_list "$db_line"

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
