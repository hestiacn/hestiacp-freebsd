#!/bin/bash
# info: add user sftp jail for FreeBSD
# options: USER [RESTART]
#
# example: v-add-user-sftp-jail admin
#
# This function enables sftp jailed environment natively on FreeBSD

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
restart=$2

# Includes
source /usr/local/etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

check_user_in_jail_list() {
	local check_list="$1"
	local target_user="$2"
	local old_ifs="$IFS"
	
	IFS=','
	set -- $check_list
	IFS="$old_ifs"

	for existing_user in "$@"; do
		if [ "$existing_user" = "$target_user" ]; then
			if [[ -d "/home/$target_user" && -z "$(find /home/$target_user -user root -print -prune -o -prune)" ]]; then
				chown root:root "/home/$target_user"
			fi
			exit 0
		fi
	done
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER'
is_format_valid 'user'
check=$(is_object_valid 'user' 'USER' "$user")
if [ $? -ne 0 ]; then
	user_str=$(grep "^$user:" /etc/passwd | egrep "rssh|nologin")
	#try to detect "owner" of the ftp_user if not found dont set it up
	user_owner=$(echo "$user_str" | cut -f6 -d : | cut -f3 -d /)
	is_object_valid 'user' 'USER' "$user_owner"
fi
user_str=$(grep "^$user:" /etc/passwd | egrep "rssh|nologin")
if [ -z "$user_str" ]; then
	exit
fi

# 获取当前已经加入 SFTP 沙箱的原始逗号分隔字符串列表
ssh_users=$(grep -A1 "^# Hestia SFTP Chroot" /etc/ssh/sshd_config | sed -n 2p | sed 's/Match User //')
check_user_in_jail_list "$ssh_users" "$user"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ -z "$ssh_users" ]; then
	new_users="$user"
else
	new_users="${ssh_users},${user}"
fi

sed -i "" "s/Match User $ssh_users/Match User $new_users/g" /etc/ssh/sshd_config

# Set home folder permission to root
if [ -d "/home/$user" ]; then
	chown root:root "/home/$user"
fi
add_chroot_jail "$user"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Restart ssh service
if [ "$restart" = 'no' ]; then
	# Skip restart of SSH daemon
	echo "" > /dev/null 2>&1
else
	service sshd restart > /dev/null 2>&1
fi

# Logging
log_event "$OK" "$ARGUMENTS"

exit 0
