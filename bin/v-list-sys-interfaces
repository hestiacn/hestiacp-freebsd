#!/bin/sh
# info: list system interfaces
# options: [FORMAT]
#
# example: v-list-sys-interfaces
#
# This function for obtaining the list of network interfaces.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format="${1:-shell}"

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	objects=$(echo "$physical_nics" | wc -l)
	i=1
	echo '['
	for interface in $physical_nics; do
		printf '    "%s"' "$interface"
		if [ "$i" -lt "$objects" ]; then
			echo ','
		else
			echo
		fi
		i=$((i + 1))
	done
	echo ']'
}

# SHELL list function
shell_list() {
	echo "INTERFACE"
	echo "---------"
	for interface in $physical_nics; do
		echo "$interface"
	done
}

# PLAIN list function
plain_list() {
	for interface in $physical_nics; do
		echo "$interface"
	done
}

# CSV list function
csv_list() {
	echo "INTERFACE"
	for interface in $physical_nics; do
		echo "$interface"
	done
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Defining interface list
# Detect "physical" NICs only (virtual NICs created by Docker, WireGuard etc. are excluded)
if command -v ip >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
	# Linux - using ip and jq
	physical_nics="$(ip -d -j link show 2>/dev/null | jq -r '.[] | if .link_type == "loopback" then empty else .ifname end')"
elif [ -f /sbin/ifconfig ] || [ -f /bin/ifconfig ]; then
	# FreeBSD - using ifconfig
	physical_nics="$(ifconfig -l 2>/dev/null | tr ' ' '\n' | grep -v '^lo' | grep -v '^vlan' | grep -v '^tun' | grep -v '^pflog')"
else
	physical_nics=""
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
