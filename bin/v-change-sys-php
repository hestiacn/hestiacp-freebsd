#!/bin/sh
# info: Change default php version server wide
# options: VERSION
#
# example: v-change-sys-php 84
#
# This function changes the system-wide default PHP version natively on FreeBSD.

version=$1

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

check_args '1' "$#" 'VERSION'

# Verify php version format
if ! echo "$version" | grep -qE '^[0-9]{2}$'; then
    echo "The specified PHP version format is invalid, it should look like 2 digits."
    echo "Example: 82, 83, 84, 85"
    exit "$E_INVALID"
fi

# Check if php version exists
version_check=$($BIN/v-list-sys-php plain | grep -w "$version")
if [ -z "$version_check" ]; then
    echo "ERROR: Specified PHP version is not installed."
    exit "$E_INVALID"
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# 更改系统默认 PHP 版本
if [ -f "/usr/local/bin/php$version" ]; then
    ln -sf "/usr/local/bin/php$version" "/usr/local/bin/php"
    echo "System default PHP changed to version $version"
fi

# 重建用户网站和邮件配置
for user in $("$BIN/v-list-users" list); do
    $BIN/v-rebuild-web-domains "$user" 'no' > /dev/null 2>&1
    $BIN/v-rebuild-mail-domains "$user" 'no' > /dev/null 2>&1
done

# Restart services
$BIN/v-restart-web-backend
$BIN/v-restart-web
$BIN/v-restart-proxy

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

log_event "$OK" "$ARGUMENTS"
echo "PHP default version changed to $version"
exit 0