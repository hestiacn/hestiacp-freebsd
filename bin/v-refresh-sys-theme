#!/bin/bash
# info: change active system theme
# options: NONE
#
# example: v-refresh-sys-theme
#
# This function for changing the currently active system theme.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Store current theme name
CURRENT_THEME="$THEME"

# Cycle theme to regenerate (helps if cache is stuck)
$BIN/v-change-sys-theme "default"
$BIN/v-change-sys-theme "$CURRENT_THEME"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
