#!/bin/sh
# info: update system IP
# options: NONE
#
# example: v-update-sys-ip
#          # Intended for internal usage
#
# This function scans configured IP in the system and register them with Hestia
# internal database. This call is intended for use on vps servers, where IP is
# set by hypervisor.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# shellcheck source=/usr/local/hestia/func/ip.sh
source "$HESTIA/func/ip.sh"
# shellcheck source=/usr/local/hestia/func/domain.sh
source "$HESTIA/func/domain.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Listing system IP addresses
if [ "$(uname)" = "FreeBSD" ]; then
	ips=""
	for iface in $(ifconfig -a | grep -E '^[a-z0-9]' | cut -d: -f1); do
		case "$iface" in lo0) continue ;; esac
		ip=$(ifconfig "$iface" | grep -E 'inet [0-9]' | grep -v '127.0.0.1' | awk '{print $2}')
		if [ -n "$ip" ]; then
			ips="${ips} ${ip}"
		fi
	done
else
	nics="$(ip -d -j link show | jq -r '.[] | if .link_type == "loopback" then empty else .ifname end')"
	ips=""
	
	for nic in $nics; do
		nic_type="$(ip -d -j link show "$nic" | jq -r '.[].linkinfo.info_kind')"
		if [ "$nic_type" = "bridge" ]; then
			continue
		fi
		nic_ipv4s="$(ip -4 -d -j addr show "$nic" | jq -r '.[] | select(length > 0) | .addr_info[] | if .scope == "global" then .local else empty end')"
		
		if [ -z "$ips" ]; then
			ips="$nic_ipv4s"
		else
			if [ -z "$nic_ipv4s" ]; then
				continue
			fi
			ips="$ips $nic_ipv4s"
		fi
	done
fi

ips=$(echo "$ips" | xargs)

v_ips=""
if [ -d "$HESTIA/data/ips" ]; then
	for ip_file in "$HESTIA/data/ips"/*; do
		[ -f "$ip_file" ] || continue
		v_ips="${v_ips} $(basename "$ip_file")"
	done
fi
v_ips=$(echo "$v_ips" | xargs)

ip_num=$(echo "$ips" | wc -w | tr -d ' ')
v_ip_num=$(echo "$v_ips" | wc -w | tr -d ' ')

if [ "$ip_num" -eq 1 ] && [ "$v_ip_num" -eq 1 ] && [ "$ips" != "$v_ips" ]; then
	old_ip="$v_ips"
	new_ip="$ips"
	
	# Updating configs
	mv "$HESTIA/data/ips/$old_ip" "$HESTIA/data/ips/$new_ip"
	new_timestamp

	# Updating IP's values
	ip="$new_ip"
	
	if [ "$(uname)" = "FreeBSD" ]; then
		for iface in $(ifconfig -a | grep -E '^[a-z0-9]' | cut -d: -f1); do
			case "$iface" in lo0) continue ;; esac
			check_ip=$(ifconfig "$iface" | grep -E 'inet [0-9]' | awk '{print $2}')
			if [ "$check_ip" = "$new_ip" ]; then
				interface="$iface"
				hex_mask=$(ifconfig "$iface" | grep -E 'inet [0-9]' | awk '{print $4}')
				hex_val=$(echo "$hex_mask" | sed 's/0x//')
				oct1=$(echo "$hex_val" | cut -c1-2)
				oct2=$(echo "$hex_val" | cut -c3-4)
				oct3=$(echo "$hex_val" | cut -c5-6)
				oct4=$(echo "$hex_val" | cut -c7-8)
				netmask="$((0x$oct1)).$((0x$oct2)).$((0x$oct3)).$((0x$oct4))"
				break
			fi
		done
	else
		interface=$(ip -4 addr show | grep -B2 "$new_ip" | head -1 | awk '{print $2}' | sed 's/:$//')
		prefixlen=$(ip -4 addr show | grep "$new_ip" | awk '{print $2}' | cut -d/ -f2)
		netmask=$(convert_cidr "$prefixlen")
	fi
	
	update_ip_value '$INTERFACE' "$interface"
	update_ip_value '$NETMASK' "$netmask"
	update_ip_value '$TIME' "$time"
	update_ip_value '$DATE' "$date"
	
	# Updating PROXY
	if [ -n "$PROXY_SYSTEM" ]; then
		if [ "$(uname)" = "FreeBSD" ]; then
			conf_dir="/usr/local/etc/$PROXY_SYSTEM/conf.d"
		else
			conf_dir="/etc/$PROXY_SYSTEM/conf.d"
		fi
		if [ -f "$conf_dir/$old_ip.conf" ]; then
			mv "$conf_dir/$old_ip.conf" "$conf_dir/$new_ip.conf"
			sed -i "s/$old_ip/$new_ip/g" "$conf_dir/$new_ip.conf"
		fi
	fi
	
	# Updating WEB
	if [ -n "$WEB_SYSTEM" ]; then
		if [ "$(uname)" = "FreeBSD" ]; then
			conf_dir="/usr/local/etc/$WEB_SYSTEM/conf.d"
		else
			conf_dir="/etc/$WEB_SYSTEM/conf.d"
		fi
		if [ -f "$conf_dir/$old_ip.conf" ]; then
			mv "$conf_dir/$old_ip.conf" "$conf_dir/$new_ip.conf"
			sed -i "s/$old_ip/$new_ip/g" "$conf_dir/$new_ip.conf"
		fi
		
		for user in $("$BIN/v-list-users" list); do
			sed -i "s/$old_ip/$new_ip/g" "$HESTIA/data/users/$user/web.conf"
			$BIN/v-rebuild-web-domains "$user" no
		done
		
		if [ "$(uname)" != "FreeBSD" ]; then
			if [ -f "/usr/local/etc/apache24/mods-available/remoteip.conf" ]; then
				sed -i "s/$old_ip/$new_ip/g" /usr/local/etc/apache24/mods-available/remoteip.conf
			fi
			if [ -f "/etc/apache2/mods-enabled/rpaf.conf" ]; then
				sed -i "s/$old_ip/$new_ip/g" /etc/apache2/mods-enabled/rpaf.conf
			fi
		fi
		
		$BIN/v-restart-proxy
		$BIN/v-restart-web
	fi
	
	# Updating MAIL
	if [ -n "$IMAP_SYSTEM" ]; then
		for user in $("$BIN/v-list-users" list); do
			$BIN/v-rebuild-mail-domains "$user" no
		done
		$BIN/v-restart-mail
	fi
	
	# Updating DNS
	if [ -n "$DNS_SYSTEM" ]; then
		for user in $("$BIN/v-list-users" list); do
			sed -i "s/$old_ip/$new_ip/g" "$HESTIA/data/users/$user/dns.conf"
			for dns_file in "$HESTIA/data/users/$user/dns"/*.conf; do
				[ -f "$dns_file" ] && sed -i "s/$old_ip/$new_ip/g" "$dns_file"
			done
			$BIN/v-rebuild-dns-domains "$user" no
		done
		$BIN/v-restart-dns
	fi
	
	# Updating FTP
	if [ -n "$FTP_SYSTEM" ] && [ "$FTP_SYSTEM" = 'vsftpd' ]; then
		if [ "$(uname)" = "FreeBSD" ]; then
			ftp_conf="/usr/local/etc/vsftpd.conf"
		else
			ftp_conf="/etc/vsftpd.conf"
		fi
		if [ -f "$ftp_conf" ]; then
			sed -i "s/$old_ip/$new_ip/g" "$ftp_conf"
			$BIN/v-restart-ftp
		fi
	fi
	
	# Updating firewall
	if [ -n "$FIREWALL_SYSTEM" ]; then
		sed -i "s/$old_ip/$new_ip/g" "$HESTIA/data/firewall"/*.conf
		$BIN/v-update-firewall
	fi
fi

# Adding system IP
for ip in $ips; do
	if [ ! -f "$HESTIA/data/ips/$ip" ]; then
		if [ "$(uname)" = "FreeBSD" ]; then
			for iface in $(ifconfig -a | grep -E '^[a-z0-9]' | cut -d: -f1); do
				case "$iface" in lo0) continue ;; esac
				check_ip=$(ifconfig "$iface" | grep -E 'inet [0-9]' | awk '{print $2}')
				if [ "$check_ip" = "$ip" ]; then
					interface="$iface"
					hex_mask=$(ifconfig "$iface" | grep -E 'inet [0-9]' | awk '{print $4}')
					hex_val=$(echo "$hex_mask" | sed 's/0x//')
					oct1=$(echo "$hex_val" | cut -c1-2)
					oct2=$(echo "$hex_val" | cut -c3-4)
					oct3=$(echo "$hex_val" | cut -c5-6)
					oct4=$(echo "$hex_val" | cut -c7-8)
					netmask="$((0x$oct1)).$((0x$oct2)).$((0x$oct3)).$((0x$oct4))"
					break
				fi
			done
		else
			interface=$(ip -4 addr show | grep -B2 "$ip" | head -1 | awk '{print $2}' | sed 's/:$//')
			prefixlen=$(ip -4 addr show | grep "$ip" | awk '{print $2}' | cut -d/ -f2)
			netmask=$(convert_cidr "$prefixlen")
		fi
		$BIN/v-add-sys-ip "$ip" "$netmask" "$interface"
	elif [ -f "/etc/nginx/conf.d/$ip.conf" ] && [ "$(uname)" != "FreeBSD" ]; then
		process_http2_directive "/etc/nginx/conf.d/$ip.conf"
	fi
done

# Updating NAT
pub_ipv4=$(curl -fsLm5 --retry 2 --ipv4 https://ip.hestiacp.com)
if [ -n "$pub_ipv4" ] && [ ! -f "$HESTIA/data/ips/$pub_ipv4" ]; then
	if ! grep -q "$pub_ipv4" "$HESTIA/data/ips/"/*; then
		first_ip=$(ls -t "$HESTIA/data/ips/" | head -1)
		if [ -n "$first_ip" ]; then
			$BIN/v-change-sys-ip-nat "$first_ip" "$pub_ipv4"
		fi
	fi
fi

# Updating IP usage counters
$BIN/v-update-sys-ip-counters

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
