#!/bin/sh
# info: get system timezone
# options: [FORMAT]
#
# This function to get system timezone

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Checking timesonze on FreeBSD
if [ -f "/var/db/zoneinfo" ]; then
    ZONE=$(cat /var/db/zoneinfo)
# Checking timesonze on RHEL/CentOS
elif [ -f "/etc/sysconfig/clock" ]; then
    # shellcheck source=/etc/sysconfig/clock
    source /etc/sysconfig/clock
    ZONE="$ZONE"
# Checking timesonze on Debian/Ubuntu
elif [ -f "/etc/timezone" ]; then
    ZONE=$(cat /etc/timezone)
# Checking symlynks
elif [ -h /etc/localtime ]; then
    ZONE=$(readlink /etc/localtime | sed 's|.*/zoneinfo/||')
fi

echo "$ZONE"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit