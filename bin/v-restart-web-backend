#!/bin/bash
# info: restart php interpreter
# options: NONE
#
# example: v-restart-web-backend
#
# This function reloads php interpreter configuration.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
restart=$1
version=$2

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
	SED_OPTS="-i"
	OS="linux"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
	SED_OPTS="-i ''"
	OS="freebsd"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

send_email_report() {
	email=$(grep CONTACT "$HESTIA/data/users/$ROOT_USER/user.conf")
	email=$(echo "$email" | cut -f 2 -d "'")
	subj="$(hostname): $WEB_BACKEND restart failed"
	cat "$tmpfile" | $SENDMAIL -s "$subj" "$email"
	if [ -f "$tmpfile" ]; then
		rm -f "$tmpfile"
	fi
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

is_format_valid 'restart'

if [ -n "$version" ]; then
	if [[ ! $version =~ ^[0-9]+\.[0-9]+ ]]; then
		echo "The specified PHP version format is invalid, it should look like [0-9].[0-9]."
		echo "Example: 7.0, 7.4, 8.0"
		exit "$E_INVALID"
	fi
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Exit
if [ -z "$WEB_BACKEND" ] || [ "$WEB_BACKEND" = 'remote' ]; then
	exit
fi

if [ "$restart" = "no" ]; then
	exit
fi

# Schedule restart
if [ "$restart" = 'scheduled' ] || { [ -z "$restart" ] && [ "$SCHEDULED_RESTART" = 'yes' ]; }; then
	eval "sed $SED_OPTS \"/\/$SCRIPT now/d\" \"$HESTIA/data/queue/restart.pipe\""
	echo "$BIN/$SCRIPT now" >> "$HESTIA/data/queue/restart.pipe"
	exit
fi

tmpfile=$(mktemp)

if [ -z "$version" ]; then
	# Substitute php-fpm service name formats
	for version in $($BIN/v-list-sys-php plain); do
		if [ "$OS" = "linux" ]; then
			dummy_conf="/etc/php/${version}/fpm/pool.d/dummy.conf"
			if [ ! -f "$dummy_conf" ]; then
				cp -f "$HESTIA_INSTALL_DIR/php-fpm/dummy.conf" "/etc/php/${version}/fpm/pool.d/"
				sed -i "s/9999/99${version//./}/g" "/etc/php/${version}/fpm/pool.d/dummy.conf"
			fi
			v_php="php$version-fpm"
		else
			version_clean=$(echo "$version" | tr -d '.')
			dummy_conf="/usr/local/etc/php${version_clean}/php-fpm.d/dummy.conf"
			if [ ! -f "$dummy_conf" ]; then
				mkdir -p "/usr/local/etc/php${version_clean}/php-fpm.d"
				cp -f "$HESTIA_INSTALL_DIR/php-fpm/dummy.conf" "$dummy_conf"
				sed -i '' "s/9999/99${version_clean}/g" "$dummy_conf"
			fi
			v_php="php${version_clean}_fpm"
		fi

		$BIN/v-restart-service "$v_php" "$restart"
		if [ $? -ne 0 ]; then
			send_email_report
			check_result "$E_RESTART" "$v_php restart failed"
		fi
	done
else
	if [ "$OS" = "linux" ]; then
		v_php="php$version-fpm"
	else
		version_clean=$(echo "$version" | tr -d '.')
		v_php="php${version_clean}_fpm"
	fi
	$BIN/v-restart-service "$v_php" "$restart"
	if [ $? -ne 0 ]; then
		send_email_report
		check_result "$E_RESTART" "$v_php restart failed"
	fi
fi

# Update restart queue
if [ -e "$HESTIA/data/queue/restart.pipe" ]; then
	eval "sed $SED_OPTS \"/\/$SCRIPT now/d\" \"$HESTIA/data/queue/restart.pipe\""
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

if [ -f "$tmpfile" ]; then
	rm -f "$tmpfile"
fi
exit
