#!/bin/bash
# info: restart cron service
# options: NONE
#
# example: v-restart-cron
#
# This function tells crond service to reread its configuration files.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
restart_type=$1

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
	SED_OPTS="-i"
	OS="linux"
	SERVICE_CMD="systemctl"
	CRON_SERVICE_NAME="$CRON_SYSTEM"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
	SED_OPTS="-i ''"
	OS="freebsd"
	SERVICE_CMD="service"
	CRON_SERVICE_NAME="cron"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

send_email_report() {
	email=$(grep CONTACT "$HESTIA/data/users/$ROOT_USER/user.conf")
	email=$(echo "$email" | cut -f 2 -d "'")
	tmpfile=$(mktemp)
	subj="$(hostname): $CRON_SYSTEM restart failed"
	
	# 只收集状态信息，不重启
	if [ "$OS" = "freebsd" ]; then
		service "$CRON_SERVICE_NAME" status >> "$tmpfile" 2>&1
	else
		systemctl status "$CRON_SYSTEM" >> "$tmpfile" 2>&1
	fi
	
	cat "$tmpfile" | $SENDMAIL -s "$subj" "$email"
	rm -f "$tmpfile"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

is_format_valid 'restart'

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Exit if no local cron
if [ -z "$CRON_SYSTEM" ] || [ "$CRON_SYSTEM" = 'remote' ]; then
	exit
fi

# Schedule restart
if [ "$restart_type" = 'scheduled' ] || [ -z "$restart_type" ] && [ "$SCHEDULED_RESTART" = 'yes' ]; then
	eval "sed $SED_OPTS \"/\/$SCRIPT now/d\" \"$HESTIA/data/queue/restart.pipe\""
	echo "$BIN/$SCRIPT now" >> "$HESTIA/data/queue/restart.pipe"
	exit
fi

if [ "$restart_type" = "no" ] || [ -z "$restart_type" ]; then
	exit
fi

# Restart cron service
if [ "$OS" = "freebsd" ]; then
	service "$CRON_SERVICE_NAME" restart > /dev/null 2>&1
else
	$BIN/v-restart-service "$CRON_SYSTEM" > /dev/null 2>&1
fi

if [ $? -ne 0 ]; then
	send_email_report
	check_result "$E_RESTART" "$CRON_SYSTEM restart failed"
fi

# Update restart queue
if [ -e "$HESTIA/data/queue/restart.pipe" ]; then
	eval "sed $SED_OPTS \"/\/$SCRIPT now/d\" \"$HESTIA/data/queue/restart.pipe\""
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
