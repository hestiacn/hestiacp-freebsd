#!/bin/sh
# info: delete php fpm version
# options: VERSION
#
# example: v-delete-web-php 73
#
# This function checks and delete a fpm php version if not used by any domain.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
version=$1

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'VERSION'

if [ -z "$WEB_BACKEND" ]; then
    echo "Multiple php versions are not supported for modphp"
fi

# Set file locations
php_fpm_rc="/usr/local/etc/rc.d/php$version-fpm"
php_config_dir="/usr/local/etc/php$version"

# Verify php version format (FreeBSD: 73, 80, 81, 82, 83, 84, 85)
if ! echo "$version" | grep -qE '^[0-9]{2}$'; then
    echo "The PHP version format is invalid, it should look like 2 digits."
    echo "Example: 73, 80, 81, 82, 83, 84, 85"
    exit "$E_INVALID"
fi

# Remove backend template
if [ -f "$HESTIA/data/templates/web/php-fpm/PHP-${version}.tpl" ]; then
    rm -f "$HESTIA/data/templates/web/php-fpm/PHP-${version}.tpl"
fi

# Check if php version exists
version_check=$($BIN/v-list-sys-php plain | grep -w "$version")
if [ -z "$version_check" ]; then
    echo "ERROR: Specified PHP version is not installed."
    exit "$E_INVALID"
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Build package list for removal (FreeBSD ć ĽĺĽŹ)
mph="php$version php$version-extensions php$version-mbstring php$version-bcmath php$version-curl
     php$version-gd php$version-intl php$version-mysqli
     php$version-soap php$version-xml php$version-zip php$version-bz2
     php$version-pspell php$version-pecl-imagick php$version-pgsql php$version-pecl-imap
     php$version-ldap php$version-pecl-APCu php$version-filter php$version-session
     php$version-tokenizer php$version-readline php$version-pdo php$version-pdo_mysql php$version-pdo_pgsql"

# Check if version is 73 or below to remove mcrypt
if [ "$version" -lt 80 ] 2>/dev/null; then
    mph="$mph php$version-mcrypt"
fi

# Purge php packages (FreeBSD ć–ąĺĽŹ)
pkg delete -y $mph > /dev/null 2>&1 &

BACK_PID=$!

echo "Removing PHP-$version, please wait..."
spinner="/-\|"
spin_i=1
while kill -0 $BACK_PID > /dev/null 2>&1; do
    printf "\b${spinner:spin_i++%${#spinner}:1}"
    sleep 0.5
done

echo

# Check if removal was successful
if [ -f "$php_fpm_rc" ]; then
    echo "ERROR: Uninstallation failed, please run the following command manually for debugging:"
    echo "pkg delete -y $mph"
    exit 1
fi

# Cleanup php folder
if [ -d "$php_config_dir" ]; then
    rm -rf "$php_config_dir"
fi

# Remove RC script
if [ -f "$php_fpm_rc" ]; then
    rm -f "$php_fpm_rc"
fi

# Disable service in rc.conf
sed -i '' "/php${version}_fpm_enable/d" /etc/rc.conf

# Check if any PHP-FPM remains, if not restart web backend
if [ "$WEB_BACKEND" = "php-fpm" ]; then
    remaining=$(find /usr/local/etc -maxdepth 1 -name "php[0-9][0-9]" -type d 2>/dev/null | head -1)
    if [ -z "$remaining" ]; then
        $BIN/v-restart-web-backend
    fi
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Info" "System" "Uninstalled PHP $version."
log_event "$OK" "$ARGUMENTS"

echo "PHP $version uninstalled successfully!"
exit
