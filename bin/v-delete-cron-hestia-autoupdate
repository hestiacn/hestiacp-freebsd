#!/bin/sh
# info: delete hestia autoupdate cron job
# options: NONE
#
# This function deletes hestia autoupdate cron job.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

is_system_enabled "$CRON_SYSTEM" 'CRON_SYSTEM'

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# FreeBSD: cron path is /var/cron/tabs/ instead of /var/spool/cron/crontabs/
# FreeBSD sed requires -i "" for in-place editing
sed -i "" "/v-update-sys-hestia-all/d" "/var/cron/tabs/hestiaweb"
sed -i "" "/v-update-sys-hestia-git/d" "/var/cron/tabs/hestiaweb"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Restarting crond
$BIN/v-restart-cron
check_result $? "Cron restart failed" > /dev/null

# Logging
$BIN/v-log-action "system" "Warning" "System" "Automatic updates disabled."
log_event "$OK" "$ARGUMENTS"

exit 0
