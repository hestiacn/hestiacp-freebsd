#!/bin/bash
# info: listing available webmail clients
# options: [FORMAT]
# labels: hestia mail
#
# example: v-list-sys-webmail
#
# List available webmail clients

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
    clients=${WEBMAIL_SYSTEM//,/ }
    i=1
    objects=$(echo "$clients" | wc -w)
    echo '['
    for client in $clients; do
        if [ "$i" -ne "$objects" ]; then
            printf '    "%s",\n' "$client"
        else
            printf '    "%s"\n' "$client"
        fi
        i=$((i + 1))
    done
    echo ']'
}

# SHELL list function
shell_list() {
    echo "Webmail Client"
    echo "--------------"
    for client in ${WEBMAIL_SYSTEM//,/ }; do
        echo "$client"
    done
}

# PLAIN list function
plain_list() {
    for client in ${WEBMAIL_SYSTEM//,/ }; do
        echo "$client"
    done
}

# CSV list function
csv_list() {
    echo "CLIENT"
    for client in ${WEBMAIL_SYSTEM//,/ }; do
        echo "$client"
    done
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Listing data
case $format in
    json) json_list ;;
    plain) plain_list ;;
    csv) csv_list ;;
    shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
