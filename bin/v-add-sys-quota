#!/bin/sh
# info: add system quota for FreeBSD
# options: NONE
#
# example: v-add-sys-quota
#
# This function enables filesystem quota on FreeBSD UFS/ZFS partition

#----------------------------------------------------------#
#                 Variable & Function                      #
#----------------------------------------------------------#

# Includes
source /usr/local/etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA"/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Extracting FreeBSD file system and partition info
mnt=$(df -P /home | awk '{print $6}' | tail -n1)
if [ -z "$mnt" ]; then
    mnt="/"
fi

lnr=$(awk -v mnt="$mnt" '$1 !~ /^#/ && $2 == mnt {print NR; exit}' /etc/fstab)

# Verify line number was found
if [ -z "$lnr" ]; then
    log_history "Error: No entry found in /etc/fstab for $mnt"
    exit "$E_NOTEXIST"
fi

# Read fstab line details
read -r _ _ fstype opt _ _ < <(sed -n "${lnr}p" /etc/fstab)

# FreeBSD UFS/ZFS quota configuration
case "$fstype" in
    ufs|ufs2)
        log_history "UFS filesystem detected on $mnt. Configuring FreeBSD quota."

        # Check if quota options are already present
        if ! echo "$opt" | grep -qE "userquota|groupquota"; then
            # Clean up any existing quota-related options
            clean_opts=$(echo "$opt" | tr ',' '\n' | grep -vE '^(userquota|groupquota)' | tr '\n' ',' | sed 's/,$//')
            
            if [ -n "$clean_opts" ]; then
                new_full_opts="${clean_opts},userquota,groupquota"
            else
                new_full_opts="userquota,groupquota"
            fi

            # Update fstab
            sed -i "" "${lnr}s|$opt|$new_full_opts|" /etc/fstab
            log_history "Added userquota,groupquota to fstab for $mnt"
            
            # Remount with new options
            mount -u -o userquota,groupquota "$mnt" > /dev/null 2>&1
            log_history "Remounted $mnt with quota options"
        fi

        # Enable quota in rc.conf
        if ! grep -q "^quota_enable=\"YES\"" /etc/rc.conf 2>/dev/null; then
            echo 'quota_enable="YES"' >> /etc/rc.conf
            echo 'check_quotas="YES"' >> /etc/rc.conf
            log_history "Enabled quota in /etc/rc.conf"
        fi

        # Create quota files
        if [ ! -f "$mnt/quota.user" ]; then
            quotacheck -vug "$mnt" > /dev/null 2>&1
            log_history "Created quota files on $mnt"
        fi

        # Enable quotas
        quotaon -vug "$mnt" > /dev/null 2>&1
        check_result $? "quota can't be enabled on $mnt" "$E_DISK"
        ;;

    zfs)
        log_history "ZFS filesystem detected. Configuring ZFS quota."

        current_quota=$(zfs get quota "$mnt" 2>/dev/null | awk 'NR==2 {print $3}')
        if [ "$current_quota" = "none" ] || [ -z "$current_quota" ]; then
            # ZFS doesn't need fstab entries
            # Quotas are set per dataset/user/group
            log_history "ZFS quota support ready (set via zfs set)"
        fi

        if ! zfs get userquota@ "$mnt" 2>/dev/null | grep -q "local"; then
            zfs set userquota@=none "$mnt" 2>/dev/null
            zfs set groupquota@=none "$mnt" 2>/dev/null
            log_history "Enabled ZFS user/group quota support"
        fi
        ;;

    *)
        log_history "Unsupported filesystem: $fstype"
        echo "Error: Hestia does not support quotas on $fstype filesystem."
        exit "$E_DISK"
        ;;
esac

# Add periodic quotacheck (FreeBSD style)
mkdir -p /etc/periodic/daily
cron_file="/etc/periodic/daily/hestia-quotacheck"

cat > "$cron_file" << 'EOF'
#!/bin/sh
# Periodic quotacheck for FreeBSD
if [ -d /home ]; then
    /sbin/quotacheck -vug /home 2>/dev/null
fi
EOF
chmod a+x "$cron_file"
log_history "Added periodic quotacheck to /etc/periodic/daily/"

# Update hestia.conf value
$BIN/v-change-sys-config-value "DISK_QUOTA" "yes"

# Rebuild user quota
for user in $("$BIN"/v-list-users list); do
    $BIN/v-update-user-quota "$user"
done
log_history "User quotas updated successfully."

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Info" "Plugins" "System Quota enforcement enabled."
log_history "system quota enforcement enabled"
log_event "$OK" "$ARGUMENTS"

exit 0
