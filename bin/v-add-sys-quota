#!/bin/bash
# info: add system quota for FreeBSD
# options: NONE
#
# example: v-add-sys-quota
#
# This function enables native filesystem quota on FreeBSD storage partition

#----------------------------------------------------------#
#                 Variable & Function                      #
#----------------------------------------------------------#

# Includes
source /usr/local/etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA"/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Extracting FreeBSD file system and partition info
# 精准提取 /home 分区，完美对齐多租户骨架总线大本营 [INDEX]
mnt=$(df -P /home | awk '{print $6}' | tail -n1)
lnr=$(awk -v mnt="$mnt" '$1 !~ /^#/ && $2 == mnt {print NR; exit}' /etc/fstab)

# Verify line number was found in FreeBSD fstab
if [ -z "$lnr" ]; then
	log_history "Error: No entry found in /etc/fstab for $mnt"
	exit "$E_NOTEXIST"
fi

# Read fstab line details
read -r _ _ fstype opt _ _ < <(sed -n "${lnr}p" /etc/fstab)

# 🌟 针对 FreeBSD 原生文件系统环境执行最高规格存储总线配置 [INDEX]
if [ "$fstype" = "ufs" ] || [ "$fstype" = "ufs2" ] || [ "$fstype" = "zfs" ]; then
	log_history "FreeBSD $fstype filesystem detected on $mnt. Configuring native quota."

	# 检查当前挂载选项中是否已具备 FreeBSD 官方合规的配额关键字 [INDEX]
	if ! echo "$opt" | grep -qE "userquota|groupquota"; then
		# 清洗可能存在的旧属性，重新安全揉碎并拼接
		clean_opts=$(echo "$opt" | tr ',' '\n' | grep -vE '^(usrquota|grpquota|prjquota|usrjquota=|grpjquota=|prjjquota=|jqfmt=|uquota|gquota|pquota|userquota|groupquota)' | tr '\n' ',' | sed 's/,$//')
		
		if [ -n "$clean_opts" ]; then
			new_full_opts="${clean_opts},userquota,groupquota"
		else
			new_full_opts="userquota,groupquota"
		fi

		# 补齐符合 FreeBSD 原生 BSD sed 的硬性 "" 空缀原地覆写规则，彻底阻断报错 [INDEX]
		sed -i "" "${lnr}s|$opt|$new_full_opts|" /etc/fstab
		
		# 🌟 核心注册：利用 FreeBSD 原生的 sysrc 注册机制，通知系统内核开机自动激活配额防护网 [INDEX]
		/usr/sbin/sysrc quota_enable="YES" > /dev/null 2>&1
		/usr/sbin/sysrc check_quotas="YES" > /dev/null 2>&1

		# 下发 FreeBSD 非卸载式的平滑重挂载命令，实现 0 延时现场注入 [INDEX]
		mount -u -o userquota,groupquota "$mnt" > /dev/null 2>&1 || true
		log_history "Remounted $mnt with FreeBSD native quota options."
	fi
fi

# 🌟 核心自愈：现场调用 FreeBSD 官方正统的二进制配额索引器对 /home 磁盘执行初始物理账本大盘点 [INDEX]
/sbin/quotacheck -vu "$mnt" > /dev/null 2>&1
/sbin/quotacheck -vg "$mnt" > /dev/null 2>&1

# Adding quotacheck on reboot
touch /forcequotacheck

# =========================================================================
# 🌟 核心自愈与位置归位：完美落实您的工程方针，将定时任务调整命名并挪入 FreeBSD 专属位置
# =========================================================================
# 确保目标多级物理缓存目录存在，并注入带有正统 999. 数字前缀的合规脚本文件名 [INDEX]
mkdir -p /etc/periodic/daily
cron_file="/etc/periodic/daily/hestia-quotacheck"

echo '#!/bin/sh' > "$cron_file"
echo 'touch /forcequotacheck' >> "$cron_file"
# 每日深夜自动呼叫 FreeBSD 官方二进制配额审计总闸，保障用户磁盘统计率 100% 绝对精准！ [INDEX]
echo '/sbin/quotacheck -vu /home >/dev/null 2>&1' >> "$cron_file"
echo '/sbin/quotacheck -vg /home >/dev/null 2>&1' >> "$cron_file"
chmod a+x "$cron_file"

# Enabling group and user quota via FreeBSD native binary [INDEX]
if /sbin/quotaon -p "$mnt" 2>/dev/null | grep -E 'user|group' | grep -q 'disabled' || [ -z "$(/sbin/quotaon -p "$mnt" 2>/dev/null)" ]; then
	/sbin/quotaon -vu "$mnt" > /dev/null 2>&1
	/sbin/quotaon -vg "$mnt" > /dev/null 2>&1
	check_result $? "quota can't be enabled in $mnt" "$E_DISK"
fi

# Updating hestia.conf value
$BIN/v-change-sys-config-value "DISK_QUOTA" "yes"

# Rebuilding user quota (only if reboot is not required)
if [ "$reboot_req" != "Y" ]; then
	for user in $("$BIN"/v-list-users list); do
		"$BIN"/v-update-user-quota "$user"
	done
	log_history "User quotas updated successfully."
else
	# =========================================================================
	# 🚀 降维重构：完美平替 Linux /etc/cron.d/ 一次性任务，对接 FreeBSD /etc/rc.local
	# =========================================================================
	# 建立符合 FreeBSD 专属的开机自愈配额回灌脚本
	cat > /usr/local/hestia/bin/v-update-quotas-after-reboot.sh << 'EOF'
#!/bin/sh
BIN=/usr/local/hestia/bin
for user in $("$BIN"/v-list-users list); do
        "$BIN"/v-update-user-quota "$user"
done
# 清理自愈：在 FreeBSD 系统中执行完一键自动销毁，不积攒任何运维皮牛癣文件
rm -f /usr/local/hestia/bin/v-update-quotas-after-reboot.sh
if [ -f "/etc/rc.local" ]; then
	sed -i "" "/v-update-quotas-after-reboot.sh/d" /etc/rc.local
fi
EOF
	chmod +x /usr/local/hestia/bin/v-update-quotas-after-reboot.sh

	# 完美注入：将一次性任务配置挂载到 FreeBSD 标准的开机自启脚本末尾中
	touch /etc/rc.local
	chmod 555 /etc/rc.local
	echo "/usr/local/hestia/bin/v-update-quotas-after-reboot.sh &" >> /etc/rc.local

	log_history "Created one-time job to update user quotas after reboot."
	echo "[ ! ] Note: User quotas will be automatically updated after the system reboots."
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
"$BIN"/v-log-action "system" "Info" "Plugins" "System Quota enforcement enabled."
log_history "system quota enforcement enabled"
log_event "$OK" "$ARGUMENTS"

if [ "$reboot_req" = "Y" ]; then
	log_history "A system reboot is required to complete enable quota."
	echo "[ ! ] Note: A system reboot is required to complete quota setup."
fi

exit
