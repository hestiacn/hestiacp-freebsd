#!/bin/bash
# info: list mail domains
# options: USER [FORMAT]
#
# example: v-list-mail-domains admin
#
# This function of obtaining the list of all user domains.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "DOMAIN" "$USER_DATA/mail.conf")
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo -n "    \"$DOMAIN\": {"
		echo -n "\"ANTIVIRUS\": \"$ANTIVIRUS\", "
		echo -n "\"ANTISPAM\": \"$ANTISPAM\", "
		echo -n "\"REJECT\": \"$REJECT\", "
		echo -n "\"RATE_LIMIT\": \"$RATE_LIMIT\", "
		echo -n "\"DKIM\": \"$DKIM\", "
		echo -n "\"CATCHALL\": \"$CATCHALL\", "
		echo -n "\"ACCOUNTS\": \"$ACCOUNTS\", "
		echo -n "\"U_DISK\": \"$U_DISK\", "
		echo -n "\"SSL\": \"$SSL\", "
		echo -n "\"SUSPENDED\": \"$SUSPENDED\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo -n "\"DATE\": \"$DATE\", "
		echo -n "\"WEBMAIL_ALIAS\": \"$WEBMAIL_ALIAS\", "
		echo "\"WEBMAIL\": \"$WEBMAIL\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$USER_DATA/mail.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-10s %-10s %-10s %-6s %-6s %-6s %-8s %-6s %-12s\n" \
		"DOMAIN" "ANTIVIRUS" "ANTISPAM" "DKIM" "SSL" "ACC" "DISK" "SPND" "DATE"
	printf "%-10s %-10s %-10s %-6s %-6s %-6s %-8s %-6s %-12s\n" \
		"------" "---------" "--------" "----" "---" "---" "----" "----" "----"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%-10s %-10s %-10s %-6s %-6s %-6s %-8s %-6s %-12s\n" \
			"$DOMAIN" "$ANTIVIRUS" "$ANTISPAM" "$DKIM" "$SSL" "$ACCOUNTS" "$U_DISK" "$SUSPENDED" "$DATE"
	done < "$USER_DATA/mail.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$DOMAIN" "$ANTIVIRUS" "$ANTISPAM" "$DKIM" "$SSL" "$CATCHALL" \
			"$ACCOUNTS" "$U_DISK" "$SUSPENDED" "$TIME" "$DATE" "$WEBMAIL_ALIAS" "$WEBMAIL"
	done < "$USER_DATA/mail.conf"
}

# CSV list function
csv_list() {
	echo "DOMAIN,ANTIVIRUS,ANTISPAM,DKIM,SSL,CATCHALL,ACCOUNTS,U_DISK,SUSPENDED,TIME,DATE,WEBMAIL_ALIAS,WEBMAIL"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo "$DOMAIN,$ANTIVIRUS,$ANTISPAM,$DKIM,$SSL,$CATCHALL,$ACCOUNTS,$U_DISK,$SUSPENDED,$TIME,$DATE,$WEBMAIL_ALIAS,$WEBMAIL"
	done < "$USER_DATA/mail.conf"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ ! -f "$USER_DATA/mail.conf" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No mail domains found" ;;
		plain) ;;
		csv) echo "DOMAIN,ANTIVIRUS,ANTISPAM,DKIM,SSL,CATCHALL,ACCOUNTS,U_DISK,SUSPENDED,TIME,DATE,WEBMAIL_ALIAS,WEBMAIL" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
