#!/bin/sh
# info: list available APIs
# options: [FORMAT]
#
# example: v-list-apis json

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format="${1:-shell}"

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
    first=1
    echo '{'
    for api_file in "$HESTIA/data/api"/*; do
        [ -f "$api_file" ] || continue
        api=$(basename -- "$api_file")
        
        ROLE=""
        COMMANDS=""
        source_conf "$HESTIA/data/api/$api"
        
        COMMANDS_ARR='[]'
        if [ -n "$COMMANDS" ]; then
            COMMANDS_ARR="[\"$(echo "$COMMANDS" | sed 's|,|", "|g')\"]"
        fi
        
        if [ "$first" -eq 0 ]; then
            echo ','
        fi
        first=0
        echo -n "    \"$api\": {\"COMMANDS\": $COMMANDS_ARR, \"ROLE\": \"$ROLE\"}"
    done
    echo ''
    echo '}'
}

# SHELL list function
shell_list() {
    printf "%-20s %-10s %-50s\n" "API" "ROLE" "COMMANDS"
    printf "%-20s %-10s %-50s\n" "---" "----" "--------"
    
    for api_file in "$HESTIA/data/api"/*; do
        [ -f "$api_file" ] || continue
        api=$(basename -- "$api_file")
        
        ROLE=""
        COMMANDS=""
        source_conf "$HESTIA/data/api/$api"
        
        printf "%-20s %-10s %-50s\n" "$api" "$ROLE" "$COMMANDS"
    done
}

# Listing data
case $format in
    json) json_list ;;
    shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
