#!/bin/sh
# info: list user cron jobs
# options: USER [FORMAT]
#
# example: v-list-cron-jobs admin
#
# This function for obtaining the list of all users cron jobs.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "JOB" "$USER_DATA/cron.conf" || echo 0)
	echo "{"
	while read -r str; do
		parse_object_kv_list "$str"
		CMD=$(echo "$CMD" | sed -e 's/"/\\"/g' -e "s/%quote%/'/g")
		echo -n "    \"$JOB\": {"
		echo -n "\"MIN\": \"$MIN\", "
		echo -n "\"HOUR\": \"$HOUR\", "
		echo -n "\"DAY\": \"$DAY\", "
		echo -n "\"MONTH\": \"$MONTH\", "
		echo -n "\"WDAY\": \"$WDAY\", "
		echo -n "\"CMD\": \"$CMD\", "
		echo -n "\"JOB\": \"$JOB\", "
		echo -n "\"SUSPENDED\": \"$SUSPENDED\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$USER_DATA/cron.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-6s %-6s %-6s %-6s %-8s %-6s %-50s\n" "JOB" "MIN" "HOUR" "DAY" "MONTH" "WDAY" "COMMAND"
	printf "%-6s %-6s %-6s %-6s %-8s %-6s %-50s\n" "---" "---" "----" "---" "-----" "----" "-------"
	while read -r str; do
		parse_object_kv_list "$str"
		CMD=$(echo "$CMD" | sed -e 's/"/\\"/g' -e "s/%quote%/'/g")
		printf "%-6s %-6s %-6s %-6s %-8s %-6s %-50s\n" "$JOB" "$MIN" "$HOUR" "$DAY" "$MONTH" "$WDAY" "$CMD"
	done < "$USER_DATA/cron.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		parse_object_kv_list "$str"
		CMD=$(echo "$CMD" | sed -e 's/"/\\"/g' -e "s/%quote%/'/g")
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$JOB" "$MIN" "$HOUR" "$DAY" "$MONTH" "$WDAY" "$CMD" "$SUSPENDED" "$TIME" "$DATE"
	done < "$USER_DATA/cron.conf"
}

# CSV list function
csv_list() {
	echo "JOB,MIN,HOUR,DAY,MONTH,WDAY,CMD,SUSPENDED,TIME,DATE"
	while read -r str; do
		parse_object_kv_list "$str"
		CMD=$(echo "$CMD" | sed -e 's/"/\\"/g' -e "s/%quote%/'/g")
		echo "\"$JOB\",\"$MIN\",\"$HOUR\",\"$DAY\",\"$MONTH\",\"$WDAY\",\"$CMD\",\"$SUSPENDED\",\"$TIME\",\"$DATE\""
	done < "$USER_DATA/cron.conf"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#
if [ ! -f "$USER_DATA/cron.conf" ]; then
	echo "No cron jobs found for user $user"
	exit 0
fi
# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
