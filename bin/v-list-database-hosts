#!/bin/sh
# info: list database hosts
# options: [FORMAT]
#
# example: v-list-database-hosts json
#
# This function for obtaining the list of all configured database hosts.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# shellcheck source=/usr/local/hestia/func/db.sh
source "$HESTIA/func/db.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	first=1
	echo "["
	for type in $(echo "$DB_SYSTEM" | sed 's/,/ /g'); do
		if [ -e "$HESTIA/conf/$type.conf" ]; then
			# Set default port values
			database_set_default_ports
			while read -r str; do
				[ -z "$str" ] && continue
				parse_object_kv_list "$str"
				if [ "$first" -eq 0 ]; then
					echo ","
				fi
				first=0
				echo '    {'
				echo "        \"HOST\": \"$HOST\","
				echo "        \"PORT\": \"$PORT\","
				echo "        \"TYPE\": \"$type\","
				echo "        \"CHARSETS\": \"$CHARSETS\","
				echo "        \"MAX_DB\": \"$MAX_DB\","
				echo "        \"U_SYS_USERS\": \"$U_SYS_USERS\","
				echo "        \"U_DB_BASES\": \"$U_DB_BASES\","
				echo "        \"TPL\": \"$TPL\","
				echo "        \"SUSPENDED\": \"$SUSPENDED\","
				echo "        \"TIME\": \"$TIME\","
				echo "        \"DATE\": \"$DATE\""
				echo -n "    }"
			done < "$HESTIA/conf/$type.conf"
		fi
	done
	echo ""
	echo "]"
}

# SHELL list function
shell_list() {
	printf "%-20s %-8s %-10s %-8s %-10s %-6s %-10s %-10s\n" "HOST" "PORT" "TYPE" "MAX_DB" "DB_USED" "SPND" "TIME" "DATE"
	printf "%-20s %-8s %-10s %-8s %-10s %-6s %-10s %-10s\n" "----" "----" "----" "------" "-------" "----" "----" "----"
	for type in $(echo "$DB_SYSTEM" | sed 's/,/ /g'); do
		if [ -e "$HESTIA/conf/$type.conf" ]; then
			database_set_default_ports
			while read -r str; do
				[ -z "$str" ] && continue
				parse_object_kv_list "$str"
				printf "%-20s %-8s %-10s %-8s %-10s %-6s %-10s %-10s\n" \
					"$HOST" "$PORT" "$type" "$MAX_DB" "$U_DB_BASES" "$SUSPENDED" "$TIME" "$DATE"
			done < "$HESTIA/conf/$type.conf"
		fi
	done
}

# PLAIN list function
plain_list() {
	for type in $(echo "$DB_SYSTEM" | sed 's/,/ /g'); do
		if [ -e "$HESTIA/conf/$type.conf" ]; then
			database_set_default_ports
			while read -r str; do
				[ -z "$str" ] && continue
				parse_object_kv_list "$str"
				printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
					"$HOST" "$PORT" "$type" "$CHARSETS" "$MAX_DB" "$U_SYS_USERS" "$U_DB_BASES" "$TPL" "$SUSPENDED" "$TIME" "$DATE"
			done < "$HESTIA/conf/$type.conf"
		fi
	done
}

# CSV list function
csv_list() {
	echo "HOST,PORT,TYPE,CHARSETS,MAX_DB,U_SYS_USERS,U_DB_BASES,TPL,SUSPENDED,TIME,DATE"
	for type in $(echo "$DB_SYSTEM" | sed 's/,/ /g'); do
		if [ -e "$HESTIA/conf/$type.conf" ]; then
			database_set_default_ports
			while read -r str; do
				[ -z "$str" ] && continue
				parse_object_kv_list "$str"
				echo "$HOST,$PORT,$type,\"$CHARSETS\",$MAX_DB,\"$U_SYS_USERS\",$U_DB_BASES,$TPL,$SUSPENDED,$TIME,$DATE"
			done < "$HESTIA/conf/$type.conf"
		fi
	done
}

# Type format validator
is_type_format_valid() {
	exclude="[!|#|$|^|&|(|)|+|=|{|}|:|@|<|>|?|/|\|\"|'|;|%|\`| ]|\."
	if [[ "$1" =~ $exclude ]]; then
		check_result $E_INVALID "invalid type extention format :: $1"
	fi
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
