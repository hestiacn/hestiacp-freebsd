#!/bin/bash
# info: move file
# options: USER SRC_DIRECTORY DST_DIRECTORY
#
# example: v-move-fs-directory admin /home/admin/web /home/user02/
#
# This function moved file or directory on the file system. This function
# can also be used to rename files just like normal mv command.

user=$1
src_dir=$2
dst_dir=$3

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '3' "$#" 'USER SRC_DIRECTORY DST_DIRECTORY'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

# Checking user homedir
if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	# Linux
	homedir=$(grep "^$user:" /etc/passwd | cut -f 6 -d :)
else
	# FreeBSD
	homedir=$(grep "^$user:" /etc/master.passwd | cut -f 6 -d :)
fi

if [ -z "$homedir" ]; then
	echo "Error: user home directory doesn't exist"
	exit 12
fi

# Checking source file
if [ ! -d "$src_dir" ] && [ ! -f "$src_dir" ]; then
	echo "Error: source $src_dir doesn't exist"
	exit 3
fi

# Checking source path
rpath=$(readlink -f "$src_dir")
if [ -z "$(echo "$rpath" | grep -E "^/tmp|^$homedir")" ]; then
	echo "Error: invalid source path $src_dir"
	exit 2
fi

# Checking destination path
rpath=$(readlink -f "$dst_dir")
if [ -z "$(echo "$rpath" | grep -E "^/tmp|^$homedir")" ]; then
	echo "Error: invalid destination path $dst_dir"
	exit 2
fi

# Moving directory
user_exec mv "$src_dir" "$dst_dir" > /dev/null 2>&1
if [ $? -ne 0 ]; then
	echo "Error: $src_dir was not moved"
	exit 3
fi

# Exiting
exit
