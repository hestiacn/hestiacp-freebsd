#!/bin/sh
# info: list db status
# options:
#
# v-list-sys-db-status
#
# This function lists db server status

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Checking db system
if [ -z "$DB_SYSTEM" ]; then
	exit 0
fi

# Checking supported database systems
OLD_IFS="$IFS"
IFS=','
for db in $DB_SYSTEM; do
	IFS="$OLD_IFS"

	# Checking database config
	if [ -e "$HESTIA/conf/$db.conf" ]; then

		# Checking server status
		while read -r host_str; do
			[ -z "$host_str" ] && continue
			parse_object_kv_list "$host_str"

			# Checking MySQL
			if [ "$db" = 'mysql' ]; then
				mycnf="$HESTIA/conf/.mysql.$HOST"
				if [ ! -e "$mycnf" ]; then
					echo "[client]" > "$mycnf"
					echo "host='$HOST'" >> "$mycnf"
					echo "user='$USER'" >> "$mycnf"
					echo "password='$PASSWORD'" >> "$mycnf"
					chmod 600 "$mycnf"
				else
					mypw=$(grep password "$mycnf" | cut -f 2 -d \')
					if [ "$mypw" != "$PASSWORD" ]; then
						echo "[client]" > "$mycnf"
						echo "host='$HOST'" >> "$mycnf"
						echo "user='$USER'" >> "$mycnf"
						echo "password='$PASSWORD'" >> "$mycnf"
						chmod 660 "$mycnf"
					fi
				fi
				if [ -f '/usr/bin/mariadb-admin' ]; then
					echo "MySQL $HOST status"
					mariadb-admin --defaults-file="$mycnf" status | sed -e "s/  /\n/g"
					echo
					mariadb-admin --defaults-file="$mycnf" processlist
				else
					echo "MySQL $HOST status"
					mysqladmin --defaults-file="$mycnf" status | sed -e "s/  /\n/g"
					echo
					mysqladmin --defaults-file="$mycnf" processlist
				fi
				printf "\n---------------------------------------------"
				printf "---------------------------------------------\n\n"
			fi

			# Checking PostgreSQL
			if [ "$db" = 'pgsql' ] && command -v psql >/dev/null 2>&1; then
				echo "PostgreSQL $HOST status"
				export PGPASSWORD="$PASSWORD"
				psql -h "$HOST" -U "$USER" -c "SELECT * FROM pg_stat_activity"
			fi
		done < "$HESTIA/conf/$db.conf"
	fi
	IFS=','
done
IFS="$OLD_IFS"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
