#!/bin/sh
# info: delete firewall ipset
# options: NAME
#
# example: v-delete-firewall-ipset country-nl
#
# This function removes ipset from system and from hestia

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

ip_name=${1}

if [ "$FIREWALL_SYSTEM" = "pf" ]; then
    pfctl="/sbin/pfctl"
elif [ "$FIREWALL_SYSTEM" = "ipfw" ]; then
    ipfw="/sbin/ipfw"
fi

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'NAME'
is_format_valid 'ip_name'
is_system_enabled "$FIREWALL_SYSTEM" 'FIREWALL_SYSTEM'

# Define variables for ipset/pf table configuration
ipset_hstobject='../../../data/firewall/ipset'
is_object_valid "$ipset_hstobject" 'LISTNAME' "$ip_name"
ip_version="$(get_object_value "$ipset_hstobject" 'LISTNAME' "$ip_name" '$IP_VERSION')"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

IPSET_PATH="$HESTIA/data/firewall/ipset"
IPSET_FILE="${ip_name}.${ip_version}"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ "$FIREWALL_SYSTEM" = "pf" ]; then
    if $pfctl -t "$ip_name" -T show > /dev/null 2>&1; then
        $pfctl -t "$ip_name" -T kill 2>/dev/null
        check_result $? "pf table $ip_name still in use. Cannot remove"
    fi
    if $pfctl -t "${ip_name}-tmp" -T show > /dev/null 2>&1; then
        $pfctl -t "${ip_name}-tmp" -T kill 2>/dev/null
    fi
elif [ "$FIREWALL_SYSTEM" = "ipfw" ]; then
    if $ipfw table "$ip_name" list > /dev/null 2>&1; then
        $ipfw table "$ip_name" destroy 2>/dev/null
        check_result $? "ipfw table $ip_name still in use. Cannot remove"
    fi
fi

# Delete from Hestia configuration
# FreeBSD sed requires -i ""
sed -i "" "/LISTNAME='$ip_name'/d" "${IPSET_PATH}.conf"
rm -f "${IPSET_PATH}/${IPSET_FILE}.iplist"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Info" "Firewall" "IPset/PF table deleted (Name: $ip_name)."
log_event "$OK" "$ARGUMENTS"

exit 0
