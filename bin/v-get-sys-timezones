#!/bin/sh
# info: list system timezone
# options: [FORMAT]
#
# example: v-get-sys-timezones json
#
# This function checks system timezone settings

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

json_list() {
    printf '%s\n' $zones | jq -ncR '[inputs]'
}

shell_list() {
    echo "Timezone"
    echo "--------"
    for zone in $zones; do
        echo "$zone"
    done
}

plain_list() {
    for zone in $zones; do
        echo "$zone"
    done
}

zones=$(cd /usr/share/zoneinfo && find -L . -type f -o -type l | sed 's|^\./||' | sort)

# Listing data
case $format in
    json) json_list ;;
    plain) plain_list ;;
    shell) shell_list | column -t ;;
    *) shell_list | column -t ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit