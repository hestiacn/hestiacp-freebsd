#!/bin/bash
# info: list system IPs
# options: [FORMAT]
#
# example: v-list-sys-ip json
#
# This function for getting the list of system IP parameters.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi
# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# shellcheck source=/usr/local/hestia/func/ip.sh
source $HESTIA/func/ip.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(ls -1 "$HESTIA/data/ips/" 2>/dev/null | wc -l)
	echo "{"
	for ip_file in $(ls -1 "$HESTIA/data/ips/" 2>/dev/null); do
		ip="$ip_file"
		. "$HESTIA/data/ips/$ip"
		echo -n "    \"$ip\": {"
		echo -n "\"OWNER\": \"$OWNER\", "
		echo -n "\"STATUS\": \"$STATUS\", "
		echo -n "\"NAME\": \"$NAME\", "
		echo -n "\"U_SYS_USERS\": \"$U_SYS_USERS\", "
		echo -n "\"U_WEB_DOMAINS\": \"$U_WEB_DOMAINS\", "
		echo -n "\"INTERFACE\": \"$INTERFACE\", "
		echo -n "\"NETMASK\": \"$NETMASK\", "
		echo -n "\"NAT\": \"$NAT\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-15s %-10s %-10s %-15s %-10s %-15s %-10s %-12s\n" \
		"IP" "OWNER" "STATUS" "NAME" "INTERFACE" "USERS" "DOMAINS" "DATE"
	printf "%-15s %-10s %-10s %-15s %-10s %-15s %-10s %-12s\n" \
		"--" "-----" "------" "----" "---------" "-----" "-------" "----"
	for ip_file in $(ls -1 "$HESTIA/data/ips/" 2>/dev/null); do
		ip="$ip_file"
		. "$HESTIA/data/ips/$ip"
		printf "%-15s %-10s %-10s %-15s %-10s %-15s %-10s %-12s\n" \
			"$ip" "$OWNER" "$STATUS" "$NAME" "$INTERFACE" "$U_SYS_USERS" "$U_WEB_DOMAINS" "$DATE"
	done
}

# PLAIN list function
plain_list() {
	for ip_file in $(ls -1 "$HESTIA/data/ips/" 2>/dev/null); do
		ip="$ip_file"
		. "$HESTIA/data/ips/$ip"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$ip" "$OWNER" "$STATUS" "$NAME" "$U_SYS_USERS" "$U_WEB_DOMAINS" \
			"$INTERFACE" "$NETMASK" "$NAT" "$TIME" "$DATE"
	done
}

# CSV list function
csv_list() {
	echo "IP,OWNER,STATUS,NAME,U_SYS_USERS,U_WEB_DOMAINS,INTERFACE,NETMASK,NAT,TIME,DATE"
	for ip_file in $(ls -1 "$HESTIA/data/ips/" 2>/dev/null); do
		ip="$ip_file"
		. "$HESTIA/data/ips/$ip"
		echo "$ip,$OWNER,$STATUS,$NAME,\"$U_SYS_USERS\",$U_WEB_DOMAINS,$INTERFACE,$NETMASK,$NAT,$TIME,$DATE"
	done
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ ! -d "$HESTIA/data/ips" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No IPs configured" ;;
		plain) ;;
		csv) echo "IP,OWNER,STATUS,NAME,U_SYS_USERS,U_WEB_DOMAINS,INTERFACE,NETMASK,NAT,TIME,DATE" ;;
	esac
	exit 0
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
