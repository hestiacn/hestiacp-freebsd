#!/bin/bash
# info: list virtual memory info
#
# example: v-list-sys-memory-status

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Displaying memory and swap usage
if command -v free >/dev/null 2>&1; then
	# Linux
	free -t -m
else
	# FreeBSD
	top -d1 -s1 2>/dev/null || top -n 37
fi

printf -- "\n-----------------------------------------------"
printf -- "-----------------------------------------------\n"

# Displaying memory stats
if vmstat -S m -s 2>/dev/null | grep -q "total memory"; then
	# Linux
	vmstat -S m -s
else
	# FreeBSD
	vmstat -s | head -20
fi

printf -- "\n-----------------------------------------------"
printf -- "-----------------------------------------------\n"

# Displaying ram information
if command -v dmidecode >/dev/null 2>&1; then
	dmidecode -t 17
else
	echo "dmidecode command not found"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
