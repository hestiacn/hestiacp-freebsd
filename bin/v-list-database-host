#!/bin/sh
# info: list database host
# options: TYPE HOST [FORMAT]
#
# example: v-list-database-host mysql localhost
#
# This function for obtaining database host parameters.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
type=$1
host=$2
format=${3:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# shellcheck source=/usr/local/hestia/func/db.sh
source "$HESTIA/func/db.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	echo '{'
	echo "    \"$HOST\": {"
	echo "        \"HOST\": \"$HOST\","
	echo "        \"PORT\": \"$PORT\","
	echo "        \"TYPE\": \"$type\","
	echo "        \"CHARSETS\": \"$CHARSETS\","
	echo "        \"MAX_DB\": \"$MAX_DB\","
	echo "        \"U_SYS_USERS\": \"$U_SYS_USERS\","
	echo "        \"U_DB_BASES\": \"$U_DB_BASES\","
	echo "        \"TPL\": \"$TPL\","
	echo "        \"SUSPENDED\": \"$SUSPENDED\","
	echo "        \"TIME\": \"$TIME\","
	echo "        \"DATE\": \"$DATE\""
	echo "    }"
	echo '}'
}

# SHELL list function
shell_list() {
	echo "HOST:           $HOST"
	echo "PORT:           $PORT"
	echo "TYPE:           $type"
	echo "CHARSETS:       $CHARSETS"
	echo "MAX_DB:         $MAX_DB"
	echo "U_DB_BASES:     $U_DB_BASES"
	echo "U_SYS_USERS:    $U_SYS_USERS"
	echo "TPL:            $TPL"
	echo "SUSPENDED:      $SUSPENDED"
	echo "TIME:           $TIME"
	echo "DATE:           $DATE"
}

# PLAIN list function
plain_list() {
	printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
		"$HOST" "$PORT" "$type" "$CHARSETS" "$MAX_DB" "$U_SYS_USERS" "$U_DB_BASES" "$TPL" "$SUSPENDED" "$TIME" "$DATE"
}

# CSV list function
csv_list() {
	echo "HOST,PORT,TYPE,CHARSETS,MAX_DB,U_SYS_USERS,U_DB_BASES,TPL,SUSPENDED,TIME,DATE"
	echo "$HOST,$PORT,$type,\"$CHARSETS\",$MAX_DB,\"$U_SYS_USERS\",$U_DB_BASES,$TPL,$SUSPENDED,$TIME,$DATE"
}

# Type format validator
is_type_format_valid() {
	case "$1" in
		*[!a-zA-Z0-9_-]*)
			echo "Error: invalid type extension format :: $1"
			exit 2
			;;
	esac
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'TYPE HOST [FORMAT]'
is_format_valid 'host'
is_type_format_valid "$type"
is_object_valid "../../../conf/$type" 'HOST' "$host"

# Set default port values if they don't exist in host configuration file
database_set_default_ports

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing hosts
host_line=$(grep "HOST='$host'" "$HESTIA/conf/$type.conf")
if [ -z "$host_line" ]; then
	echo "Error: Host $host not found for type $type"
	exit 3
fi
parse_object_kv_list "$host_line"

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list | column -t ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
