#!/bin/sh
# info: list system updates
# options: [FORMAT]
#
# example: v-list-sys-hestia-updates
#
# This function checks available updates for hestia packages.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

fields="\$NAME \$VERSION \$ARCH \$UPDATED \$DESCR \$TIME \$DATE"

# Check details of installed .deb package function
check_installed_deb() {
	dpkg_data=$(dpkg-query -s "$1" 2>/dev/null)
	pkg_date=$(stat -c "%Y" "/var/lib/dpkg/info/$1.list" 2>/dev/null)
	ARCH=$(echo "$dpkg_data" | grep "Architecture" | cut -f 2 -d ' ')
	VERSION=$(echo "$dpkg_data" | grep "^Version" | cut -f 2 -d ' ')
	if [ -n "$pkg_date" ]; then
		DATE=$(date -d "@$pkg_date" +"%F" 2>/dev/null)
		TIME=$(date -d "@$pkg_date" +"%T" 2>/dev/null)
	fi
}

# Check details of installed .rpm package function
check_installed_rpm() {
	rpm_data=$(rpm -qi "$1" 2>/dev/null)
	ARCH=$(echo "$rpm_data" | grep "Architecture" | cut -f 2 -d ' ')
	VERSION=$(echo "$rpm_data" | grep "Version" | cut -f 2 -d ':' | xargs)
	DATE=$(echo "$rpm_data" | grep "Build Date" | awk '{print $5 " " $6 " " $7}')
	TIME=$(echo "$rpm_data" | grep "Build Date" | awk '{print $8 " " $9 " " $10}')
}

# JSON list function
json_list() {
	i=1
	objects=$(echo "$data" | grep -c "NAME")
	echo "{"
	echo "$data" | while read -r line; do
		[ -z "$line" ] && continue
		parse_object_kv_list "$line"
		echo -n "    \"$NAME\": {"
		echo -n "\"VERSION\": \"$VERSION\", "
		echo -n "\"ARCH\": \"$ARCH\", "
		echo -n "\"UPDATED\": \"$UPDATED\", "
		echo -n "\"DESCR\": \"$DESCR\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-20s %-15s %-10s %-8s %-12s\n" "PKG" "VER" "ARCH" "UPDT" "DATE"
	printf "%-20s %-15s %-10s %-8s %-12s\n" "---" "---" "----" "----" "----"
	echo "$data" | while read -r line; do
		[ -z "$line" ] && continue
		parse_object_kv_list "$line"
		printf "%-20s %-15s %-10s %-8s %-12s\n" \
			"$NAME" "$VERSION" "$ARCH" "$UPDATED" "$DATE"
	done
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Checking official latest version
if [ -f '/etc/redhat-release' ]; then
	hestia_v=$(dnf list hestia 2>/dev/null | grep hestia | awk '{print $2}' | cut -f 1 -d '-')
	nginx_v=$(dnf list hestia-nginx 2>/dev/null | grep hestia-nginx | awk '{print $2}' | cut -f 1 -d '-')
	php_v=$(dnf list hestia-php 2>/dev/null | grep hestia-php | awk '{print $2}' | cut -f 1 -d '-')
else
	hestia_v=$(apt-cache policy hestia 2>/dev/null | grep Candidate | cut -d ':' -f 2 | xargs)
	nginx_v=$(apt-cache policy hestia-nginx 2>/dev/null | grep Candidate | cut -d ':' -f 2 | xargs)
	php_v=$(apt-cache policy hestia-php 2>/dev/null | grep Candidate | cut -d ':' -f 2 | xargs)
fi

# Checking installed hestia version
if [ -f '/etc/redhat-release' ]; then
	check_installed_rpm hestia
else
	check_installed_deb hestia
fi

UPDATED='yes'
if [ -n "$hestia_v" ] && [ "$hestia_v" != "$VERSION" ]; then
	UPDATED='no'
fi

data="NAME='hestia' VERSION='$VERSION' ARCH='$ARCH'"
data="$data UPDATED='$UPDATED' DESCR='Hestia core package' TIME='$TIME' DATE='$DATE'"

# Checking installed hestia-php version
if [ -f '/etc/redhat-release' ]; then
	check_installed_rpm hestia-php
else
	check_installed_deb hestia-php
fi

UPDATED='yes'
if [ -n "$php_v" ] && [ "$php_v" != "$VERSION" ]; then
	UPDATED='no'
fi

data="$data
NAME='hestia-php' VERSION='$VERSION' ARCH='$ARCH' UPDATED='$UPDATED' DESCR='Hestia internal php interpreter' TIME='$TIME' DATE='$DATE'"

# Checking installed hestia-nginx version
if [ -f '/etc/redhat-release' ]; then
	check_installed_rpm hestia-nginx
else
	check_installed_deb hestia-nginx
fi

UPDATED='yes'
if [ -n "$nginx_v" ] && [ "$nginx_v" != "$VERSION" ]; then
	UPDATED='no'
fi

data="$data
NAME='hestia-nginx' VERSION='$VERSION' ARCH='$ARCH' UPDATED='$UPDATED' DESCR='Hestia internal web server' TIME='$TIME' DATE='$DATE'"

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
