#!/bin/sh
# info: archive to directory
# options: USER ARCHIVE DIRECTORY [SELECTED_DIR] [STRIP] [TEST]
#
# example: v-extract-fs-archive admin latest.tar.gz /home/admin
#
# This function extracts archive into directory on the file system

user=$1
src_file=$2
dst_dir=$3
selected_dir=$4
strip=$5
test=$6

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '3' "$#" 'USER ARCHIVE DIRECTORY [SELECTED_DIR] [STRIP] [TEST]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

# Checking user homedir
homedir=$(grep "^$user:" /etc/passwd | cut -f 6 -d :)
if [ -z "$homedir" ]; then
    echo "Error: user home directory doesn't exist"
    exit 12
fi

# Checking source dir
if [ ! -e "$src_file" ]; then
    echo "Error: source file $src_file doesn't exist"
    exit 3
fi

if command -v realpath > /dev/null 2>&1; then
    rpath=$(realpath "$src_file" 2>/dev/null)
else
    rpath=$(cd "$(dirname "$src_file")" && pwd)/$(basename "$src_file")
fi

if ! echo "$rpath" | grep -qE "^/tmp|^$homedir|^$BACKUP/$user\.|^$BACKUP/tmp\."; then
    echo "Error: invalid source path $src_file"
    exit 2
fi

# Checking destination path
if command -v realpath > /dev/null 2>&1; then
    rpath=$(realpath "$dst_dir" 2>/dev/null)
else
    rpath=$(cd "$dst_dir" 2>/dev/null && pwd)
fi

if ! echo "$rpath" | grep -qE "^/tmp|^$homedir"; then
    echo "Error: invalid destination path $dst_dir"
    exit 2
fi

if [ -n "$strip" ]; then
    is_int_format_valid "$strip" 'strip-components'
    tar_strip_level="--strip-components $strip"
fi

# Extracting gziped archive
if echo "$src_file" | grep -qiE '\.tgz$|\.tar\.gz$'; then
    x='yes'
    if [ -z "$test" ] || [ "$test" = "no" ]; then
        user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
        user_exec bsdtar -xzf "$src_file" -C "$dst_dir" --no-wildcards "$selected_dir" $tar_strip_level > /dev/null 2>&1
        rc=$?
    else
        user_exec bsdtar -tf "$src_file" --no-wildcards "$selected_dir" > /dev/null 2>&1
        rc=$?
    fi
fi

# Extracting bziped archive
if echo "$src_file" | grep -qiE '\.tbz$|\.tar\.bz2?$'; then
    x='yes'
    if [ -z "$test" ] || [ "$test" = "no" ]; then
        user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
        user_exec bsdtar -xjf "$src_file" -C "$dst_dir" --no-wildcards "$selected_dir" $tar_strip_level > /dev/null 2>&1
        rc=$?
    else
        user_exec bsdtar -tf "$src_file" --no-wildcards "$selected_dir" > /dev/null 2>&1
        rc=$?
    fi
fi

# Extracting ZSTD archive
if echo "$src_file" | grep -qi '\.tar\.zst$'; then
    x='yes'
    if [ -z "$test" ] || [ "$test" = "no" ]; then
        user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
        user_exec bsdtar -xf "$src_file" -C "$dst_dir" --no-wildcards "$selected_dir" $tar_strip_level > /dev/null 2>&1
        rc=$?
    else
        user_exec bsdtar -tf "$src_file" --no-wildcards "$selected_dir" > /dev/null 2>&1
        rc=$?
    fi
fi

# Extracting zstd file
if echo "$src_file" | grep -qi '\.zst$' && [ -z "$x" ]; then
    user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
    user_exec mv "$src_file" "$dst_dir" > /dev/null 2>&1
    user_exec zstd -d "$dst_dir/$(basename "$src_file")" > /dev/null 2>&1
    rc=$?
fi

# Extracting gziped file
if echo "$src_file" | grep -qi '\.gz$' && [ -z "$x" ]; then
    user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
    user_exec mv "$src_file" "$dst_dir" > /dev/null 2>&1
    user_exec gzip -d "$dst_dir/$(basename "$src_file")" > /dev/null 2>&1
    rc=$?
fi

# Extracting bziped file
if echo "$src_file" | grep -qi '\.bz2?$' && [ -z "$x" ]; then
    user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
    user_exec mv "$src_file" "$dst_dir" > /dev/null 2>&1
    user_exec bzip2 -d "$dst_dir/$(basename "$src_file")" > /dev/null 2>&1
    rc=$?
fi

# Extracting zip archive
if echo "$src_file" | grep -qi '\.zip$'; then
    user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
    user_exec unzip "$src_file" -d "$dst_dir" > /dev/null 2>&1
    rc=$?
fi

# Extracting 7z archive
if echo "$src_file" | grep -qi '\.7z$'; then
    user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
    user_exec mv "$src_file" "$dst_dir" > /dev/null 2>&1
    user_exec 7z x "$dst_dir/$(basename "$src_file")" -o"$dst_dir" > /dev/null 2>&1
    rc=$?
fi

# Extracting tar archive
if echo "$src_file" | grep -qi '\.tar$' && [ -z "$x" ]; then
    x='yes'
    if [ -z "$test" ] || [ "$test" = "no" ]; then
        user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
        user_exec bsdtar -xf "$src_file" -C "$dst_dir" --no-wildcards "$selected_dir" $tar_strip_level > /dev/null 2>&1
        rc=$?
    else
        user_exec bsdtar -tf "$src_file" --no-wildcards "$selected_dir" > /dev/null 2>&1
        rc=$?
    fi
fi

# Extracting rar archive
if echo "$src_file" | grep -qi '\.rar$'; then
    user_exec mkdir -p "$dst_dir" > /dev/null 2>&1
    user_exec unrar x "$src_file" "$dst_dir" > /dev/null 2>&1
    rc=$?
fi

# Checking result
if [ "$rc" -ne 0 ]; then
    echo "Error: $src_file was not extracted"
    exit 3
fi

exit
