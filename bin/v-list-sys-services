#!/bin/bash
# info: list system services
# options: [FORMAT]
#
# example: v-list-sys-services json
#
# This function for obtaining the list of configured system services.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
	php_fpm="/usr/sbin/php*fpm*"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
	php_fpm="/usr/local/sbin/php-fpm*"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(echo "$data" | grep -c "NAME")
	echo "{"
	echo "$data" | while read -r line; do
		[ -z "$line" ] && continue
		parse_object_kv_list "$line"
		echo -n "    \"$NAME\": {"
		echo -n "\"SYSTEM\": \"$SYSTEM\", "
		echo -n "\"STATE\": \"$STATE\", "
		echo -n "\"CPU\": \"$CPU\", "
		echo -n "\"MEM\": \"$MEM\", "
		echo "\"RTIME\": \"$RTIME\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-20s %-8s %-8s %-8s %-10s\n" "NAME" "STATE" "CPU" "MEM" "UPTIME"
	printf "%-20s %-8s %-8s %-8s %-10s\n" "----" "-----" "---" "---" "------"
	echo "$data" | while read -r line; do
		[ -z "$line" ] && continue
		parse_object_kv_list "$line"
		printf "%-20s %-8s %-8s %-8s %-10s\n" \
			"$NAME" "$STATE" "$CPU" "$MEM" "$RTIME"
	done
}

# PLAIN list function
plain_list() {
	echo "$data" | while read -r line; do
		[ -z "$line" ] && continue
		parse_object_kv_list "$line"
		printf "%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$NAME" "$SYSTEM" "$STATE" "$CPU" "$MEM" "$RTIME"
	done
}

# CSV list function
csv_list() {
	echo "NAME,SYSTEM,STATE,CPU,MEM,RTIME"
	echo "$data" | while read -r line; do
		[ -z "$line" ] && continue
		parse_object_kv_list "$line"
		echo "$NAME,\"$SYSTEM\",$STATE,$CPU,$MEM,$RTIME"
	done
}

# Get service state function
get_srv_state() {
	srv=$1
	name=${2:-$1}
	state='running'
	mem=0
	cpu=0
	rtime="0"

	# Searching related pids
	if [ -z "$3" ]; then
		pids=$(pidof "$name" | tr ' ' '|')
	else
		pids=$(pidof -x "$name" | tr ' ' '|')
	fi
	used_pgrep=0
	if [ -z "$pids" ] && [ "$name" != 'nginx' ]; then
		if [ ${#name} -ge 15 ]; then
			pids=$(pgrep -f "$name" | tr '\n' '|')
		else
			pids=$(pgrep "$name" | tr '\n' '|')
		fi
		used_pgrep=1
	fi

	# Correctly handle hestia-web-terminal service
	if [ "$name" = 'hestia-web-terminal' ] && command -v systemctl; then
		if [ "$(systemctl show "$name".service | grep 'SubState=' | cut -f2 -d=)" = "running" ]; then
			pids=$(systemctl show "$name".service | grep '^MainPID=' | cut -f2 -d=)
		fi
	fi

	# Checking pid
	if [ -n "$pids" ]; then
		if [ "$used_pgrep" -eq 1 ]; then
			pid=$(echo "$pids" | awk -F '|' '{print $1}')
		else
			pid=$(echo "$pids" | awk -F '|' '{print $NF}')
		fi
		pids=${pids%|}
		pids=$(echo "$pids" | grep -E -f - "$tmp_file")

		# Calculating CPU usage
		cpu=$(echo "$pids" | awk '{ sum += $2} END {print sum}')
		[ -z "$cpu" ] && cpu=0

		# Calculating memory usage
		mem=$(echo "$pids" | awk '{sum += $3} END {print sum/1024 }')
		mem=$(echo "${mem%%.*}")

		# Searching pid file
		pid_file=''
		if [ -e "/run/$srv.pid" ]; then
			pid_file="/run/$srv.pid"
		fi
		if [ -z "$pid_file" ] && [ -e "/run/$srv/$srv.pid" ]; then
			pid_file="/run/$srv/$srv.pid"
		fi
		if [ -z "$pid_file" ] && [ -e "/run/$name/$name.pid" ]; then
			pid_file="/run/$name/$name.pid"
		fi
		if [ -z "$pid_file" ] && [ -e "/proc/$pid" ]; then
			pid_file="/proc/$pid"
		fi

		# Calculating uptime
		if [ -n "$pid_file" ]; then
			mtime=$(stat -c "%Y" "$pid_file")
			rtime=$((ctime - mtime))
			rtime=$((rtime / 60))
		else
			rtime=0
		fi
	else
		state='stopped'
		mem=0
		cpu=0
		rtime="0"
	fi
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Saving current proccess list
tmp_file=$(mktemp)
ps -eo pid,pcpu,size > "$tmp_file"

# Checking current time
ctime=$(date +%s)

data=""

# Checking WEB system
if [ -n "$WEB_SYSTEM" ] && [ "$WEB_SYSTEM" != 'remote' ]; then
	get_srv_state "$WEB_SYSTEM"
	data="NAME='$WEB_SYSTEM' SYSTEM='web server' STATE='$state' CPU='$cpu'"
	data="$data MEM='$mem' RTIME='$rtime'"
fi

# Checking PHP intepreter
if [ -n "$WEB_BACKEND" ] && [ "$WEB_BACKEND" != 'remote' ]; then
	php_versions=$(ls $php_fpm | cut -d'/' -f4 | sed 's|php-fpm||')
	for version in $php_versions; do
		proc_name="php-fpm${version}"
		service_name="php${version}-fpm"
		get_srv_state "$proc_name"
		data="$data
NAME='$service_name' SYSTEM='php interpreter' STATE='$state'"
		data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
	done
fi

# Checking WEB Proxy
if [ -n "$PROXY_SYSTEM" ] && [ "$PROXY_SYSTEM" != 'remote' ]; then
	get_srv_state "$PROXY_SYSTEM"
	data="$data
NAME='$PROXY_SYSTEM' SYSTEM='reverse proxy' STATE='$state'"
	data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# DNS
service="$DNS_SYSTEM"
if [ -n "$service" ] && [ "$service" != 'remote' ]; then
	proc_name='named'
	get_srv_state "$service" "$proc_name"
	data="$data
NAME='$service' SYSTEM='dns server' STATE='$state'"
	data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Checking MAIL system
if [ -n "$MAIL_SYSTEM" ] && [ "$MAIL_SYSTEM" != 'remote' ]; then
	get_srv_state "$MAIL_SYSTEM"
	data="$data
NAME='$MAIL_SYSTEM' SYSTEM='mail server' STATE='$state'"
	data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Checking MAIL IMAP
if [ -n "$IMAP_SYSTEM" ] && [ "$IMAP_SYSTEM" != 'remote' ]; then
	get_srv_state "$IMAP_SYSTEM"
	data="$data
NAME='$IMAP_SYSTEM' SYSTEM='imap/pop3 server' STATE='$state'"
	data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Checking MAIL ANTIVIRUS
if [ -n "$ANTIVIRUS_SYSTEM" ] && [ "$ANTIVIRUS_SYSTEM" != 'remote' ]; then
	proc_name=''
	if [ -d "/etc/sysconfig" ]; then
		if [ "$ANTIVIRUS_SYSTEM" = 'clamav' ]; then
			ANTIVIRUS_SYSTEM='clamd'
		fi
		get_srv_state "$ANTIVIRUS_SYSTEM"
	else
		if [ "$ANTIVIRUS_SYSTEM" = 'clamav-daemon' ]; then
			proc_name='clamd'
		fi
		get_srv_state "$ANTIVIRUS_SYSTEM" "$proc_name"
	fi
	data="$data
NAME='$ANTIVIRUS_SYSTEM' SYSTEM='email anti-virus'"
	data="$data STATE='$state' CPU='$cpu' MEM='$mem' RTIME='$rtime'"
	proc_name=''
fi

# Checking MAIL ANTISPAM
if [ -n "$ANTISPAM_SYSTEM" ] && [ "$ANTISPAM_SYSTEM" != 'remote' ]; then
	get_srv_state "$ANTISPAM_SYSTEM" "spamd"
	data="$data
NAME='$ANTISPAM_SYSTEM' SYSTEM='email spam filter'"
	data="$data STATE='$state' CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Checking DB system
if [ -n "$DB_SYSTEM" ] && [ "$DB_SYSTEM" != 'remote' ]; then
	# Convert comma-separated string to space-separated for iteration
	OLD_IFS="$IFS"
	IFS=','
	for db in $DB_SYSTEM; do
		IFS="$OLD_IFS"
		service="$db"
		proc_name=''
		mysql="/usr/bin/mysql"
		if [ -f '/usr/bin/mariadb' ]; then
			mysql="/usr/bin/mariadb"
		fi
		if [ "$service" = 'mysql' ]; then
			if [ -f "$mysql" ]; then
				mysql_version=$($mysql -V)
				mariadb_string="MariaDB"
				if [[ ! $mysql_version =~ $mariadb_string ]]; then
					# MySQL
					service='mysql'
					proc_name='mysqld'
				else
					service='mariadb'
					proc_name='mariadbd'
					# MariaDB 10.4 and lower
					mariadb_v=$($mysql -V | awk 'NR==1{print $5}')
					if [[ $mariadb_v =~ $mariadb_string ]]; then
						mariadb_v=$(echo "$mariadb_v" | awk -F "." '{ print $1 $2 }')
						if [ "$mariadb_v" -le 104 ]; then
							service='mariadb'
							proc_name='mysqld'
						fi
					fi
				fi
			fi
		fi
		if [ "$service" = 'pgsql' ]; then
			service='postgresql'
			proc_name='postmaster'
			if [ ! -d "/etc/sysconfig" ]; then
				proc_name='postgres'
			fi
			if [ ! -e '/etc/init.d/postgresql' ]; then
				proc_name='postgres'
			fi
		fi
		get_srv_state "$service" "$proc_name"
		data="$data
NAME='$service' SYSTEM='database server' STATE='$state'"
		data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
		proc_name=''
	done
	IFS="$OLD_IFS"
fi

# Checking FTP system
if [ -n "$FTP_SYSTEM" ] && [ "$FTP_SYSTEM" != 'remote' ]; then
	get_srv_state "$FTP_SYSTEM"
	data="$data
NAME='$FTP_SYSTEM' SYSTEM='ftp server' STATE='$state'"
	data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Checking CRON system
if [ -n "$CRON_SYSTEM" ] && [ "$CRON_SYSTEM" != 'remote' ]; then
	get_srv_state "$CRON_SYSTEM"
	data="$data
NAME='$CRON_SYSTEM' SYSTEM='job scheduler' STATE='$state'"
	data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Checking SSH daemon
if [ -e "/etc/ssh/sshd_config" ]; then
	get_srv_state ssh
	data="$data
NAME='ssh' SYSTEM='ssh server' STATE='$state'"
	data="$data CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Checking FIREWALL system
if [ -n "$FIREWALL_SYSTEM" ] && [ "$FIREWALL_SYSTEM" != 'remote' ]; then
	state="stopped"
	case "$FIREWALL_SYSTEM" in
		iptables|nftables)
			if command -v iptables; then
				if iptables -S INPUT | grep -qx '\-P INPUT DROP'; then
					state="running"
				fi
			fi
			;;
		pf)
			if command -v pfctl; then
				if pfctl -s info | grep -q "Status: Enabled"; then
					state="running"
				fi
			fi
			;;
		ipfw)
			if command -v ipfw; then
				if ipfw list | grep -q "deny ip from any to any"; then
					state="running"
				fi
			fi
			;;
	esac
	data="$data\nNAME='$FIREWALL_SYSTEM' SYSTEM='firewall'"
	data="$data STATE='$state' CPU='0' MEM='0' RTIME='0'"
fi

# Checking FIREWALL Fail2ban extention
if [ -n "$FIREWALL_EXTENSION" ]; then
	if [ -e '/usr/bin/lsb_release' ]; then
		release=$(lsb_release -s -r)
		if [ "$release" = "20.04" ]; then
			get_srv_state "$FIREWALL_EXTENSION" "f2b/server script"
		else
			get_srv_state "$FIREWALL_EXTENSION" "fail2ban-server script"
		fi
	else
		get_srv_state "$FIREWALL_EXTENSION" "fail2ban-server script"
	fi
	data="$data
NAME='$FIREWALL_EXTENSION' SYSTEM='brute-force protection'"
	data="$data STATE='$state' CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Checking WEB_TERMINAL
if [ -n "$WEB_TERMINAL" ] && [ "$WEB_TERMINAL" != 'false' ]; then
	get_srv_state hestia-web-terminal
	data="$data
NAME='web-terminal' SYSTEM='web terminal backend'"
	data="$data STATE='$state' CPU='$cpu' MEM='$mem' RTIME='$rtime'"
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

if [ -f "$tmp_file" ]; then
	rm -f "$tmp_file"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
