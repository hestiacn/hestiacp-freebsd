#!/bin/sh
# info: list dns status
# options:
#
# example: v-list-sys-dns-status
#
# This function lists dns server status

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
	rndc="/usr/sbin/rndc"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
	rndc="/usr/local/sbin/rndc"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Checking dns system
if [ -z "$DNS_SYSTEM" ]; then
	exit 0
fi

# Checking statistics-file on RHEL/CentOS/Linux
if [ -e "/etc/named/named.conf" ]; then
	conf="/etc/named/named.conf"
	dump_file='/var/named/data/named_stats.txt'
	dump_option="    dump-file           \"$dump_file\";"
	opt_check=$(grep "$dump_file" "$conf" | grep -v //)
	if [ -z "$opt_check" ]; then
		sed -i "s|options {|options {\n$dump_option |" "$conf"
		if command -v service >/dev/null 2>&1; then
			service named restart > /dev/null 2>&1
		fi
	fi
fi

if [ -e "/etc/named.conf" ]; then
	conf="/etc/named.conf"
	dump_file='/var/named/data/named_stats.txt'
	dump_option="    dump-file           \"$dump_file\";"
	opt_check=$(grep "$dump_file" "$conf" | grep -v //)
	if [ -z "$opt_check" ]; then
		sed -i "s|options {|options {\n$dump_option |" "$conf"
		if command -v service >/dev/null 2>&1; then
			service named restart > /dev/null 2>&1
		fi
	fi
fi

# Checking statistics-file on Debian/Ubuntu
if [ -e "/etc/bind/named.conf" ]; then
	conf="/etc/bind/named.conf.options"
	dump_file='/var/cache/bind/named.stats'
	#dump_option="    dump-file           \"$dump_file\";"
	#opt_check=$(grep "$dump_file" "$conf" | grep -v //)
	#if [ -z "$opt_check" ]; then
	#    sed -i "s|options {|options {\n$dump_option |" "$conf"
	#    service named restart >/dev/null 2>&1
	#fi
fi

# Checking statistics-file on FreeBSD
if [ -e "/usr/local/etc/namedb/named.conf" ]; then
	conf="/usr/local/etc/namedb/named.conf"
	dump_file='/var/db/named/named.stats'
	dump_option="    dump-file \"$dump_file\";"
	opt_check=$(grep "$dump_file" "$conf" | grep -v //)
	if [ -z "$opt_check" ]; then
		sed -i '' "s|options {|options {\n$dump_option |" "$conf"
		if command -v service >/dev/null 2>&1; then
			service named restart > /dev/null 2>&1
		fi
	fi
fi

# Generating dns stats
rm -f "$dump_file" 2> /dev/null
if command -v rndc >/dev/null 2>&1; then
	$rndc stats 2> /dev/null
fi

# Displaying dns status
if [ -e "$dump_file" ]; then
	cat "$dump_file"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
