#!/bin/bash
# info: list user log
# options: USER [FORMAT]
#
# This function of obtaining the list of 10 last users commands.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(echo "$logs" | wc -l)
	echo "{"
	echo "$logs" | while read -r line; do
		[ -z "$line" ] && continue
		DATE=$(echo "$line" | cut -f 2 -d "'")
		TIME=$(echo "$line" | cut -f 4 -d "'")
		IP=$(echo "$line" | cut -f 6 -d "'")
		ACTION=$(echo "$line" | cut -f 8 -d "'")
		STATUS=$(echo "$line" | cut -f 10 -d "'")
		USER_AGENT=$(echo "$line" | cut -f 12 -d "'")
		SESSION=$(echo "$line" | cut -f 14 -d "'")
		ACTIVE=$(echo "$line" | cut -f 16 -d "'")
		printf '    "%d": {' "$i"
		printf '"DATE": "%s", ' "$DATE"
		printf '"TIME": "%s", ' "$TIME"
		printf '"IP": "%s", ' "$IP"
		printf '"ACTION": "%s", ' "$ACTION"
		printf '"STATUS": "%s", ' "$STATUS"
		printf '"USER_AGENT": "%s", ' "$USER_AGENT"
		printf '"SESSION": "%s", ' "$SESSION"
		printf '"ACTIVE": "%s"}' "$ACTIVE"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done
	echo "}"
}

shell_list() {
	printf "%-10s | %-10s | %-15s | %-10s | %-10s | %-20s | %-10s | %-10s\n" "DATE" "TIME" "IP" "ACTION" "STATUS" "USER_AGENT" "SESSION" "ACTIVE"
	printf "%-10s | %-10s | %-15s | %-10s | %-10s | %-20s | %-10s | %-10s\n" "----------" "----------" "---------------" "----------" "----------" "--------------------" "----------" "----------"
	echo "$logs" | while read -r line; do
		[ -z "$line" ] && continue
		DATE=$(echo "$line" | cut -f 2 -d "'")
		TIME=$(echo "$line" | cut -f 4 -d "'")
		IP=$(echo "$line" | cut -f 6 -d "'")
		ACTION=$(echo "$line" | cut -f 8 -d "'")
		STATUS=$(echo "$line" | cut -f 10 -d "'")
		USER_AGENT=$(echo "$line" | cut -f 12 -d "'")
		SESSION=$(echo "$line" | cut -f 14 -d "'")
		ACTIVE=$(echo "$line" | cut -f 16 -d "'")
		printf "%-10s | %-10s | %-15s | %-10s | %-10s | %-20s | %-10s | %-10s\n" "$DATE" "$TIME" "$IP" "$ACTION" "$STATUS" "$USER_AGENT" "$SESSION" "$ACTIVE"
	done
}

# PLAIN list function
plain_list() {
	echo "$logs" | while read -r line; do
		[ -z "$line" ] && continue
		DATE=$(echo "$line" | cut -f 2 -d "'")
		TIME=$(echo "$line" | cut -f 4 -d "'")
		IP=$(echo "$line" | cut -f 6 -d "'")
		ACTION=$(echo "$line" | cut -f 8 -d "'")
		STATUS=$(echo "$line" | cut -f 10 -d "'")
		USER_AGENT=$(echo "$line" | cut -f 12 -d "'")
		SESSION=$(echo "$line" | cut -f 14 -d "'")
		ACTIVE=$(echo "$line" | cut -f 16 -d "'")
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$DATE" "$TIME" "$IP" "$ACTION" "$STATUS" "$USER_AGENT" "$SESSION" "$ACTIVE"
	done
}

# CSV list function
csv_list() {
	echo "DATE,TIME,IP,ACTION,STATUS,USER_AGENT,SESSION,ACTIVE"
	echo "$logs" | while read -r line; do
		[ -z "$line" ] && continue
		DATE=$(echo "$line" | cut -f 2 -d "'")
		TIME=$(echo "$line" | cut -f 4 -d "'")
		IP=$(echo "$line" | cut -f 6 -d "'")
		ACTION=$(echo "$line" | cut -f 8 -d "'")
		STATUS=$(echo "$line" | cut -f 10 -d "'")
		USER_AGENT=$(echo "$line" | cut -f 12 -d "'")
		SESSION=$(echo "$line" | cut -f 14 -d "'")
		ACTIVE=$(echo "$line" | cut -f 16 -d "'")
		echo "$DATE,$TIME,$IP,$ACTION,$STATUS,$USER_AGENT,$SESSION,$ACTIVE"
	done
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing history log
logs=$(tail -n 10 "$USER_DATA/auth.log" 2>/dev/null)

if [ -z "$logs" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No logs found" ;;
		plain) ;;
		csv) echo "DATE,TIME,IP,ACTION,STATUS,USER_AGENT,SESSION,ACTIVE" ;;
	esac
	exit 0
fi

case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
