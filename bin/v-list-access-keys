#!/bin/sh
# info: list all API access keys
# options: [USER] [FORMAT]
#
# example: v-list-access-keys json

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# Argument definition
user="$1"
format="${2:-shell}"

# JSON list function
json_list() {
	first=1
	echo -n '{'
	
	for key_file in "$HESTIA/data/access-keys"/*; do
		[ -f "$key_file" ] || continue
		key_file_name=$(basename -- "$key_file")
		
		# 检查是否是有效的密钥 ID（20位字母数字）
		case "$key_file_name" in
			''|*[!A-Za-z0-9]*) continue ;;
		esac
		[ ${#key_file_name} -eq 20 ] || continue
		
		USER="$ROOT_USER"
		SECRET_ACCESS_KEY=""
		PERMISSIONS=""
		DATE=""
		TIME=""
		COMMENT=""
		source_conf "$HESTIA/data/access-keys/$key_file_name"
		
		# 过滤用户
		if [ -n "$user" ] && [ "$user" != "$USER" ]; then
			continue
		fi
		
		PERMISSIONS_ARR='[]'
		if [ -n "$PERMISSIONS" ]; then
			PERMISSIONS_ARR="[\"$(echo "$PERMISSIONS" | sed 's|,|", "|g')\"]"
		fi
		
		ACCESS_KEY_ID="$key_file_name"
		
		if [ "$first" -eq 0 ]; then
			echo -n ','
		fi
		first=0
		echo ""
		echo "    \"$ACCESS_KEY_ID\": {"
		echo "        \"ACCESS_KEY_ID\": \"$ACCESS_KEY_ID\","
		echo "        \"USER\": \"$USER\","
		echo "        \"PERMISSIONS\": $PERMISSIONS_ARR,"
		echo "        \"COMMENT\": \"$COMMENT\","
		echo "        \"TIME\": \"$TIME\","
		echo "        \"DATE\": \"$DATE\""
		echo -n "    }"
	done
	
	echo ""
	echo '}'
}

# SHELL list function
shell_list() {
	printf "%-20s %-10s %-30s %-20s %-8s %-10s\n" "ID" "USER" "PERMISSIONS" "COMMENT" "TIME" "DATE"
	printf "%-20s %-10s %-30s %-20s %-8s %-10s\n" "--" "------" "----" "-----------" "----" "----"
	
	for key_file in "$HESTIA/data/access-keys"/*; do
		[ -f "$key_file" ] || continue
		key_file_name=$(basename -- "$key_file")
		
		case "$key_file_name" in
			''|*[!A-Za-z0-9]*) continue ;;
		esac
		[ ${#key_file_name} -eq 20 ] || continue
		
		USER="$ROOT_USER"
		SECRET_ACCESS_KEY=""
		PERMISSIONS=""
		DATE=""
		TIME=""
		COMMENT=""
		source_conf "$HESTIA/data/access-keys/$key_file_name"
		
		if [ -n "$user" ] && [ "$user" != "$USER" ]; then
			continue
		fi
		
		ACCESS_KEY_ID="$key_file_name"
		
		printf "%-20s %-10s %-30s %-20s %-8s %-10s\n" \
			"$ACCESS_KEY_ID" \
			"$USER" \
			"${PERMISSIONS:--}" \
			"${COMMENT:--}" \
			"$TIME" \
			"$DATE"
	done
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Listing data
case $format in
	json) json_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit