#!/bin/bash
# info: start service
# options: SERVICE
#
# example: v-start-service mysql
#
# This function starts system service.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
service=$1

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
	OS="linux"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
	OS="freebsd"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'SERVICE'
is_format_valid 'service'

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ "$service" = "php-fpm" ]; then
	service_list=""
	for php_ver in $(multiphp_versions); do
		if [ "$OS" = "freebsd" ]; then
			version_clean=$(echo "$php_ver" | tr -d '.')
			service_list="${service_list} php${version_clean}_fpm"
		else
			service_list="${service_list} php${php_ver}-fpm"
		fi
	done
else
	service_list="$service"
fi

for service in $service_list; do
	if [ "$service" = "iptables" ] || [ "$service" = "pf" ] || [ "$service" = "ipfw" ]; then
		$BIN/v-update-firewall
	else
		if [ "$OS" = "freebsd" ]; then
			service "$service" start
		else
			systemctl start "$service"
		fi
		result=$?
		if [ "$result" -ne 0 ]; then
			$BIN/v-log-action "system" "Error" "System" "Service failed to start (Name: $service)."
		else
			$BIN/v-log-action "system" "Info" "System" "Service started (Name: $service)."
		fi
	fi
	check_result "$?" "ERROR: $service start failed" "$E_RESTART"
done

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
log_event "$OK" "$ARGUMENTS"

exit
