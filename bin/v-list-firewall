#!/bin/sh
# info: list firewall rules (iptables for Linux, pf for FreeBSD)
# options: [FORMAT]
#
# example: v-list-firewall json
#
# This function of obtaining the list of all firewall rules.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "RULE" "$HESTIA/data/firewall/rules.conf" 2>/dev/null || echo 0)
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo -n "    \"$RULE\": {"
		echo -n "\"ACTION\": \"$ACTION\", "
		echo -n "\"PROTOCOL\": \"$PROTOCOL\", "
		echo -n "\"PORT\": \"$PORT\", "
		echo -n "\"IP\": \"$IP\", "
		echo -n "\"COMMENT\": \"$COMMENT\", "
		echo -n "\"SUSPENDED\": \"$SUSPENDED\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$HESTIA/data/firewall/rules.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-6s %-10s %-8s %-10s %-20s %-6s %-12s\n" "RULE" "ACTION" "PROTO" "PORT" "IP" "SPND" "DATE"
	printf "%-6s %-10s %-8s %-10s %-20s %-6s %-12s\n" "----" "------" "-----" "----" "--" "----" "----"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%-6s %-10s %-8s %-10s %-20s %-6s %-12s\n" \
			"$RULE" "$ACTION" "$PROTOCOL" "$PORT" "$IP" "$SUSPENDED" "$DATE"
	done < "$HESTIA/data/firewall/rules.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$RULE" "$ACTION" "$PROTOCOL" "$PORT" "$IP" "$COMMENT" "$SUSPENDED" "$TIME" "$DATE"
	done < "$HESTIA/data/firewall/rules.conf"
}

# CSV list function
csv_list() {
	echo "RULE,ACTION,PROTOCOL,PORT,IP,COMMENT,SUSPENDED,TIME,DATE"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo "$RULE,$ACTION,$PROTOCOL,$PORT,$IP,\"$COMMENT\",$SUSPENDED,$TIME,$DATE"
	done < "$HESTIA/data/firewall/rules.conf"
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ ! -f "$HESTIA/data/firewall/rules.conf" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No firewall rules found" ;;
		plain) ;;
		csv) echo "RULE,ACTION,PROTOCOL,PORT,IP,COMMENT,SUSPENDED,TIME,DATE" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
