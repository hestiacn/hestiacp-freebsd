#!/bin/sh
# info: list mail domain accounts
# options: USER DOMAIN [FORMAT]
#
# example: v-list-mail-accounts admin acme.com
#
# This function of obtaining the list of all user domains.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
domain=$2
format=${3:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "ACCOUNT" "$USER_DATA/mail/$domain.conf")
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo -n "    \"$ACCOUNT\": {"
		echo -n "\"ALIAS\": \"$ALIAS\", "
		echo -n "\"FWD\": \"$FWD\", "
		echo -n "\"FWD_ONLY\": \"$FWD_ONLY\", "
		echo -n "\"AUTOREPLY\": \"$AUTOREPLY\", "
		echo -n "\"QUOTA\": \"$QUOTA\", "
		echo -n "\"U_DISK\": \"$U_DISK\", "
		echo -n "\"SUSPENDED\": \"$SUSPENDED\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$USER_DATA/mail/$domain.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-10s %-15s %-23s %-8s %-12s\n" "ACCOUNT" "ALIAS" "FWD" "DISK" "DATE"
	printf "%-10s %-15s %-23s %-8s %-12s\n" "-------" "-----" "---" "----" "----"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		alias_display="$ALIAS"
		fwd_display="$FWD"
		
		if [ -z "$ALIAS" ]; then
			alias_display='no'
		else
			if [ "$(echo "$ALIAS" | wc -m)" -gt 12 ]; then
				alias_display=$(echo "$ALIAS" | awk '{print substr($0, 1, 12) "..."}')
			fi
		fi
		
		if [ -z "$FWD" ]; then
			fwd_display='no'
		else
			if [ "$(echo "$FWD" | wc -m)" -gt 20 ]; then
				fwd_display=$(echo "$FWD" | awk '{print substr($0, 1, 20) "..."}')
			fi
		fi
		
		printf "%-10s %-15s %-23s %-8s %-12s\n" \
			"$ACCOUNT" "$alias_display" "$fwd_display" "$U_DISK" "$DATE"
	done < "$USER_DATA/mail/$domain.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$ACCOUNT" "$ALIAS" "$FWD" "$FWD_ONLY" "$AUTOREPLY" \
			"$QUOTA" "$U_DISK" "$SUSPENDED" "$TIME" "$DATE"
	done < "$USER_DATA/mail/$domain.conf"
}

# CSV list function
csv_list() {
	echo "ACCOUNT,ALIAS,FWD,FWD_ONLY,AUTOREPLY,QUOTA,U_DISK,SUSPENDED,TIME,DATE"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo "$ACCOUNT,\"$ALIAS\",\"$FWD\",$FWD_ONLY,$AUTOREPLY,$QUOTA,$U_DISK,$SUSPENDED,$TIME,$DATE"
	done < "$USER_DATA/mail/$domain.conf"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER DOMAIN [FORMAT]'
is_format_valid 'user' 'domain'
is_object_valid 'user' 'USER' "$user"
is_object_valid 'mail' 'DOMAIN' "$domain"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ ! -f "$USER_DATA/mail/$domain.conf" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No mail accounts found" ;;
		plain) ;;
		csv) echo "ACCOUNT,ALIAS,FWD,FWD_ONLY,AUTOREPLY,QUOTA,U_DISK,SUSPENDED,TIME,DATE" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
