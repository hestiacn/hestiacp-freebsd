#!/bin/bash
# info: list web domain access log
# options: USER DOMAIN [LINES] [FORMAT]
#
# example: v-list-web-domain-accesslog admin example.com
#
# This function of obtaining raw access web domain logs.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
domain=$2
ttl=${3:-70}
format=${4:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(echo "$lines" | wc -l)
	echo '['
	echo "$lines" | while read -r line; do
		[ -z "$line" ] && continue
		line=$(echo "$line" | sed -e 's/"/\\"/g')
		if [ "$i" -lt "$objects" ]; then
			printf '    "%s",\n' "$line"
		else
			printf '    "%s"\n' "$line"
		fi
		i=$((i + 1))
	done
	echo ']'
}

# SHELL list function
shell_list() {
	echo "$lines"
}

# PLAIN list function
plain_list() {
	echo "$lines"
}

# CSV list function
csv_list() {
	echo "LOG"
	echo "$lines"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER DOMAIN [LINES] [FORMAT]'
is_format_valid 'user' 'domain' 'ttl'
is_object_valid 'user' 'USER' "$user"
is_object_valid 'web' 'DOMAIN' "$domain"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#
log_path="/var/log/$WEB_SYSTEM/domains/$domain.log"

# Check number of output lines
if [ "$ttl" -gt 3000 ]; then
	read_cmd="cat"
else
	read_cmd="tail -n $ttl"
fi

if [ -f "$log_path" ]; then
	lines=$($read_cmd "$log_path" 2>/dev/null)
else
	lines=""
fi

if [ -z "$lines" ]; then
	case $format in
		json) echo "[]" ;;
		shell) echo "No log entries found" ;;
		plain) ;;
		csv) echo "LOG" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
