#!/bin/sh
# info: list hestia autoupdate settings
# options: [FORMAT]
#
# example: v-list-sys-hestia-autoupdate
#
# This function for obtaining autoupdate settings.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
	cron="/var/spool/cron/crontabs/hestiaweb"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
	cron="/var/cron/tabs/hestiaweb"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	echo '['
	if [ -z "$check_cron" ]; then
		echo '    "Disabled"'
	else
		echo '    "Enabled"'
	fi
	echo ']'
}

# SHELL list function
shell_list() {
	printf "AUTOUPDATE:     "
	if [ -z "$check_cron" ]; then
		echo "Disabled"
	else
		echo "Enabled"
	fi
}

# PLAIN list function
plain_list() {
	if [ -z "$check_cron" ]; then
		echo "Disabled"
	else
		echo "Enabled"
	fi
}

# CSV list function
csv_list() {
	echo "AUTOUPDATE"
	if [ -z "$check_cron" ]; then
		echo "Disabled"
	else
		echo "Enabled"
	fi
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Check cron tab
check_cron=$(grep 'v-update-sys-hestia-all' "$cron")

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
