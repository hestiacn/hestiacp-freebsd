#!/bin/sh
# info: delete system ssh jail
# options: NONE
#
# example: v-delete-sys-ssh-jail
#
# This function disables ssh jailed environment

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Delete system ssh jail - FreeBSD version

# Remove jailbash from shells and filesystem
sed -i "" "/\/usr\/sbin\/jailbash/d" /etc/shells
rm -f /usr/sbin/jailbash

# Restore internal-sftp
sed -i "" "s|Subsystem sftp /usr/sbin/jailbash|Subsystem sftp internal-sftp|g" /etc/ssh/sshd_config

# Restart SSH
service sshd restart

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Warning" "Plugins" "SSH Chroot Jail disabled."
log_event "$OK" "$ARGUMENTS"

exit 0
