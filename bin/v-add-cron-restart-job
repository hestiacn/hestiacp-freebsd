#!/bin/bash
# info: add cron restart queue
# options: NONE
#
# This function for enabling restart cron tasks

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
source /usr/local/etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

is_system_enabled "$CRON_SYSTEM" 'CRON_SYSTEM'

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Add cron job
cmd="v-update-sys-queue restart"
if [ -f "/var/cron/tabs/hestiaweb" ]; then
	check_cron=$(grep "$cmd" "/var/cron/tabs/hestiaweb" 2> /dev/null)
	if [ -z "$check_cron" ] && [ -n "$CRON_SYSTEM" ]; then
		echo "*/2 * * * * /usr/local/hestia/bin/v-update-sys-queue restart" >> "/var/cron/tabs/hestiaweb"
	fi
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
log_event "$OK" "$ARGUMENTS"

exit
