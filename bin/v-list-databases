#!/bin/sh
# info: listing databases
# options: USER [FORMAT]
#
# example: v-list-databases user json
#
# This function for obtaining the list of all user's databases.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "DB=" "$USER_DATA/db.conf" 2>/dev/null || echo 0)
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo -n "    \"$DB\": {"
		echo -n "\"DATABASE\": \"$DB\", "
		echo -n "\"DBUSER\": \"$DBUSER\", "
		echo -n "\"HOST\": \"$HOST\", "
		echo -n "\"TYPE\": \"$TYPE\", "
		echo -n "\"CHARSET\": \"$CHARSET\", "
		echo -n "\"U_DISK\": \"$U_DISK\", "
		echo -n "\"SUSPENDED\": \"$SUSPENDED\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$USER_DATA/db.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-15s %-15s %-10s %-8s %-10s %-6s %-12s\n" "DATABASE" "USER" "HOST" "TYPE" "DISK" "SPND" "DATE"
	printf "%-15s %-15s %-10s %-8s %-10s %-6s %-12s\n" "--------" "----" "----" "----" "----" "----" "----"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%-15s %-15s %-10s %-8s %-10s %-6s %-12s\n" \
			"$DB" "$DBUSER" "$HOST" "$TYPE" "$U_DISK" "$SUSPENDED" "$DATE"
	done < "$USER_DATA/db.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$DB" "$DBUSER" "$HOST" "$TYPE" "$CHARSET" "$U_DISK" "$SUSPENDED" "$TIME" "$DATE"
	done < "$USER_DATA/db.conf"
}

# CSV list function
csv_list() {
	echo "DATABASE,DBUSER,HOST,TYPE,CHARSET,U_DISK,SUSPENDED,TIME,DATE"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo "$DB,$DBUSER,$HOST,$TYPE,$CHARSET,$U_DISK,$SUSPENDED,$TIME,$DATE"
	done < "$USER_DATA/db.conf"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ ! -f "$USER_DATA/db.conf" ]; then
	case $format in
		json) echo "[]" ;;
		shell) echo "No databases found for user $user" ;;
		plain) ;;
		csv) echo "DATABASE,DBUSER,HOST,TYPE,CHARSET,U_DISK,SUSPENDED,TIME,DATE" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
