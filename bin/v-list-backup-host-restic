#!/bin/sh
# info: list backup host (restic)
# options: [FORMAT]
#
# example: v-list-backup-host-restic json
#
# This function for obtaining the list of restic backup parameters.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	echo '{'
	echo "    \"restic\": {"
	echo "        \"REPO\": \"$REPO\","
	echo "        \"SNAPSHOTS\": \"$SNAPSHOTS\","
	echo "        \"KEEP_DAILY\": \"$KEEP_DAILY\","
	echo "        \"KEEP_WEEKLY\": \"$KEEP_WEEKLY\","
	echo "        \"KEEP_MONTHLY\": \"$KEEP_MONTHLY\","
	echo "        \"KEEP_YEARLY\": \"$KEEP_YEARLY\""
	echo "    }"
	echo '}'
}

# SHELL list function
shell_list() {
	echo "REPO:           $REPO"
	echo "SNAPSHOTS:      $SNAPSHOTS"
	echo "KEEP_DAILY:     $KEEP_DAILY"
	echo "KEEP_WEEKLY:    $KEEP_WEEKLY"
	echo "KEEP_MONTHLY:   $KEEP_MONTHLY"
	echo "KEEP_YEARLY:    $KEEP_YEARLY"
}

# PLAIN list function
plain_list() {
	printf "%s\t%s\t%s\t%s\t%s\t%s\n" "$REPO" "$SNAPSHOTS" "$KEEP_DAILY" "$KEEP_WEEKLY" "$KEEP_MONTHLY" "$KEEP_YEARLY"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Checking backup config
if [ ! -e "$HESTIA/conf/restic.conf" ]; then
	exit 0
fi

# Parsing backup config
source_conf "$HESTIA/conf/restic.conf"

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	shell) shell_list | column -t ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
