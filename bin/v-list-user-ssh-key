#!/bin/bash
# info: list ssh keys
# options: USER [FORMAT]
#
# Lists user's SSH keys from $user/.ssh/authorized_keys

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(echo "$keys" | wc -l)
	echo "{"
	echo "$keys" | while read -r line; do
		[ -z "$line" ] && continue
		KEY=$(echo "$line" | awk '{print $(NF-2)}')
		ID=$(echo "$line" | awk '{print $(NF-1)}')
		echo -n "    \"$ID\": {"
		echo -n "\"ID\": \"$ID\", "
		echo "\"KEY\": \"$KEY\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-20s %-50s\n" "ID" "KEY"
	printf "%-20s %-50s\n" "--" "---"
	echo "$keys" | while read -r line; do
		[ -z "$line" ] && continue
		KEY=$(echo "$line" | awk '{print $(NF-2)}')
		ID=$(echo "$line" | awk '{print $(NF-1)}')
		printf "%-20s %-50s\n" "$ID" "$KEY"
	done
}

# PLAIN list function
plain_list() {
	echo "$keys" | while read -r line; do
		[ -z "$line" ] && continue
		KEY=$(echo "$line" | awk '{print $(NF-2)}')
		ID=$(echo "$line" | awk '{print $(NF-1)}')
		printf "%s\t%s\n" "$ID" "$KEY"
	done
}

# CSV list function
csv_list() {
	echo "ID,KEY"
	echo "$keys" | while read -r line; do
		[ -z "$line" ] && continue
		KEY=$(echo "$line" | awk '{print $(NF-2)}')
		ID=$(echo "$line" | awk '{print $(NF-1)}')
		echo "\"$ID\",\"$KEY\""
	done
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"
is_object_unsuspended 'user' 'USER' "$user"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

AUTHKEY_FILE="$HOMEDIR/$user/.ssh/authorized_keys"
if [ -z "$(readlink -f "$AUTHKEY_FILE" | grep -E "^$HOMEDIR/$user/.ssh/")" ]; then
	check_result "$E_FORBIDDEN" "Invalid authorized keys path"
fi

# Check if file exists
if [ ! -f "$AUTHKEY_FILE" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No SSH keys found" ;;
		plain) ;;
		csv) echo "ID,KEY" ;;
	esac
	exit 0
fi

keys=""
first_loop=1
while read -r line; do
	# Skip comments and empty lines
	if [ -n "$line" ] && [ "${line###}" = "$line" ]; then
		sshkey=$(ssh-keygen -l -f <(echo "$line") 2>/dev/null)
		if [ -n "$sshkey" ]; then
			if [ "$first_loop" -eq 1 ]; then
				keys="$sshkey"
				first_loop=0
			else
				keys="$keys"$'\n'"$sshkey"
			fi
		fi
	fi
done < "$AUTHKEY_FILE"

if [ -z "$keys" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No valid SSH keys found" ;;
		plain) ;;
		csv) echo "ID,KEY" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
