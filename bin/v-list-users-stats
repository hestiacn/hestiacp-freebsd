#!/bin/bash
# info: list overall user stats
# options: [FORMAT]
#
# This function for listing overall user statistics

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "DATE" "$HESTIA/data/users/$ROOT_USER/overall_stats.log")
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo -n "    \"$DATE\": {"
		echo -n "\"TIME\": \"$TIME\", "
		echo -n "\"PACKAGE\": \"$PACKAGE\", "
		echo -n "\"IP_OWNED\": \"$IP_OWNED\", "
		echo -n "\"DISK_QUOTA\": \"$DISK_QUOTA\", "
		echo -n "\"U_DISK\": \"$U_DISK\", "
		echo -n "\"U_DISK_DIRS\": \"$U_DISK_DIRS\", "
		echo -n "\"U_DISK_WEB\": \"$U_DISK_WEB\", "
		echo -n "\"U_DISK_MAIL\": \"$U_DISK_MAIL\", "
		echo -n "\"U_DISK_DB\": \"$U_DISK_DB\", "
		echo -n "\"BANDWIDTH\": \"$BANDWIDTH\", "
		echo -n "\"U_BANDWIDTH\": \"$U_BANDWIDTH\", "
		echo -n "\"U_WEB_DOMAINS\": \"$U_WEB_DOMAINS\", "
		echo -n "\"U_WEB_SSL\": \"$U_WEB_SSL\", "
		echo -n "\"U_WEB_ALIASES\": \"$U_WEB_ALIASES\", "
		echo -n "\"U_DNS_DOMAINS\": \"$U_DNS_DOMAINS\", "
		echo -n "\"U_DNS_RECORDS\": \"$U_DNS_RECORDS\", "
		echo -n "\"U_MAIL_DOMAINS\": \"$U_MAIL_DOMAINS\", "
		echo -n "\"U_MAIL_DKIM\": \"$U_MAIL_DKIM\", "
		echo -n "\"U_MAIL_ACCOUNTS\": \"$U_MAIL_ACCOUNTS\", "
		echo -n "\"U_DATABASES\": \"$U_DATABASES\", "
		echo -n "\"U_CRON_JOBS\": \"$U_CRON_JOBS\", "
		echo -n "\"U_BACKUPS\": \"$U_BACKUPS\", "
		echo "\"U_USERS\": \"$U_USERS\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$HESTIA/data/users/$ROOT_USER/overall_stats.log"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-12s %-6s %-6s %-6s %-6s %-5s %-8s %-6s %-8s %-8s\n" \
		"DATE" "USER" "WEB" "DNS" "MAIL" "DB" "BACKUPS" "IP" "DISK" "BW"
	printf "%-12s %-6s %-6s %-6s %-6s %-5s %-8s %-6s %-8s %-8s\n" \
		"----" "----" "---" "---" "----" "--" "-------" "--" "----" "--"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		U_USERS=${U_USERS:-1}
		printf "%-12s %-6s %-6s %-6s %-6s %-5s %-8s %-6s %-8s %-8s\n" \
			"$DATE" "$U_USERS" "$U_WEB_DOMAINS" "$U_DNS_DOMAINS" \
			"$U_MAIL_DOMAINS" "$U_DATABASES" "$U_BACKUPS" "$IP_OWNED" \
			"$U_DISK" "$U_BANDWIDTH"
	done < "$HESTIA/data/users/$ROOT_USER/overall_stats.log"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$DATE" "$TIME" "$PACKAGE" "$IP_OWNED" "$DISK_QUOTA" "$U_DISK" \
			"$U_DISK_DIRS" "$U_DISK_WEB" "$U_DISK_MAIL" "$U_DISK_DB" \
			"$BANDWIDTH" "$U_BANDWIDTH" "$U_WEB_DOMAINS" "$U_WEB_SSL" \
			"$U_WEB_ALIASES" "$U_DNS_DOMAINS" "$U_DNS_RECORDS" \
			"$U_MAIL_DOMAINS" "$U_MAIL_DKIM" "$U_MAIL_ACCOUNTS" \
			"$U_DATABASES" "$U_CRON_JOBS" "$U_BACKUPS" "$U_USERS"
	done < "$HESTIA/data/users/$ROOT_USER/overall_stats.log"
}

# CSV list function
csv_list() {
	echo "DATE,TIME,PACKAGE,IP_OWNED,DISK_QUOTA,U_DISK,U_DISK_DIRS,U_DISK_WEB,U_DISK_MAIL,U_DISK_DB,BANDWIDTH,U_BANDWIDTH,U_WEB_DOMAINS,U_WEB_SSL,U_WEB_ALIASES,U_DNS_DOMAINS,U_DNS_RECORDS,U_MAIL_DOMAINS,U_MAIL_DKIM,U_MAIL_ACCOUNTS,U_DATABASES,U_CRON_JOBS,U_BACKUPS,U_USERS"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo "$DATE,$TIME,$PACKAGE,$IP_OWNED,$DISK_QUOTA,$U_DISK,$U_DISK_DIRS,$U_DISK_WEB,$U_DISK_MAIL,$U_DISK_DB,$BANDWIDTH,$U_BANDWIDTH,$U_WEB_DOMAINS,$U_WEB_SSL,$U_WEB_ALIASES,$U_DNS_DOMAINS,$U_DNS_RECORDS,$U_MAIL_DOMAINS,$U_MAIL_DKIM,$U_MAIL_ACCOUNTS,$U_DATABASES,$U_CRON_JOBS,$U_BACKUPS,$U_USERS"
	done < "$HESTIA/data/users/$ROOT_USER/overall_stats.log"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '0' "$#" '[FORMAT]'

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Ensure statistics are up to date
$BIN/v-update-user-stats

# Defining config
conf="$HESTIA/data/users/$ROOT_USER/overall_stats.log"
if [ ! -e "$conf" ]; then
	touch "$conf"
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
