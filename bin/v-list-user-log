#!/bin/bash
# info: list user log
# options: USER [FORMAT]
#
# example: v-list-user-log
#
# This function of obtaining the list of 100 last users commands.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(echo "$logs" | wc -l)
	echo "{"
	echo "$logs" | while read -r line; do
		[ -z "$line" ] && continue
		ID=$(echo "$line" | cut -f 2 -d "'")
		DATE=$(echo "$line" | cut -f 4 -d "'")
		TIME=$(echo "$line" | cut -f 6 -d "'")
		LEVEL=$(echo "$line" | cut -f 8 -d "'")
		CATEGORY=$(echo "$line" | cut -f 10 -d "'")
		MESSAGE=$(echo "$line" | cut -f 12 -d "'")
		MESSAGE=${MESSAGE//\"/\\\"}
		echo -n "    \"$ID\": {"
		echo -n "\"DATE\": \"$DATE\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo -n "\"LEVEL\": \"$LEVEL\", "
		echo -n "\"CATEGORY\": \"$CATEGORY\", "
		echo "\"MESSAGE\": \"$MESSAGE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done
	echo "}"
}

shell_list() {
	printf "%-10s | %-12s | %-8s | %-10s | %-15s | %-50s\n" "ID" "DATE" "TIME" "LEVEL" "CATEGORY" "MESSAGE"
	printf "%-10s | %-12s | %-8s | %-10s | %-15s | %-50s\n" "----------" "------------" "--------" "----------" "---------------" "--------------------------------------------------"
	echo "$logs" | while read -r line; do
		[ -z "$line" ] && continue
		ID=$(echo "$line" | cut -f 2 -d "'")
		DATE=$(echo "$line" | cut -f 4 -d "'")
		TIME=$(echo "$line" | cut -f 6 -d "'")
		LEVEL=$(echo "$line" | cut -f 8 -d "'")
		CATEGORY=$(echo "$line" | cut -f 10 -d "'")
		MESSAGE=$(echo "$line" | cut -f 12 -d "'")
		printf "%-10s | %-12s | %-8s | %-10s | %-15s | %-50s\n" \
			"$ID" "$DATE" "$TIME" "$LEVEL" "$CATEGORY" "$MESSAGE"
	done
}

# PLAIN list function
plain_list() {
	echo "$logs" | while read -r line; do
		[ -z "$line" ] && continue
		ID=$(echo "$line" | cut -f 2 -d "'")
		DATE=$(echo "$line" | cut -f 4 -d "'")
		TIME=$(echo "$line" | cut -f 6 -d "'")
		LEVEL=$(echo "$line" | cut -f 8 -d "'")
		CATEGORY=$(echo "$line" | cut -f 10 -d "'")
		MESSAGE=$(echo "$line" | cut -f 12 -d "'")
		printf "%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$ID" "$DATE" "$TIME" "$LEVEL" "$CATEGORY" "$MESSAGE"
	done
}

# CSV list function
csv_list() {
	echo "ID,DATE,TIME,LEVEL,CATEGORY,MESSAGE"
	echo "$logs" | while read -r line; do
		[ -z "$line" ] && continue
		ID=$(echo "$line" | cut -f 2 -d "'")
		DATE=$(echo "$line" | cut -f 4 -d "'")
		TIME=$(echo "$line" | cut -f 6 -d "'")
		LEVEL=$(echo "$line" | cut -f 8 -d "'")
		CATEGORY=$(echo "$line" | cut -f 10 -d "'")
		MESSAGE=$(echo "$line" | cut -f 12 -d "'")
		echo "$ID,\"$DATE\",\"$TIME\",\"$LEVEL\",\"$CATEGORY\",\"$MESSAGE\""
	done
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
if [ "$user" != "system" ]; then
	is_object_valid 'user' 'USER' "$user"
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing history log
if [ "$user" = "system" ]; then
	log_file="$HESTIA/log/activity.log"
else
	log_file="$USER_DATA/history.log"
fi
logs=$(tail -n 300 "$log_file" 2>/dev/null)

if [ -z "$logs" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No logs found" ;;
		plain) ;;
		csv) echo "ID,DATE,TIME,LEVEL,CATEGORY,MESSAGE" ;;
	esac
	exit 0
fi

case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
