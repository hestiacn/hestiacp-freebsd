#!/bin/bash
# info: restart service
# options: SERVICE [RESTART]
#
# example: v-restart-service apache2
#
# This function restarts system service.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
service=$1
restart=$2

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source /etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'SERVICE [RESTART]'
is_format_valid 'service' 'restart'

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#
if [[ "$service" =~ ^php[0-9]+$ ]] || [[ "$service" =~ ^[0-9][0-9]$ ]]; then
	service="php-fpm"
fi

log="/dev/null"
if [ "$DEBUG_MODE" = "true" ]; then
	log="/var/log/hestia/debug.log"
fi

# Multi-instance service restart request handling
if [ "$service" = "php-fpm" ]; then
    service_list=''
    php_versions=$($BIN/v-list-sys-php plain)
    for version in $php_versions; do
        if [ "$OS" = "freebsd" ]; then
            service_list="${service_list} php${version//./}_fpm"
        else
            service_list="${service_list} php${version}-fpm"
        fi
    done
else
    if [ "$OS" = "freebsd" ]; then
        case "$service" in
            bind9|named)          service_list="named" ;;
            exim4|exim)           service_list="exim" ;;
            dovecot)              service_list="dovecot" ;;
            iptables|pf)          service_list="pf" ;;
            cron|crond)           service_list="cron" ;;
            ssh|sshd)             service_list="sshd" ;;
            apache2|apache|httpd) service_list="apache24" ;;
            nginx)                service_list="nginx" ;;
            mysql|mysqld|mariadb) service_list="mysql-server" ;;
            postgresql|pgsql)     service_list="postgresql" ;;
            pure-ftpd|vsftpd)     service_list="pure-ftpd" ;;
            fail2ban)             service_list="fail2ban" ;;
            *)                    service_list="$service" ;;
        esac
    else
        if [ -f /etc/redhat-release ]; then
            case "$service" in
                apache2|apache|httpd) service_list="httpd" ;;
                bind9|named)          service_list="named" ;;
                mysql|mysqld|mariadb) service_list="mariadb" ;;
                postgresql|pgsql)     service_list="postgresql" ;; 
                *)                    service_list="$service" ;;
            esac
        else
            service_list="$service"
        fi
    fi
fi

for service in $service_list; do
	# 💡 FreeBSD 适配：防火墙控制器置换
	if [ "$service" = "iptables" ] || [ "$service" = "pf" ]; then
		# 映射到未来你要重构的 FreeBSD PF 防火墙启停逻辑
		$BIN/v-stop-firewall
		$BIN/v-update-firewall
		continue
	fi

	# 执行重载或重启逻辑的分流
	if [ "$OS" = "freebsd" ]; then
		#----------------------------------------------------------#
		#                    FreeBSD 服务管理总控 (RC 系统)         #
		#----------------------------------------------------------#
		if [ "$restart" = "ssl" ] && [ "$service" = "nginx" ]; then
			service "$service" onereload >> $log 2>&1
		elif [ -z "$restart" ] || [ "$restart" = "no" ]; then
			service "$service" onereload >> $log 2>&1 || service "$service" onerestart >> $log 2>&1
		else
			service "$service" onerestart >> $log 2>&1
		fi
	else
		#----------------------------------------------------------#
		#                    Linux 服务管理总控 (Systemd)           #
		#----------------------------------------------------------#
		if [ "$restart" = "ssl" ] && [ "$service" = "nginx" ]; then
			service $service upgrade >> $log 2>&1
		elif [ -z "$restart" -o "$restart" = "no" ] && [ \
			"$service" = "nginx" -o \
			"$service" = "apache2" -o \
			"$service" = "exim4" -o \
			"$service" = "dovecot" -o \
			"$service" = "bind9" -o \
			"$service" = "named" -o \
			"$service" = "vsftpd" -o \
			"$service" = "php5.6-fpm" -o \
			"$service" = "php7.0-fpm" -o \
			"$service" = "php7.1-fpm" -o \
			"$service" = "php7.2-fpm" -o \
			"$service" = "php7.3-fpm" -o \
			"$service" = "php7.4-fpm" -o \
			"$service" = "php8.0-fpm" -o \
			"$service" = "php8.1-fpm" -o \
			"$service" = "php8.2-fpm" -o \
			"$service" = "php8.3-fpm" -o \
			"$service" = "php8.4-fpm" -o \
			"$service" = "php8.5-fpm" -o \
			"$service" = "proftpd" -o \
			"$service" = "ssh" -o \
			"$service" = "fail2ban" ]; then
			systemctl reload-or-restart "$service" >> $log 2>&1
		else
			systemctl reset-failed "$service" >> $log 2>&1
			systemctl restart "$service" >> $log 2>&1
		fi
	fi

	# Check the result of the service restart and report whether it failed.
	if [ $? -ne 0 ]; then
		check_result "$E_RESTART" "ERROR: Restart of $service failed."
		$BIN/v-log-action "system" "Error" "System" "Service failed to restart (Name: $service)."
	else
		$BIN/v-log-action "system" "Info" "System" "Service restarted (Name: $service)."
	fi
done

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
log_event "$OK" "$ARGUMENTS"

exit
