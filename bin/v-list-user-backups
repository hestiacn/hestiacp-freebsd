#!/bin/bash
# info: list user backups
# options: USER [FORMAT]
#
# example: v-list-user-backups admin
#
# This function for obtaining the list of available user backups.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "BACKUP" "$USER_DATA/backup.conf")
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo -n "    \"$BACKUP\": {"
		echo -n "\"TYPE\": \"$TYPE\", "
		echo -n "\"SIZE\": \"$SIZE\", "
		echo -n "\"WEB\": \"$WEB\", "
		echo -n "\"DNS\": \"$DNS\", "
		echo -n "\"MAIL\": \"$MAIL\", "
		echo -n "\"DB\": \"$DB\", "
		echo -n "\"CRON\": \"$CRON\", "
		echo -n "\"UDIR\": \"$UDIR\", "
		echo -n "\"RUNTIME\": \"$RUNTIME\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$USER_DATA/backup.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-30s %-8s %-8s %-10s %-12s\n" "BACKUP" "TYPE" "SIZE" "RUNTIME" "DATE"
	printf "%-30s %-8s %-8s %-10s %-12s\n" "------" "----" "----" "-------" "----"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%-30s %-8s %-8s %-10s %-12s\n" \
			"$BACKUP" "$TYPE" "$SIZE" "$RUNTIME" "$DATE"
	done < "$USER_DATA/backup.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$BACKUP" "$TYPE" "$SIZE" "$WEB" "$DNS" "$MAIL" "$CRON" "$UDIR" \
			"$RUNTIME" "$TIME" "$DATE"
	done < "$USER_DATA/backup.conf"
}

# CSV list function
csv_list() {
	echo "BACKUP,TYPE,SIZE,WEB,DNS,MAIL,CRON,UDIR,RUNTIME,TIME,DATE"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo "$BACKUP,$TYPE,$SIZE,\"$WEB\",\"$DNS\",\"$MAIL\",\"$CRON\",\"$UDIR\",$RUNTIME,$TIME,$DATE"
	done < "$USER_DATA/backup.conf"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Checking config
conf="$USER_DATA/backup.conf"
if [ ! -e "$conf" ]; then
	touch "$conf"
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
