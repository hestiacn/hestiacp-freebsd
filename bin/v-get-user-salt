#!/bin/sh
# info: get user salt
# options: USER [IP] [FORMAT]
#
# example: v-get-user-salt admin
#
# This function provides users salt

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
ip46=${2:-127.0.0.1}
format=${3:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# shellcheck source=/usr/local/hestia/conf/hestia.conf
source $HESTIA/conf/hestia.conf
# load config file
source_conf "$HESTIA/conf/hestia.conf"

time_n_date=$(date +'%T %F')
time=$(echo "$time_n_date" | cut -d' ' -f1)
date=$(echo "$time_n_date" | cut -d' ' -f2)

# JSON list function
json_list() {
    echo '{'
    echo "    \"$user\": {"
    echo "        \"METHOD\": \"$method\","
    echo "        \"SALT\": \"$salt\","
    echo "        \"TIME\": \"$time\","
    echo "        \"DATE\": \"$date\""
    echo "    }"
    echo '}'
}

# SHELL list function
shell_list() {
    echo "METHOD:         $method"
    echo "SALT:           $salt"
}

# PLAIN list function
plain_list() {
    printf "%s\t%s\n" "$method" "$salt"
}

# CSV list function
csv_list() {
    echo "METHOD,SALT"
    echo "$method,$salt"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [IP] [FORMAT]'
is_format_valid 'user' 'ip46'

# Checking user
if [ ! -d "$HESTIA/data/users/$user" ]; then
    echo "Error: password mismatch"
    echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
    exit 9
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing user's salt
shadow=$(grep "^$user:" /etc/master.passwd | cut -f 2 -d ':')

case "$shadow" in
    \$*\$*\$*)
        method=$(echo "$shadow" | cut -d'$' -f2)
        salt=$(echo "$shadow" | cut -d'$' -f3)
        case "$method" in
            y)
                method='yescrypt'
                salt=$(echo "$shadow" | cut -d'$' -f4)
                ;;
            1)
                method='md5'
                ;;
            5)
                method='sha-256'
                ;;
            6)
                method='sha-512'
                ;;
            *)
                echo "Error: password mismatch"
                echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
                exit 9
                ;;
        esac
        ;;
    *!*)
        echo "Error: Account has been suspended"
        echo "$date $time $user $ip46 has been suspended" >> $HESTIA/log/auth.log
        exit 5
        ;;
    *)
        salt=$(echo "$shadow" | cut -c1-2)
        method='des'
        ;;
esac

if [ -z "$salt" ]; then
    echo "Error: password mismatch"
    echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
    exit 9
fi

# Listing data
case $format in
    json) json_list ;;
    plain) plain_list ;;
    csv) csv_list ;;
    shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
