#!/bin/sh
# info: delete system sftp jail
# options: NONE
#
# example: v-delete-sys-sftp-jail
#
# This function disables sftp jailed environment

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# FreeBSD: sshd config path
config='/etc/ssh/sshd_config'
backup_config="${config}.bak"

# Check if backup exists before creating new one
if [ ! -f "$backup_config" ]; then
    cp "$config" "$backup_config"
fi

# Find lines to modify
sftp_line=$(grep -n "^Subsystem.*sftp" "$config" | head -1)
sftp_chroot_block=$(grep -n "^# Hestia SFTP Chroot" "$config")

restart=''

# Enable standard sftp
if [ -n "$sftp_line" ]; then
    if echo "$sftp_line" | grep -q "^[0-9]*:#"; then
        line_num=$(echo "$sftp_line" | cut -d: -f1)
        sed -i "" "${line_num}s/^#//" "$config"
        restart='yes'
    fi
fi

# Remove Hestia SFTP Chroot block if exists
if [ -n "$sftp_chroot_block" ]; then
    start_line=$(echo "$sftp_chroot_block" | cut -d: -f1)
    end_line=$((start_line + 8))
    sed -i "" "${start_line},${end_line}d" "$config" 2>/dev/null || \
    sed -i "" "/^# Hestia SFTP Chroot/,/^Match/d" "$config"
    restart='yes'
fi

# Also remove any Match Group sftp-chroot blocks
if grep -q "^Match Group sftp-chroot" "$config" 2>/dev/null; then
    sed -i "" "/^Match Group sftp-chroot/,/^[^[:space:]]/d" "$config"
    restart='yes'
fi

# Validate sshd config and restart if needed
if [ "$restart" = 'yes' ]; then
    # Test configuration
    if /usr/sbin/sshd -t 2>/dev/null; then
        service sshd restart > /dev/null 2>&1
        check_result $? "SSH restart failed" > /dev/null
    else
        # Restore backup on error
        cp "$backup_config" "$config"
        echo "Error: SSH configuration invalid, changes reverted"
        log_event "$E_INVALID" "Invalid SSH config, restored backup"
    fi
fi

# Remove
if [ -f "/etc/cron.d/hestia-sftp" ]; then
    rm -f "/etc/cron.d/hestia-sftp"
fi

if [ -f "/etc/periodic/daily/hestia-sftp" ]; then
    rm -f "/etc/periodic/daily/hestia-sftp"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Warning" "Plugins" "SFTP Chroot Jail disabled."
log_event "$OK" "$ARGUMENTS"

exit 0
