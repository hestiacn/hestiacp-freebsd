#!/bin/bash
# info: add system sftp jail
# options: [RESTART]
#
# example: v-add-sys-sftp-jail yes
#
# This function enables sftp jailed environment on FreeBSD.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes (Adjusted to FreeBSD Private Port/Repository Standard Paths)
source /usr/local/etc/hestiacp/hestia.conf
source $HESTIA/func/main.sh
source_conf "$HESTIA/conf/hestia.conf"

# Aligned with official spec: Accepts only $1 parameter
restart=$1

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Checking sshd directives
config='/etc/ssh/sshd_config'
sftp_n=$(grep -n "Subsystem.*sftp" $config | grep -v internal | grep -v ":#")
sftp_i=$(grep -n "^# Hestia SFTP Chroot" $config)

# 1. Disabling normal sftp (Fixed BSD sed missing backup extension syntax)
if [ -n "$sftp_n" ]; then
	fline=$(echo $sftp_n | cut -f 1 -d :)
	sed -i "" "${fline}s/Subsystem.*sftp/Subsystem sftp internal-sftp/" $config
	restart='yes'
fi

# 2. Enabling jailed sftp global match block
if [ -z "$sftp_i" ]; then
	echo " " >> $config
	echo "# Hestia SFTP Chroot" >> $config
	echo "Match User sftp_dummy99" >> $config
	echo "    ChrootDirectory /srv/jail/%u" >> $config
	echo "    X11Forwarding no" >> $config
	echo "    AllowTCPForwarding no" >> $config
	echo "    ForceCommand internal-sftp -d /home/%u" >> $config
	restart='yes'
fi

# 3. Validating opensshd config and restarting FreeBSD service
if [ "$restart" = 'yes' ]; then
	subj="OpenSSH restart failed"
	email=$(grep CONTACT "$HESTIA/data/users/$ROOT_USER/user.conf" | cut -f 2 -d \')
	
	# Execute FreeBSD native sshd validation
	/usr/sbin/sshd -t > /dev/null 2>&1
	if [ "$?" -ne 0 ]; then
		# Clean English error logging payload
		mail_text="OpenSSH can not be restarted. Please check config:\n\n$(/usr/sbin/sshd -t 2>&1)"
		echo -e "$mail_text" | $SENDMAIL -s "$subj" $email
	else
		# Fixed: FreeBSD system service identifier must be sshd (not ssh)
		service sshd restart > /dev/null 2>&1
	fi
fi

# 4. Checking users (Expanded fallback regex to match FreeBSD nologin shell paths)
shells="rssh|nologin"
for user in $(grep "$HOMEDIR" /etc/passwd | egrep "$shells" | cut -f 1 -d:); do
	if [ -d "$HOMEDIR/$user" ]; then
		# Call single-user script with exactly 2 arguments locally
		$BIN/v-add-user-sftp-jail "$user" "no"
	fi
done

# 5. Final audit: restart service if requested by any internal logic block
if [ "$restart" = 'no' ] || [ -z "$restart" ]; then
	echo "" > /dev/null 2>&1
else
	service sshd restart > /dev/null 2>&1
fi

# 6. === 🍏 FreeBSD Modular /etc/cron.d File Drop ===
# Your environment natively parses /etc/cron.d as a standard multi-column cron ledger.
# We write an independent 'hestia-sftp' file to guarantee 100% autostart isolation.
cron_file="/etc/cron.d/hestia-sftp"
if [ ! -f "$cron_file" ]; then
	echo "# hestia-sftp: auto-healing routine for OpenSSH jailed environment" > "$cron_file"
	echo "@reboot root sleep 60 && /usr/local/hestia/bin/v-add-sys-sftp-jail > /dev/null 2>&1" >> "$cron_file"
	chmod 644 "$cron_file"
	service cron restart >/dev/null 2>&1
fi


#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

log_event "$OK" "$ARGUMENTS"

exit 0
