#!/bin/bash
# info: update user resource limits (RCTL)
# options: USER
#
# example: v-update-user-cgroup admin
#
# The functions updates rctl, cpu, ram ,... for specific user

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1

# Includes
source /usr/local/etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '0' "$#" 'USER'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#
if [ -f "/etc/rctl.conf" ]; then
	sed -i "" "/user:${user}:/d" /etc/rctl.conf
fi
/sbin/rctl -r "user:${user}" > /dev/null 2>&1

# get user resources values
cpu_quota=$(get_user_value '$CPU_QUOTA')
cpu_quota_period=$(get_user_value '$CPU_QUOTA_PERIOD')
memory_limit=$(get_user_value '$MEMORY_LIMIT')
swap_limit=$(get_user_value '$SWAP_LIMIT')

# Set CPU quota via FreeBSD RCTL (pcpu):
if [ "$cpu_quota" != 'unlimited' ]; then
	cpu_val=$(echo "$cpu_quota" | tr -d '%')
	/sbin/rctl -a "user:${user}:pcpu:deny=${cpu_val}" > /dev/null 2>&1
	echo "user:${user}:pcpu:deny=${cpu_val}" >> /etc/rctl.conf
fi

# Set CPU period for CFS:
if [ "$cpu_quota_period" != 'unlimited' ]; then
	:
fi

# Set memory limits via FreeBSD RCTL (vmem):
if [ "$memory_limit" != 'unlimited' ]; then
	/sbin/rctl -a "user:${user}:vmem:deny=${memory_limit}" > /dev/null 2>&1
	echo "user:${user}:vmem:deny=${memory_limit}" >> /etc/rctl.conf
fi

# Set memory swap limits via FreeBSD RCTL (swapuse):
if [ "$swap_limit" != 'unlimited' ]; then
	/sbin/rctl -a "user:${user}:swapuse:deny=${swap_limit}" > /dev/null 2>&1
	echo "user:${user}:swapuse:deny=${swap_limit}" >> /etc/rctl.conf
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
log_event "$OK" "$ARGUMENTS"

exit
