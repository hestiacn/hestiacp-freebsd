#!/bin/bash
# info: add system ssh jail for FreeBSD
# options: NONE
#
# example: v-add-sys-ssh-jail
#
# This function enables ssh jailed environment on FreeBSD.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
source /usr/local/etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"


# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Move jailbash to /usr/sbin
if [ ! -x /usr/sbin/jailbash ]; then
	cp -f $HESTIA_COMMON_DIR/bubblewrap/jailbash /usr/sbin/jailbash
	chmod +x /usr/sbin/jailbash

fi

# Register /usr/sbin/jailbash
if [ -z "$(grep ^/usr/sbin/jailbash /etc/shells)" ]; then
	echo "/usr/sbin/jailbash" >> /etc/shells
fi

# Use sftp-server binary so the sftp process can run inside jailbash
if [ -z "$(grep 'Subsystem sftp /usr/libexec/sftp-server' /etc/ssh/sshd_config)" ]; then
	sed -i "" -E "s|Subsystem sftp internal-sftp|Subsystem sftp /usr/libexec/sftp-server|g" /etc/ssh/sshd_config
	sed -i "" -E "s|Subsystem sftp /usr/lib/sftp-server|Subsystem sftp /usr/libexec/sftp-server|g" /etc/ssh/sshd_config
    service sshd restart > /dev/null 2>&1
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
log_event "$OK" "$ARGUMENTS"

exit
