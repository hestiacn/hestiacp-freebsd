#!/bin/sh
# info: delete firewall chain
# options: CHAIN
#
# example: v-delete-firewall-chain WEB
#
# This function adds new rule to system firewall

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
chain=$(echo "$1" | tr '[:lower:]' '[:upper:]')

# FreeBSD: pf or ipfw commands
if [ "$FIREWALL_SYSTEM" = "pf" ]; then
    pfctl="/sbin/pfctl"
elif [ "$FIREWALL_SYSTEM" = "ipfw" ]; then
    ipfw="/sbin/ipfw"
fi

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# shellcheck source=/usr/local/hestia/func/firewall.sh
source "$HESTIA/func/firewall.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'CHAIN'
is_format_valid 'chain'
is_system_enabled "$FIREWALL_SYSTEM" 'FIREWALL_SYSTEM'

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# heal_iptables_links

# Deleting chain
chains="$HESTIA/data/firewall/chains.conf"
banlist="$HESTIA/data/firewall/banlist.conf"
chain_param=""
[ -f "$chains" ] && chain_param=$(grep "CHAIN='$chain'" "$chains")
if [ -n "$chain_param" ]; then
    parse_object_kv_list "$chain_param"
    sed -i "" "/CHAIN='$chain'/d" "$chains"
    sed -i "" "/CHAIN='$chain'/d" "$banlist"
    if [ "$FIREWALL_SYSTEM" = "pf" ]; then
        $pfctl -a "fail2ban/$chain" -F all 2>/dev/null
        $pfctl -a "fail2ban" -F all 2>/dev/null
    elif [ "$FIREWALL_SYSTEM" = "ipfw" ]; then
        rule_num=$($ipfw list | grep -w "fail2ban-$chain" | awk '{print $1}' | head -1)
        $ipfw delete "$rule_num" 2>/dev/null
    fi
fi

# Deleting pf table or ipfw chain
if [ "$FIREWALL_SYSTEM" = "pf" ]; then
    $pfctl -t "fail2ban-$chain" -T kill 2>/dev/null
elif [ "$FIREWALL_SYSTEM" = "ipfw" ]; then
    $ipfw delete set "fail2ban-$chain" 2>/dev/null
fi

# Changing permissions
[ -f "$chains" ] && chmod 660 "$chains"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
log_event "$OK" "$ARGUMENTS"

exit 0