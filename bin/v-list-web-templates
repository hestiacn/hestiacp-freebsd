#!/bin/bash
# info: list web templates
# options: [FORMAT]
#
# example: v-list-web-templates
#
# This function for obtaining the list of web templates available to a user.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	objects=$(echo "$templates" | wc -w)
	i=1
	echo '['
	for template in $templates; do
		if [ "$i" -lt "$objects" ]; then
			printf '    "%s",\n' "$template"
		else
			printf '    "%s"\n' "$template"
		fi
		i=$((i + 1))
	done
	echo ']'
}

# SHELL list function
shell_list() {
	echo "TEMPLATE"
	echo "--------"
	for template in $templates; do
		echo "$template"
	done
}

# PLAIN list function
plain_list() {
	for template in $templates; do
		echo "$template"
	done
}

# CSV list function
csv_list() {
	echo "TEMPLATE"
	for template in $templates; do
		echo "$template"
	done
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing templates
tpl_path="$WEBTPL/$WEB_SYSTEM/$WEB_BACKEND/"

if [ -d "$tpl_path" ]; then
	templates=$(ls -v "$tpl_path" | grep '\.tpl' | sed 's/\.tpl$//')
else
	templates=""
fi

if [ -z "$templates" ]; then
	case $format in
		json) echo "[]" ;;
		shell) echo "No templates found" ;;
		plain) ;;
		csv) echo "TEMPLATE" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
