#!/bin/bash
# info: list users
# options: [FORMAT]
#
# example: v-list-users
#
# This function to obtain the list of all system users.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# Argument definition
format=${1:-shell}

# JSON list function
json_list() {
	echo '{'
	first=1
	while read -r USER; do
		if [ ! -f "$HESTIA/data/users/$USER/user.conf" ]; then
			continue
		fi
		if [ $first -eq 1 ]; then
			first=0
		else
			echo ","
		fi
		source_conf "$HESTIA/data/users/$USER/user.conf"
		echo -n "    \"$USER\": {"
		echo -n "\"NAME\": \"$NAME\", "
		echo -n "\"PACKAGE\": \"$PACKAGE\", "
		echo -n "\"WEB_TEMPLATE\": \"$WEB_TEMPLATE\", "
		echo -n "\"BACKEND_TEMPLATE\": \"$BACKEND_TEMPLATE\", "
		echo -n "\"PROXY_TEMPLATE\": \"$PROXY_TEMPLATE\", "
		echo -n "\"DNS_TEMPLATE\": \"$DNS_TEMPLATE\", "
		echo -n "\"WEB_DOMAINS\": \"$WEB_DOMAINS\", "
		echo -n "\"WEB_ALIASES\": \"$WEB_ALIASES\", "
		echo -n "\"DNS_DOMAINS\": \"$DNS_DOMAINS\", "
		echo -n "\"DNS_RECORDS\": \"$DNS_RECORDS\", "
		echo -n "\"MAIL_DOMAINS\": \"$MAIL_DOMAINS\", "
		echo -n "\"MAIL_ACCOUNTS\": \"$MAIL_ACCOUNTS\", "
		echo -n "\"DATABASES\": \"$DATABASES\", "
		echo -n "\"CRON_JOBS\": \"$CRON_JOBS\", "
		echo -n "\"DISK_QUOTA\": \"$DISK_QUOTA\", "
		echo -n "\"CPU_QUOTA\": \"$CPU_QUOTA\", "
		echo -n "\"CPU_QUOTA_PERIOD\": \"$CPU_QUOTA_PERIOD\", "
		echo -n "\"MEMORY_LIMIT\": \"$MEMORY_LIMIT\", "
		echo -n "\"SWAP_LIMIT\": \"$SWAP_LIMIT\", "
		echo -n "\"BANDWIDTH\": \"$BANDWIDTH\", "
		echo -n "\"NS\": \"$NS\", "
		echo -n "\"SHELL\": \"$SHELL\", "
		echo -n "\"BACKUPS\": \"$BACKUPS\", "
		echo -n "\"CONTACT\": \"$CONTACT\", "
		echo -n "\"CRON_REPORTS\": \"$CRON_REPORTS\", "
		echo -n "\"RKEY\": \"$RKEY\", "
		echo -n "\"ROLE\": \"$ROLE\", "
		echo -n "\"SUSPENDED\": \"$SUSPENDED\", "
		echo -n "\"SUSPENDED_USERS\": \"$SUSPENDED_USERS\", "
		echo -n "\"SUSPENDED_WEB\": \"$SUSPENDED_WEB\", "
		echo -n "\"SUSPENDED_DNS\": \"$SUSPENDED_DNS\", "
		echo -n "\"SUSPENDED_MAIL\": \"$SUSPENDED_MAIL\", "
		echo -n "\"SUSPENDED_DB\": \"$SUSPENDED_DB\", "
		echo -n "\"SUSPENDED_CRON\": \"$SUSPENDED_CRON\", "
		echo -n "\"IP_AVAIL\": \"$IP_AVAIL\", "
		echo -n "\"IP_OWNED\": \"$IP_OWNED\", "
		echo -n "\"U_USERS\": \"$U_USERS\", "
		echo -n "\"U_DISK\": \"$U_DISK\", "
		echo -n "\"U_DISK_DIRS\": \"$U_DISK_DIRS\", "
		echo -n "\"U_DISK_WEB\": \"$U_DISK_WEB\", "
		echo -n "\"U_DISK_MAIL\": \"$U_DISK_MAIL\", "
		echo -n "\"U_DISK_DB\": \"$U_DISK_DB\", "
		echo -n "\"U_BANDWIDTH\": \"$U_BANDWIDTH\", "
		echo -n "\"U_WEB_DOMAINS\": \"$U_WEB_DOMAINS\", "
		echo -n "\"U_WEB_SSL\": \"$U_WEB_SSL\", "
		echo -n "\"U_WEB_ALIASES\": \"$U_WEB_ALIASES\", "
		echo -n "\"U_DNS_DOMAINS\": \"$U_DNS_DOMAINS\", "
		echo -n "\"U_DNS_RECORDS\": \"$U_DNS_RECORDS\", "
		echo -n "\"U_MAIL_DOMAINS\": \"$U_MAIL_DOMAINS\", "
		echo -n "\"U_MAIL_DKIM\": \"$U_MAIL_DKIM\", "
		echo -n "\"U_MAIL_ACCOUNTS\": \"$U_MAIL_ACCOUNTS\", "
		echo -n "\"U_DATABASES\": \"$U_DATABASES\", "
		echo -n "\"U_CRON_JOBS\": \"$U_CRON_JOBS\", "
		echo -n "\"U_BACKUPS\": \"$U_BACKUPS\", "
		echo -n "\"LANGUAGE\": \"$LANGUAGE\", "
		echo "\"TIME\": \"$TIME\", \"DATE\": \"$DATE\"}"
	done < <(grep '@' /etc/passwd | cut -f1 -d:)
	echo
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-12s %-8s %-8s %-6s %-6s %-6s %-5s %-8s %-8s %-6s %-12s\n" "USER" "ROLE" "PKG" "WEB" "DNS" "MAIL" "DB" "DISK" "BW" "SPND" "DATE"
	printf "%-12s %-8s %-8s %-6s %-6s %-6s %-5s %-8s %-8s %-6s %-12s\n" "----" "----" "---" "---" "---" "----" "--" "----" "--" "----" "----"
	while read -r USER; do
		if [ ! -f "$HESTIA/data/users/$USER/user.conf" ]; then
			continue
		fi
		source_conf "$HESTIA/data/users/$USER/user.conf"
		printf "%-12s %-8s %-8s %-6s %-6s %-6s %-5s %-8s %-8s %-6s %-12s\n" \
			"$USER" "$ROLE" "$PACKAGE" "$U_WEB_DOMAINS" "$U_DNS_DOMAINS" \
			"$U_MAIL_DOMAINS" "$U_DATABASES" "$U_DISK" "$U_BANDWIDTH" "$SUSPENDED" "$DATE"
	done < <(grep '@' /etc/passwd | cut -f1 -d:)
}

# PLAIN list function
plain_list() {
	while read -r USER; do
		if [ ! -f "$HESTIA/data/users/$USER/user.conf" ]; then
			continue
		fi
		source_conf "$HESTIA/data/users/$USER/user.conf"
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$USER" "$NAME" "$PACKAGE" "$WEB_TEMPLATE" "$BACKEND_TEMPLATE" \
			"$PROXY_TEMPLATE" "$DNS_TEMPLATE" "$WEB_DOMAINS" "$WEB_ALIASES" \
			"$DNS_DOMAINS" "$DNS_RECORDS" "$MAIL_DOMAINS" "$MAIL_ACCOUNTS" \
			"$DATABASES" "$CRON_JOBS" "$DISK_QUOTA" "$CPU_QUOTA" "$CPU_QUOTA_PERIOD" \
			"$MEMORY_LIMIT" "$SWAP_LIMIT" "$BANDWIDTH" "$NS" "$SHELL" "$BACKUPS" \
			"$CONTACT" "$CRON_REPORTS" "$RKEY" "$ROLE" "$SUSPENDED" \
			"$SUSPENDED_USERS" "$SUSPENDED_WEB" "$SUSPENDED_DNS" "$SUSPENDED_MAIL" \
			"$SUSPENDED_DB" "$SUSPENDED_CRON" "$IP_AVAIL" "$IP_OWNED" "$U_USERS" \
			"$U_DISK" "$U_DISK_DIRS" "$U_DISK_WEB" "$U_DISK_MAIL" "$U_DISK_DB" \
			"$U_BANDWIDTH" "$U_WEB_DOMAINS" "$U_WEB_SSL" "$U_WEB_ALIASES" \
			"$U_DNS_DOMAINS" "$U_DNS_RECORDS" "$U_MAIL_DOMAINS" "$U_MAIL_DKIM" \
			"$U_MAIL_ACCOUNTS" "$U_DATABASES" "$U_CRON_JOBS" "$U_BACKUPS" \
			"$LANGUAGE" "$TIME" "$DATE"
	done < <(grep '@' /etc/passwd | cut -f1 -d:)
}

# CSV list function
csv_list() {
	echo "USER,NAME,PACKAGE,WEB_TEMPLATE,BACKEND_TEMPLATE,PROXY_TEMPLATE,DNS_TEMPLATE,WEB_DOMAINS,WEB_ALIASES,DNS_DOMAINS,DNS_RECORDS,MAIL_DOMAINS,MAIL_ACCOUNTS,DATABASES,CRON_JOBS,DISK_QUOTA,CPU_QUOTA,CPU_QUOTA_PERIOD,MEMORY_LIMIT,SWAP_LIMIT,BANDWIDTH,NS,HOME,SHELL,BACKUPS,CONTACT,CRON_REPORTS,RKEY,ROLE,SUSPENDED,SUSPENDED_USERS,SUSPENDED_WEB,SUSPENDED_DNS,SUSPENDED_MAIL,SUSPENDED_DB,SUSPENDED_CRON,IP_AVAIL,IP_OWNED,U_USERS,U_DISK,U_DISK_DIRS,U_DISK_WEB,U_DISK_MAIL,U_DISK_DB,U_BANDWIDTH,U_WEB_DOMAINS,U_WEB_SSL,U_WEB_ALIASES,U_DNS_DOMAINS,U_DNS_RECORDS,U_MAIL_DOMAINS,U_MAIL_DKIM,U_MAIL_ACCOUNTS,U_DATABASES,U_CRON_JOBS,U_BACKUPS,LANGUAGE,TIME,DATE"
	while read -r USER; do
		if [ ! -f "$HESTIA/data/users/$USER/user.conf" ]; then
			continue
		fi
		source_conf "$HESTIA/data/users/$USER/user.conf"
		echo "$USER,\"$NAME\",$PACKAGE,$WEB_TEMPLATE,$BACKEND_TEMPLATE,$PROXY_TEMPLATE,$DNS_TEMPLATE,$WEB_DOMAINS,$WEB_ALIASES,$DNS_DOMAINS,$DNS_RECORDS,$MAIL_DOMAINS,$MAIL_ACCOUNTS,$DATABASES,$CRON_JOBS,$DISK_QUOTA,$CPU_QUOTA,$CPU_QUOTA_PERIOD,$MEMORY_LIMIT,$SWAP_LIMIT,$BANDWIDTH,\"$NS\",$HOME,$SHELL,$BACKUPS,$CONTACT,$CRON_REPORTS,\"$RKEY\",$ROLE,$SUSPENDED,$SUSPENDED_USERS,$SUSPENDED_WEB,$SUSPENDED_DNS,$SUSPENDED_MAIL,$SUSPENDED_DB,$SUSPENDED_CRON,$IP_AVAIL,$IP_OWNED,$U_USERS,$U_DISK,$U_DISK_DIRS,$U_DISK_WEB,$U_DISK_MAIL,$U_DISK_DB,$U_BANDWIDTH,$U_WEB_DOMAINS,$U_WEB_SSL,$U_WEB_ALIASES,$U_DNS_DOMAINS,$U_DNS_RECORDS,$U_MAIL_DOMAINS,$U_MAIL_DKIM,$U_MAIL_ACCOUNTS,$U_DATABASES,$U_CRON_JOBS,$U_BACKUPS,$LANGUAGE,$TIME,$DATE"
	done < <(grep '@' /etc/passwd | cut -f1 -d:)
}

# USER ONLY list function
only_user_list() {
	while read -r USER; do
		if [ ! -f "$HESTIA/data/users/$USER/user.conf" ]; then
			continue
		fi
		echo "$USER"
	done < <(grep '@' /etc/passwd | cut -f1 -d:)
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
	list) only_user_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
