#!/bin/sh
# info: delete restart job
# options: NONE
#
# This function for disabling restart cron tasks

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

is_system_enabled "$CRON_SYSTEM" 'CRON_SYSTEM'

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Add cron job
cmd="v-update-sys-queue restart"
check_cron=$(grep "$cmd" "/var/cron/tabs/hestiaweb" 2>/dev/null)
if [ -n "$check_cron" ]; then
    sed -i "" "/v-update-sys-queue restart/d" "/var/cron/tabs/hestiaweb"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
log_event "$OK" "$ARGUMENTS"

exit 0
