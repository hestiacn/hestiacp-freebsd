#!/bin/sh
# info: delete system quota
# options: NONE
#
# example: v-delete-sys-quota
#
# This function disables filesystem quota on /home partition

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# Function to safely remove quota options from fstab
remove_quota_options() {
    local line_num="$1"
    local options="$2"
    local pattern="$3"

    # Remove quota-related options
    local new_options
    new_options=$(echo "$options" | tr ',' '\n' | grep -v -E "$pattern" | tr '\n' ',' | sed 's/,$//')

    # Handle case where all options are removed
    if [ -z "$new_options" ]; then
        new_options="defaults"
    fi

    # Escape special characters for sed
    local escaped_old
    local escaped_new
    escaped_old=$(printf '%s\n' "$options" | sed 's/[[\.*^$/]/\\&/g')
    escaped_new=$(printf '%s\n' "$new_options" | sed 's/[[\.*^$/]/\\&/g')

    # FreeBSD sed requires -i ""
    sed -i "" "${line_num}s/${escaped_old}/${escaped_new}/" /etc/fstab
}

# Function to disable quota if active (FreeBSD)
disable_quota() {
    local mount_point="$1"
    
    if command -v quotaoff > /dev/null 2>&1; then
        quotaoff -a 2>/dev/null
    fi
}

# Function to remove quota index files (FreeBSD UFS)
remove_quota_files() {
    local mount_point="$1"
    
    # FreeBSD UFS quota files
    if [ -f "$mount_point/quota.user" ]; then
        rm -f "$mount_point/quota.user"
    fi
    if [ -f "$mount_point/quota.group" ]; then
        rm -f "$mount_point/quota.group"
    fi
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

log_history "INFO" "Starting quota removal process"

# Deleting group and user quota on /home partition
mnt=$(df -P /home 2>/dev/null | awk 'NR==2 {print $6}')

# Verify mount point exists
if [ -z "$mnt" ]; then
    log_history "ERROR" "Could not determine mount point for /home"
    exit "$E_NOTEXIST"
fi

log_history "INFO" "Mount point detected: $mnt"

# Find the line in fstab (excluding comments)
lnr=$(awk -v mnt="$mnt" '$1 !~ /^#/ && $2 == mnt {print NR; exit}' /etc/fstab)

# Verify line number was found
if [ -z "$lnr" ]; then
    log_history "WARNING" "Mount point $mnt not found in /etc/fstab"
else
    # Read fstab line details
    read -r _ _ fstype opt _ _ < <(sed -n "${lnr}p" /etc/fstab)

    log_history "INFO" "Filesystem type: $fstype, Current options: $opt"

    case "$fstype" in
        ufs)
            quota_pattern='userquota|groupquota'

            if echo "$opt" | grep -qE "$quota_pattern"; then
                log_history "INFO" "Removing UFS quota options from fstab"
                remove_quota_options "$lnr" "$opt" "$quota_pattern"
            fi

            mount -o remount "$mnt" 2>/dev/null

            # Disabling quota
            disable_quota "$mnt"

            # Remove quota files
            remove_quota_files "$mnt"
            ;;

        zfs)
            if zfs get quota "$mnt" 2>/dev/null | grep -q "LOCAL"; then
                log_history "INFO" "Removing ZFS quota on $mnt"
                zfs set quota=none "$mnt" 2>/dev/null
            fi
            if zfs get userquota@ "$mnt" 2>/dev/null | grep -q "LOCAL"; then
                log_history "INFO" "Removing ZFS userquota on $mnt"
                zfs set userquota@=none "$mnt" 2>/dev/null
            fi
            if zfs get groupquota@ "$mnt" 2>/dev/null | grep -q "LOCAL"; then
                log_history "INFO" "Removing ZFS groupquota on $mnt"
                zfs set groupquota@=none "$mnt" 2>/dev/null
            fi
            ;;

        *)
            log_history "WARNING" "Unsupported or undetected filesystem type: $fstype"
            ;;
    esac
fi

# Remove cron job and quotacheck
log_history "INFO" "Cleaning up quota-related files"
if [ -f "/etc/periodic/quotacheck" ]; then
    rm -f "/etc/periodic/quotacheck"
fi

sysrc quota_enable="NO" > /dev/null 2>&1
sysrc check_quotas="NO" > /dev/null 2>&1

# Update hestia.conf value
log_history "INFO" "Updating Hestia configuration"
"$BIN/v-change-sys-config-value" "DISK_QUOTA" "no"

# Remove quota package
if pkg info quota 2>/dev/null | grep -q "quota"; then
    log_history "INFO" "Removing quota package"
    pkg delete -y quota > /dev/null 2>&1
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
"$BIN/v-log-action" "system" "Info" "Plugins" "System Quota Enforcement disabled."
log_event "$OK" "$ARGUMENTS"

log_history "INFO" "Quota removal completed successfully"

exit 0
