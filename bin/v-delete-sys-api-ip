#!/bin/sh
# info: delete ip adresss from allowed ip list api
# options: IP
#
# example: v-delete-sys-api-ip 1.1.1.1

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

ip46=${1// /}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# shellcheck source=/usr/local/hestia/func/ip.sh
source $HESTIA/func/ip.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'IP'
is_format_valid 'ip46'

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

new_list=''
set -f # avoid globbing (expansion of *).
OLD_IFS="$IFS"
IFS=',
'
for ip in $API_ALLOWED_IP; do
    if [ "$ip" != "$ip46" ]; then
        if [ -z "$new_list" ]; then
            new_list="$ip"
        else
            new_list="$new_list,$ip"
        fi
    fi
done
IFS="$OLD_IFS"
set +f

$BIN/v-change-sys-config-value 'API_ALLOWED_IP' "$new_list"

# Logging
$BIN/v-log-action "system" "Warning" "System" "Removed IP address added from Allowed IP API (IP: $ip46)"
log_event "$OK" "$ARGUMENTS"

exit 0
