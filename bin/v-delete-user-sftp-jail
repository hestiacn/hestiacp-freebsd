#!/bin/sh
# info: delete user sftp jail
# options: USER
#
# example: v-delete-user-sftp-jail whistler
#
# This function disables sftp jailed environment for USER

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER'
is_format_valid 'user'
user_str=$(grep "^$user:" /etc/passwd)
if [ -z "$user_str" ]; then
    exit 0
fi

# Get current users
config='/etc/ssh/sshd_config'
match_line=$(grep -n "^# Hestia SFTP Chroot" "$config")
if [ -z "$match_line" ]; then
    exit 0
fi

# Get the Match User line
match_line_num=$(echo "$match_line" | cut -d: -f1)
match_user_line=$((match_line_num + 1))
ssh_users=$(sed -n "${match_user_line}p" "$config" | sed 's/Match User //' | tr -d ' ')

# Check if user is in the list
found=0
OLD_IFS="$IFS"
IFS=','
for u in $ssh_users; do
    if [ "$u" = "$user" ]; then
        found=1
        break
    fi
done
IFS="$OLD_IFS"

if [ "$found" -eq 0 ]; then
    exit 0
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Remove user from list
new_users=""
OLD_IFS="$IFS"
IFS=','
for u in $ssh_users; do
    if [ "$u" != "$user" ]; then
        if [ -z "$new_users" ]; then
            new_users="$u"
        else
            new_users="$new_users,$u"
        fi
    fi
done
IFS="$OLD_IFS"
if [ -z "$new_users" ]; then
    end_line=$((match_line_num + 3))
    sed -i "" "${match_line_num},${end_line}d" "$config"
else
    sed -i "" "${match_user_line}s/.*/Match User ${new_users}/" "$config"
fi

# chown permissions back to user:user
if [ -d "/home/$user" ]; then
    chown -h "$user":"$user" "/home/$user"
fi

# Deleting chroot jail for SFTP and FTP
delete_chroot_jail "$user"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Restart ssh service
service sshd restart > /dev/null 2>&1

# Logging
log_event "$OK" "$ARGUMENTS"

exit 0
