#!/bin/sh
# info: list dns templates
# options: [FORMAT]
#
# example: v-list-dns-templates json
#
# This function for obtaining the list of all DNS templates available.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(echo "$templates" | wc -w | tr -d ' ')
	echo "["
	for template in $templates; do
		if [ "$i" -lt "$objects" ]; then
			echo "    \"$template\","
		else
			echo "    \"$template\""
		fi
		i=$((i + 1))
	done
	echo "]"
}

# SHELL list function
shell_list() {
	echo "TEMPLATE"
	echo "--------"
	if [ -d "$DNSTPL" ]; then
		ls -t "$DNSTPL" 2>/dev/null | grep '\.tpl$' | sed 's/\.tpl$//'
	fi
}

# PLAIN list function
plain_list() {
	for template in $templates; do
		echo "$template"
	done
}

# CSV list function
csv_list() {
	echo "TEMPLATE"
	for template in $templates; do
		echo "$template"
	done
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#
if [ ! -d "$DNSTPL" ]; then
	exit 0
fi
templates=$(ls -t "$DNSTPL" 2>/dev/null | grep '\.tpl$' | sed 's/\.tpl$//' | tr '\n' ' ' | sed 's/ $//')
if [ -z "$templates" ]; then
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
