#!/bin/sh
# info: check user password
# options: USER PASSWORD [IP] [RETURN_HASH]
#
# example: v-check-user-password admin qwerty1234
#
# This function verifies user password from file

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
password=$2
HIDE=2
ip46=${3-127.0.0.1}
return_hash=$4

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

time_n_date=$(date +'%H:%M:%S %Y-%m-%d')
time=$(echo "$time_n_date" | cut -f 1 -d \ )
date=$(echo "$time_n_date" | cut -f 2 -d \ )

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER PASSWORD [IP] [RETURN_HASH]'
is_format_valid 'user' 'ip46'

# Checking user
if [ ! -d "$HESTIA/data/users/$user" ]; then
    echo "Error: password missmatch"
    echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
    exit 9
fi

is_password_valid

# Checking empty password
if [ -z "$password" ]; then
    echo "Error: password missmatch"
    echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
    exit 9
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing user's salt
shadow=$(grep "^$user:" /etc/master.passwd | cut -f 2 -d :)

if echo "$shadow" | grep -qE '^\$[0-9a-z]+\$[^\$]+\$'; then
    salt=$(echo "$shadow" | cut -f 3 -d \$)
    method=$(echo "$shadow" | cut -f 2 -d \$)
    if [ "$method" = "y" ]; then
        method="yescrypt"
    elif [ "$method" = "1" ]; then
        method='md5'
    elif [ "$method" = "6" ]; then
        method='sha-512'
    else
        echo "Error: password missmatch"
        echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
        exit 9
    fi
else
    salt=${shadow:0:2}
    method='des'
fi

if [ -z "$salt" ]; then
    echo "Error: password missmatch"
    echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
    exit 9
fi

if [ "$method" = "yescrypt" ]; then
    if ! command -v v-crypt > /dev/null 2>&1; then
        echo "Error: v-crypt not available"
        echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
        exit 9
    fi
    
    if ! v-crypt "$password" "$shadow" > /dev/null 2>&1; then
        echo "Error: password missmatch"
        echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
        exit 9
    fi
    hash="$shadow"
else
    # Generating hash
    set -o noglob
    hash=$(echo "$password" | $BIN/v-generate-password-hash "$method" "$salt")
    if [ -z "$hash" ]; then
        echo "Error: password missmatch"
        if [ -z "$return_hash" ]; then
            echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
        fi
        exit 9
    fi
fi

# Checking hash
result=$(grep "^$user:$hash:" /etc/master.passwd 2>/dev/null)
if [ -z "$result" ]; then
    echo "Error: password missmatch"
    if [ -z "$return_hash" ]; then
        echo "$date $time $user $ip46 failed to login" >> $HESTIA/log/auth.log
    fi
    exit 9
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

if [ -n "$return_hash" ]; then
    echo "$hash"
else
    echo "$date $time $user $ip46 successfully logged in" >> $HESTIA/log/auth.log
fi

exit 0