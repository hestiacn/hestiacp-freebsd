#!/bin/bash
# info: list files in latest restic snapshot
# options: USER [FOLDER] [FORMAT]
#
# example: v-list-user-files-restic admin /home/user/web
#
# This function lists files in the latest restic snapshot.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
folder=${2:-/}
format=${3:-plain}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# shellcheck source=/usr/local/hestia/func/domain.sh
source "$HESTIA/func/domain.sh"
# shellcheck source=/usr/local/hestia/func/db.sh
source "$HESTIA/func/db.sh"
# shellcheck source=/usr/local/hestia/func/backup.sh
source "$HESTIA/func/backup.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FOLDER]'
is_format_valid 'user'
is_system_enabled "$BACKUP_SYSTEM" 'BACKUP_SYSTEM'
is_object_valid 'user' 'USER' "$user"
is_object_unsuspended 'user' 'USER' "$user"

# Check restic configuration
if [ ! -f "$HESTIA/conf/restic.conf" ]; then
	echo "Error: restic configuration not found at $HESTIA/conf/restic.conf"
	exit 1
fi

if [ ! -f "$USER_DATA/restic.conf" ]; then
	echo "Error: restic password file not found for user $user"
	exit 1
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

source_conf "$HESTIA/conf/restic.conf"

# Get the latest snapshot ID
snapshot=$(restic --repo "$REPO$user" --password-file "$USER_DATA/restic.conf" \
	snapshots --json 2>/dev/null | grep -o '"short_id":"[^"]*"' | head -1 | cut -d'"' -f4)

if [ -z "$snapshot" ]; then
	echo "Error: No snapshots found for user $user"
	exit 1
fi

# List files in snapshot
case $format in
	json)
		restic --repo "$REPO$user" --password-file "$USER_DATA/restic.conf" \
			--json ls "$snapshot" "$folder"
		;;
	plain)
		restic --repo "$REPO$user" --password-file "$USER_DATA/restic.conf" \
			ls "$snapshot" "$folder"
		;;
	*)
		restic --repo "$REPO$user" --password-file "$USER_DATA/restic.conf" \
			ls "$snapshot" "$folder"
		;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
