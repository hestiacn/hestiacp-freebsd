#!/bin/bash
# info: list web domains
# options: USER [FORMAT]
#
# example: v-list-web-domains alice
#
# This function to obtain the list of all user web domains.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
format=${2:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "DOMAIN" "$USER_DATA/web.conf")
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		# Set correct document root path
		if [ -n "$CUSTOM_DOCROOT" ]; then
			DOCROOT="$CUSTOM_DOCROOT"
		else
			DOCROOT="$HOMEDIR/$user/web/$DOMAIN/public_html/"
		fi
		echo -n "    \"$DOMAIN\": {"
		echo -n "\"IP\": \"$IP\", "
		echo -n "\"IP6\": \"$IP6\", "
		echo -n "\"DOCUMENT_ROOT\": \"$DOCROOT\", "
		echo -n "\"U_DISK\": \"$U_DISK\", "
		echo -n "\"U_BANDWIDTH\": \"$U_BANDWIDTH\", "
		echo -n "\"TPL\": \"$TPL\", "
		echo -n "\"ALIAS\": \"$ALIAS\", "
		echo -n "\"STATS\": \"$STATS\", "
		echo -n "\"STATS_USER\": \"$STATS_USER\", "
		echo -n "\"SSL\": \"$SSL\", "
		echo -n "\"SSL_HOME\": \"$SSL_HOME\", "
		echo -n "\"LETSENCRYPT\": \"$LETSENCRYPT\", "
		echo -n "\"FTP_USER\": \"$FTP_USER\", "
		echo -n "\"FTP_PATH\": \"$FTP_PATH\", "
		echo -n "\"AUTH_USER\": \"$AUTH_USER\", "
		echo -n "\"BACKEND\": \"$BACKEND\", "
		echo -n "\"PROXY\": \"$PROXY\", "
		echo -n "\"PROXY_EXT\": \"$PROXY_EXT\", "
		echo -n "\"SUSPENDED\": \"$SUSPENDED\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$USER_DATA/web.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-20s %-15s %-8s %-6s %-8s %-6s %-6s %-12s\n" \
		"DOMAIN" "IP" "TPL" "SSL" "DISK" "BW" "SPND" "DATE"
	printf "%-20s %-15s %-8s %-6s %-8s %-6s %-6s %-12s\n" \
		"------" "--" "---" "---" "----" "--" "----" "-----"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%-20s %-15s %-8s %-6s %-8s %-6s %-6s %-12s\n" \
			"$DOMAIN" "$IP" "$TPL" "$SSL" "$U_DISK" "$U_BANDWIDTH" "$SUSPENDED" "$DATE"
	done < "$USER_DATA/web.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		# Set correct document root path
		if [ -n "$CUSTOM_DOCROOT" ]; then
			DOCROOT="$CUSTOM_DOCROOT"
		else
			DOCROOT="$HOMEDIR/$user/web/$DOMAIN/public_html/"
		fi
		printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
			"$DOMAIN" "$IP" "$IP6" "$DOCROOT" "$U_DISK" "$U_BANDWIDTH" "$TPL" \
			"$ALIAS" "$STATS" "$STATS_USER" "$SSL" "$SSL_HOME" "$LETSENCRYPT" \
			"$FTP_USER" "$FTP_PATH" "$AUTH_USER" "$BACKEND" "$PROXY" \
			"$PROXY_EXT" "$SUSPENDED" "$TIME" "$DATE"
	done < "$USER_DATA/web.conf"
}

# CSV list function
csv_list() {
	echo "DOMAIN,IP,IP6,DOCROOT,U_DISK,U_BANDWIDTH,TPL,ALIAS,STATS,STATS_USER,SSL,SSL_HOME,LETSENCRYPT,FTP_USER,FTP_PATH,AUTH_USER,BACKEND,PROXY,PROXY_EXT,SUSPENDED,TIME,DATE"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		# Set correct document root path
		if [ -n "$CUSTOM_DOCROOT" ]; then
			DOCROOT="$CUSTOM_DOCROOT"
		else
			DOCROOT="$HOMEDIR/$user/web/$DOMAIN/public_html/"
		fi
		echo "$DOMAIN,$IP,$IP6,$DOCROOT,$U_DISK,$U_BANDWIDTH,$TPL,\"$ALIAS\",$STATS,\"$STATS_USER\",$SSL,$SSL_HOME,$LETSENCRYPT,\"$FTP_USER\",\"$FTP_PATH\",\"$AUTH_USER\",$BACKEND,$PROXY,\"$PROXY_EXT\",$SUSPENDED,$TIME,$DATE"
	done < "$USER_DATA/web.conf"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

unset docroot

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
