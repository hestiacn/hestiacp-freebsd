#!/bin/sh
# info: add firewall blocking rule
# options: IPV4_CIDR CHAIN
#
# example: v-add-firewall-ban 37.120.129.20 MAIL
#
# This function adds new blocking rule to system firewall

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
ipv4_cidr=$1
chain=$(echo "$2" | tr '[:lower:]' '[:upper:]')

# FreeBSD: firewall commands
if [ "$FIREWALL_SYSTEM" = "pf" ]; then
    pfctl="/sbin/pfctl"
elif [ "$FIREWALL_SYSTEM" = "ipfw" ]; then
    ipfw="/sbin/ipfw"
fi

# Includes
source /usr/local/etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# shellcheck source=/usr/local/hestia/func/firewall.sh
source $HESTIA/func/firewall.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'IPV4_CIDR CHAIN'
is_format_valid 'ipv4_cidr' 'chain'
is_system_enabled "$FIREWALL_SYSTEM" 'FIREWALL_SYSTEM'

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Checking server ip
if [ -e "$HESTIA/data/ips/$ipv4_cidr" ] || [ "$ipv4_cidr" = '127.0.0.1' ]; then
    exit 0
fi

# Checking ip exclusions
excludes="$HESTIA/data/firewall/excludes.conf"
check_excludes=$(grep "^$ipv4_cidr$" "$excludes" 2>/dev/null)
if [ -n "$check_excludes" ]; then
    exit 0
fi

# Checking ip in banlist
conf="$HESTIA/data/firewall/banlist.conf"
check_ip=$(grep "IP='$ipv4_cidr' CHAIN='$chain'" "$conf" 2>/dev/null)
if [ -n "$check_ip" ]; then
    exit 0
fi

# Adding chain
$BIN/v-add-firewall-chain "$chain"

# Generating timestamp
time_n_date=$(date +'%H:%M:%S %Y-%m-%d')
time=$(echo "$time_n_date" | cut -f 1 -d \ )
date=$(echo "$time_n_date" | cut -f 2 -d \ )

# Adding ip to banlist
echo "IP='$ipv4_cidr' CHAIN='$chain' TIME='$time' DATE='$date'" >> "$conf"
chain_lower=$(echo "$chain" | tr '[:upper:]' '[:lower:]')
if [ "$FIREWALL_SYSTEM" = "pf" ]; then
    $pfctl -t "fail2ban-$chain_lower" -T add "$ipv4_cidr" > /dev/null 2>&1
elif [ "$FIREWALL_SYSTEM" = "ipfw" ]; then
    $ipfw table "fail2ban-$chain_lower" add "$ipv4_cidr" 2>/dev/null
fi

# Changing permissions
chmod 660 "$conf"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/v-log-action "system" "Warning" "Firewall" "Banned IP address $ipv4_cidr."
log_event "$OK" "$ARGUMENTS"

exit 0