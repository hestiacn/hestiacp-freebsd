#!/bin/sh
# info: list firewall block list
# options: [FORMAT]
#
# example: v-list-firewall-ban json
#
# This function of obtaining the list of currently blocked ips.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	i=1
	objects=$(grep -c "IP" "$HESTIA/data/firewall/banlist.conf")
	echo "{"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo -n "    \"$IP\": {"
		echo -n "\"IP\": \"$IP\", "
		echo -n "\"CHAIN\": \"$CHAIN\", "
		echo -n "\"TIME\": \"$TIME\", "
		echo "\"DATE\": \"$DATE\"}"
		if [ "$i" -lt "$objects" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done < "$HESTIA/data/firewall/banlist.conf"
	echo "}"
}

# SHELL list function
shell_list() {
	printf "%-15s %-10s %-10s %-12s\n" "IP" "CHAIN" "TIME" "DATE"
	printf "%-15s %-10s %-10s %-12s\n" "--" "-----" "----" "----"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%-15s %-10s %-10s %-12s\n" \
			"$IP" "$CHAIN" "$TIME" "$DATE"
	done < "$HESTIA/data/firewall/banlist.conf"
}

# PLAIN list function
plain_list() {
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		printf "%s\t%s\t%s\t%s\n" \
			"$IP" "$CHAIN" "$TIME" "$DATE"
	done < "$HESTIA/data/firewall/banlist.conf"
}

# CSV list function
csv_list() {
	echo "IP,CHAIN,TIME,DATE"
	while read -r str; do
		[ -z "$str" ] && continue
		parse_object_kv_list "$str"
		echo "$IP,$CHAIN,$TIME,$DATE"
	done < "$HESTIA/data/firewall/banlist.conf"
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ ! -f "$HESTIA/data/firewall/banlist.conf" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No blocked IPs found" ;;
		plain) ;;
		csv) echo "IP,CHAIN,TIME,DATE" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
