#!/bin/bash
# info: update system firewall rules for FreeBSD PF
# options: NONE
#
# example: v-update-firewall
#
# This function compiles and updates FreeBSD PF firewall rules

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

pfctl="/sbin/pfctl"
sysctl="/sbin/sysctl"

# Includes
source /etc/profile.d/hestia.sh 2>/dev/null || true
source /usr/local/etc/hestiacp/hestia.conf
source "$HESTIA/func/main.sh"
source "$HESTIA/func/firewall.sh" 2>/dev/null || true
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

is_system_enabled "$FIREWALL_SYSTEM" 'FIREWALL_SYSTEM'

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# 开启 PF 服务（开机自愈初始化）
sysrc pf_enable="YES" > /dev/null 2>&1
sysrc pf_rules="/etc/pf.conf" > /dev/null 2>&1
sysrc pflog_enable="YES" > /dev/null 2>&1
sysrc pflog_logfile="/var/log/pflog" > /dev/null 2>&1

# 规则文件
rules="$HESTIA/data/firewall/rules.conf"
if [ ! -e "$rules" ]; then
    exit
fi

chains="$HESTIA/data/firewall/chains.conf"
banlist="$HESTIA/data/firewall/banlist.conf"

# 检查自定义 SSH 端口
sshport="$($BIN/v-list-sys-sshd-port plain | sed ':a;N;$!ba;s/\n/,/g')"
if echo "$sshport" | grep -E '^[0-9]+(,[0-9]+)*$' > /dev/null 2>&1; then
    sed -i '' -E "s/(PORT=')[0-9]+(,[0-9]+)*('.*COMMENT='SSH')/\1$sshport\3/" "$rules"
    if [ -f "$chains" ]; then
        sed -i '' "/CHAIN='SSH'/c\CHAIN='SSH' PORT='$sshport' PROTOCOL='TCP'" "$chains"
    else
        "$BIN/v-add-firewall-chain" 'SSH' "$sshport" 'TCP'
    fi
fi

# 加载 ipset 列表
"$BIN/v-update-firewall-ipset" load 2>/dev/null || true

# 创建临时文件
pf_tmp="$(mktemp -t hst_pf)"

# =========================================================================
# 生成 FreeBSD PF 防火墙配置
# =========================================================================

cat << 'EOF' > "$pf_tmp"
# =========================================================================
# FreeBSD PF (Packet Filter) Firewall Configuration
# Generated automatically by HestiaCP FreeBSD Edition
# =========================================================================

# 1. 全局宏与基础放行接口
set skip on lo0
scrub in all

# 2. 动态申明 Fail2ban 隔离表
EOF

# 添加 Fail2ban 表
if [ -f "$chains" ]; then
    for chain_line in $(cat "$chains"); do
        parse_object_kv_list "$chain_line"
        c_name=$(echo "$CHAIN" | tr '[:upper:]' '[:lower:]')
        echo "table <fail2ban-${c_name}> persist" >> "$pf_tmp"
    done
fi

# 添加 ipset 表
if [ -d "$HESTIA/data/firewall/ipset" ]; then
    for ipset_file in $(ls $HESTIA/data/firewall/ipset/*.iplist 2>/dev/null); do
        ipset_base=$(basename "$ipset_file" | cut -f1 -d.)
        echo "table <${ipset_base}> persist file \"${ipset_file}\"" >> "$pf_tmp"
    done
fi

# 默认策略
cat << 'EOF' >> "$pf_tmp"

# 3. 默认策略：阻止所有入站，允许所有出站
block in all
pass out all keep state

# 4. 允许本地 IP
EOF

# 允许本地 IP
if [ -d "$HESTIA/data/ips" ]; then
    for local_ip_file in "$HESTIA/data/ips"/*; do
        if [ -f "$local_ip_file" ]; then
            local_ip=$(basename "$local_ip_file")
            echo "pass in quick from $local_ip to any" >> "$pf_tmp"
        fi
    done
fi
echo "pass in quick from 127.0.0.1 to any" >> "$pf_tmp"
echo "pass inet proto icmp icmp-type echoreq" >> "$pf_tmp"

# 5. Fail2ban 阻断规则
cat << 'EOF' >> "$pf_tmp"

# 5. Fail2ban 动态阻断规则
EOF

if [ -f "$chains" ]; then
    for chain_line in $(cat "$chains"); do
        parse_object_kv_list "$chain_line"
        c_name=$(echo "$CHAIN" | tr '[:upper:]' '[:lower:]')
        p_proto=$(echo "$PROTOCOL" | tr '[:upper:]' '[:lower:]')
        
        if [[ "$PORT" =~ ,|-|: ]]; then
            p_port="{ ${PORT//,/ } }"
            p_port="${p_port//-/:}"
        else
            p_port="$PORT"
        fi
        
        if [ "$PORT" = "0" ] || [ "$PROTOCOL" = "ICMP" ]; then
            echo "block in quick proto ${p_proto} from <fail2ban-${c_name}> to any" >> "$pf_tmp"
        else
            echo "block in quick proto ${p_proto} from <fail2ban-${c_name}> to any port ${p_port}" >> "$pf_tmp"
        fi
    done
fi

# 6. 用户自定义规则
cat << 'EOF' >> "$pf_tmp"

# 6. 用户自定义防火墙规则
EOF

IFS=$'\n'
for line in $(sort -r -n -k 2 -t \' "$rules"); do
    parse_object_kv_list "$line"
    if [ "$SUSPENDED" = 'no' ]; then
        p_proto=$(echo "$PROTOCOL" | tr '[:upper:]' '[:lower:]')
        p_action=$(echo "$ACTION" | tr '[:upper:]' '[:lower:]')
        
        [ "$p_action" = "drop" ] && p_action="block"
        [ "$p_action" = "accept" ] && p_action="pass"

        if [[ "$PORT" =~ ,|-|: ]]; then
            p_port="{ ${PORT//,/ } }"
            p_port="${p_port//-/:}"
        else
            p_port="$PORT"
        fi

        if [[ "$IP" =~ ^ipset: ]]; then
            ipset_name="${IP#ipset:}"
            p_src="<${ipset_name}_v4>"
        elif [ "$IP" = "0.0.0.0/0" ] || [ "$IP" = "any" ]; then
            p_src="any"
        else
            p_src="$IP"
        fi

        if [ "$PORT" = "0" ] || [ "$PROTOCOL" = "ICMP" ]; then
            echo "${p_action} in proto ${p_proto} from ${p_src} to any keep state" >> "$pf_tmp"
        else
            echo "${p_action} in proto ${p_proto} from ${p_src} to any port ${p_port} keep state" >> "$pf_tmp"
        fi
    fi
done
unset IFS

# 应用配置
cp -f "$pf_tmp" /etc/pf.conf
chmod 644 /etc/pf.conf
rm -f "$pf_tmp"

# 加载防火墙规则
$pfctl -f /etc/pf.conf > /dev/null 2>&1

# 处理黑名单（动态添加）
if [ -f "$banlist" ] && [ -n "$FIREWALL_EXTENSION" ]; then
    for ban in $(cat "$banlist"); do
        parse_object_kv_list "$ban"
        c_name=$(echo "$CHAIN" | tr '[:upper:]' '[:lower:]')
        $pfctl -t "fail2ban-${c_name}" -T add "$IP" >/dev/null 2>&1 || true
    done
fi

# 自定义触发脚本
if [ -x "$HESTIA/data/firewall/custom.sh" ]; then
    bash "$HESTIA/data/firewall/custom.sh"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

log_event "$OK" "$ARGUMENTS"
exit