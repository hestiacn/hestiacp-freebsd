#!/bin/sh
# info: list dovecot config parameters
# options: [FORMAT]
#
# example: v-list-sys-dovecot-config
#
# This function for obtaining the list of dovecot config parameters.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
    dovecot_base="/etc/dovecot"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
    dovecot_base="/usr/local/etc/dovecot"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
    echo '{'
    echo '    "CONFIG": {'
    echo "        \"config_path\": \"$config_path\","
    echo "        \"config_path1\": \"$config_path1\","
    echo "        \"config_path2\": \"$config_path2\","
    echo "        \"config_path3\": \"$config_path3\","
    echo "        \"config_path4\": \"$config_path4\","
    echo "        \"config_path5\": \"$config_path5\","
    echo "        \"config_path6\": \"$config_path6\","
    echo "        \"config_path7\": \"$config_path7\","
    echo "        \"config_path8\": \"$config_path8\""
    echo '    }'
    echo '}'
}

# SHELL list function
shell_list() {
    echo "config_path:    $config_path"
    echo "config_path1:   $config_path1"
    echo "config_path2:   $config_path2"
    echo "config_path3:   $config_path3"
    echo "config_path4:   $config_path4"
    echo "config_path5:   $config_path5"
    echo "config_path6:   $config_path6"
    echo "config_path7:   $config_path7"
    echo "config_path8:   $config_path8"
}

# PLAIN list function
plain_list() {
    printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
        "$config_path" "$config_path1" "$config_path2" "$config_path3" \
        "$config_path4" "$config_path5" "$config_path6" "$config_path7" "$config_path8"
}

# CSV list function
csv_list() {
    echo "config_path,config_path1,config_path2,config_path3,config_path4,config_path5,config_path6,config_path7,config_path8"
    echo "$config_path,$config_path1,$config_path2,$config_path3,$config_path4,$config_path5,$config_path6,$config_path7,$config_path8"
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Defining config path
if [ -e '/etc/dovecot.conf' ]; then
    config_path='/etc/dovecot.conf'
    config_path1=''
    config_path2=''
    config_path3=''
    config_path4=''
    config_path5=''
    config_path6=''
    config_path7=''
    config_path8=''
else
    config_path="$dovecot_base/dovecot.conf"
    config_path1="$dovecot_base/conf.d/10-auth.conf"
    config_path2="$dovecot_base/conf.d/10-logging.conf"
    config_path3="$dovecot_base/conf.d/10-mail.conf"
    config_path4="$dovecot_base/conf.d/10-master.conf"
    config_path5="$dovecot_base/conf.d/10-ssl.conf"
    config_path6="$dovecot_base/conf.d/20-imap.conf"
    config_path7="$dovecot_base/conf.d/20-pop3.conf"
    config_path8="$dovecot_base/conf.d/auth-passwdfile.conf.ext"
fi

# Listing data
case $format in
    json) json_list ;;
    plain) plain_list ;;
    csv) csv_list ;;
    shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
