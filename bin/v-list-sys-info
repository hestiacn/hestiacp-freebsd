#!/bin/bash
# info: list system os
# options: [FORMAT]
#
# example: v-list-sys-info
#
# This function checks available updates for hestia packages.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# Retrieve Hestia Control Panel version number
HESTIA_VERSION=$(grep VERSION "$HESTIA/conf/hestia.conf" | cut -d '=' -f2 | sed "s|'||g")
HESTIA_RELEASE=$(grep RELEASE_BRANCH "$HESTIA/conf/hestia.conf" | cut -d '=' -f2 | sed "s|'||g")

# JSON list function
json_list() {
	echo '{'
	echo '    "sysinfo": {'
	echo "        \"HOSTNAME\": \"$HOSTNAME\","
	echo "        \"OS\": \"$OS\","
	echo "        \"VERSION\": \"$VERSION\","
	echo "        \"ARCH\": \"$ARCH\","
	echo "        \"HESTIA\": \"$HESTIA_VERSION\","
	echo "        \"RELEASE\": \"$HESTIA_RELEASE\","
	echo "        \"UPTIME\": \"$UPTIME\","
	echo "        \"LOADAVERAGE\": \"$LOADAVERAGE\""
	echo '    }'
	echo '}'
}

# SHELL list function
shell_list() {
	printf "%-10s %-10s %-8s %-8s %-8s %-8s %-10s %-15s\n" \
		"HOSTNAME" "OS" "VER" "ARCH" "HESTIA" "RELEASE" "UPTIME" "LA"
	printf "%-10s %-10s %-8s %-8s %-8s %-8s %-10s %-15s\n" \
		"--------" "--" "---" "----" "------" "-------" "------" "--"
	printf "%-10s %-10s %-8s %-8s %-8s %-8s %-10s %-15s\n" \
		"$HOSTNAME" "$OS" "$VERSION" "$ARCH" "$HESTIA_VERSION" "$HESTIA_RELEASE" "$UPTIME" "$LOADAVERAGE"
}

# PLAIN list function
plain_list() {
	printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
		"$HOSTNAME" "$OS" "$VERSION" "$ARCH" "$HESTIA_VERSION" "$HESTIA_RELEASE" "$UPTIME" "$LOADAVERAGE"
}

# CSV list function
csv_list() {
	echo "HOSTNAME,OS,VERSION,ARCH,HESTIA,RELEASE,UPTIME,LOADAVERAGE"
	echo "$HOSTNAME,$OS,$VERSION,$ARCH,$HESTIA_VERSION,$HESTIA_RELEASE,$UPTIME,$LOADAVERAGE"
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Check hostname
HOSTNAME=$(hostname)

# Check OS/Release
if [ -d '/etc/sysconfig' ]; then
	if [ -e '/etc/redhat-release' ]; then
		OS='CentOS'
		VERSION=$(grep -o '[0-9]' /etc/redhat-release | head -n1)
	else
		OS="Amazon"
		VERSION=$(grep -o '[0-9]' /etc/issue | head -n1)
	fi
else
	if command -v lsb_release >/dev/null 2>&1; then
		distro_id=$(lsb_release -si)
		if [ "$distro_id" = "Ubuntu" ] && [ -e '/etc/debian_version' ]; then
			OS="Ubuntu"
			VERSION=$(grep DISTRIB_RELEASE /etc/lsb-release | cut -f 2 -d '=')
		fi
	else
		distro=$(head -n1 /etc/issue | cut -f 1 -d ' ')
		if [ "$distro" = 'Debian' ]; then
			OS="Debian"
			VERSION=$(cat /etc/debian_version)
		else
			# FreeBSD detection
			if [ -f /etc/os-release ]; then
				. /etc/os-release
				OS="$NAME"
				VERSION="$VERSION_ID"
			elif [ -f /usr/local/etc/hestiacp/hestia.conf ]; then
				OS="FreeBSD"
				VERSION=$(freebsd-version)
			else
				OS='UNKNOWN'
				VERSION='UNKNOWN'
			fi
		fi
	fi
fi

# Check architecture
ARCH=$(uname -m)

# Check uptime (POSIX兼容)
if [ -f /proc/uptime ]; then
	# Linux
	uptime_seconds=$(cat /proc/uptime | cut -f 1 -d ' ' | cut -f 1 -d .)
else
	# FreeBSD
	boot_seconds=$(sysctl -n kern.boottime | awk -F '[= ,]' '{print $5}')
	current_seconds=$(date +%s)
	uptime_seconds=$((current_seconds - boot_seconds))
fi
UPTIME=$((uptime_seconds / 60))

# Check LoadAverage (POSIX兼容)
if [ -f /proc/loadavg ]; then
	# Linux
	LOADAVERAGE=$(cat /proc/loadavg | cut -f 1-3 -d ' ' | sed 's/ / \/ /g')
else
	# FreeBSD
	LOADAVERAGE=$(sysctl -n vm.loadavg | sed 's/[{}]//g' | awk '{print $1 " / " $2 " / " $3}')
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
