#!/bin/sh
# info: Install Roundcube webmail client
# options: [MODE]
#
# This function installs the Roundcube webmail client.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/usr/local/etc/hestiacp/hestia.conf
source /usr/local/etc/hestiacp/hestia.conf
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
source $HESTIA/func/db.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# upgrade config file
source "$HESTIA/install/upgrade/upgrade.conf"

MODE=$2
UPDATE="no"

# pkg 安装的路径
RC_INSTALL_DIR="/usr/local/www/roundcube"
RC_CONFIG_DIR="/usr/local/etc/roundcube"
RC_LOG="/var/log/roundcube"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "x$(id -u)" != 'x0' ]; then
    echo "ERROR: v-add-sys-roundcube can only be executed by root"
    exit 10
fi

if [ -z "$HESTIA" ]; then
    HESTIA="/usr/local/hestia"
fi

if [ -z "$HOMEDIR" ] || [ -z "$HESTIA_COMMON_DIR" ]; then
    echo "ERROR: Environment variables not present, installation aborted."
    exit 2
fi

case "$DB_SYSTEM" in
    *mysql*) ;;
    *)
        echo "ERROR: Mysql not available. Installation aborted"
        exit 2
        ;;
esac

# 检查是否已安装 Roundcube
if pkg info roundcube-php$fpm_v-1.6.15,1 >; then
    if [ "$MODE" != "force" ]; then
        echo "ERROR: Roundcube already installed via pkg"
        echo "Use MODE=force to reinstall"
        exit 2
    fi
fi

# 获取当前版本（用于升级）
if [ -f "$RC_INSTALL_DIR/program/include/iniset.php" ]; then
    version="$(grep RCMAIL_VERSION "$RC_INSTALL_DIR/program/include/iniset.php" | cut -d "'" -f 4)"
    if [ "$version" = "$rc_v" ]; then
        echo "Error: Installed version ($version) is equal to the available version ($rc_v)"
        exit 2
    else
        UPDATE="yes"
    fi
fi

# Roundcube 1.7 requires PHP 8.1 or greater
case "$rc_v" in
    1.7*)
        php_min="8.1"
        php_ver="$("$HESTIA/bin/v-list-default-php" plain)"
        if ! printf "%s\n%s\n" "$php_ver" "$php_min" | sort -V | head -n1 | grep -q "$php_min"; then
            echo "Error: PHP $php_ver < $php_min (Roundcube $rc_v requires PHP >= $php_min)"
            exit 2
        fi
        ;;
esac

check_hestia_demo_mode

#----------------------------------------------------------#
#                 Install PHP Dependencies                 #
#----------------------------------------------------------#

install_roundcube_deps() {
    echo "[ * ] Installing PHP extensions for Roundcube..."
    
    local exts="dom exif fileinfo intl pdo pdo_mysql"
    local fpm_restart=0
    
    for ext in $exts; do
        local pkg_name="php${fpm_v}-${ext}"
        if ! pkg info "$pkg_name" > /dev/null 2>&1; then
            pkg install -y "$pkg_name"
        fi
        
        if [ -f "/usr/local/etc/php/ext-20-${ext}.ini.sample" ] && ! php -m 2>/dev/null | grep -q "$ext"; then
            cp "/usr/local/etc/php/ext-20-${ext}.ini.sample" "/usr/local/etc/php/ext-20-${ext}.ini"
            fpm_restart=1
        fi
    done
    
    if [ "$fpm_restart" = "1" ]; then
        service php_fpm restart
    fi
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ "$UPDATE" = "no" ]; then
    # 安装 PHP 依赖
    install_roundcube_deps
    
    # 安装 Roundcube
    echo "[ * ] Installing Roundcube via pkg..."
    pkg install -y roundcube-php85
    
    # 确保配置目录存在
    mkdir -p "$RC_CONFIG_DIR"
    mkdir -p "$RC_LOG"
    
    # 备份原始配置
    if [ -f "$RC_INSTALL_DIR/config/config.inc.php.sample" ]; then
        cp "$RC_INSTALL_DIR/config/config.inc.php.sample" "$RC_CONFIG_DIR/config.inc.php.sample.bak"
    fi
    
    # 复制 Hestia 配置
    cp -f "$HESTIA_COMMON_DIR/roundcube/main.inc.php" "$RC_CONFIG_DIR/config.inc.php"
    cp -f "$HESTIA_COMMON_DIR/roundcube/mimetypes.php" "$RC_CONFIG_DIR/mimetypes.php"
    chmod 644 "$RC_CONFIG_DIR"/*.php
    
    # 复制 Hestia 密码驱动
    mkdir -p "$RC_INSTALL_DIR/plugins/password/drivers/"
    cp -f "$HESTIA_COMMON_DIR/roundcube/hestia.php" "$RC_INSTALL_DIR/plugins/password/drivers/"
    
    # 创建插件配置目录
    mkdir -p "$RC_CONFIG_DIR/plugins/password"
    mkdir -p "$RC_CONFIG_DIR/plugins/newmail_notifier"
    mkdir -p "$RC_CONFIG_DIR/plugins/zipdownload"
    
    # 复制插件配置
    cp -f "$HESTIA_COMMON_DIR/roundcube/config.inc.php" "$RC_CONFIG_DIR/plugins/password/config.inc.php"
    ln -sf "$RC_CONFIG_DIR/plugins/password/config.inc.php" "$RC_INSTALL_DIR/plugins/password/config.inc.php"
    
    cp -f "$HESTIA_COMMON_DIR/roundcube/plugins/config_newmail_notifier.inc.php" "$RC_CONFIG_DIR/plugins/newmail_notifier/config.inc.php"
    ln -sf "$RC_CONFIG_DIR/plugins/newmail_notifier/config.inc.php" "$RC_INSTALL_DIR/plugins/newmail_notifier/config.inc.php"
    
    cp -f "$HESTIA_COMMON_DIR/roundcube/plugins/config_zipdownload.inc.php" "$RC_CONFIG_DIR/plugins/zipdownload/config.inc.php"
    ln -sf "$RC_CONFIG_DIR/plugins/zipdownload/config.inc.php" "$RC_INSTALL_DIR/plugins/zipdownload/config.inc.php"
    
    # 设置权限 (FreeBSD: hestiamail:www)
    chown -R hestiamail:www "$RC_CONFIG_DIR/"
    chmod 751 -R "$RC_CONFIG_DIR"
    chmod 640 "$RC_CONFIG_DIR/config.inc.php"
    chmod 644 "$RC_CONFIG_DIR/plugins/password/config.inc.php"
    chmod 644 "$RC_CONFIG_DIR/plugins/newmail_notifier/config.inc.php"
    chmod 644 "$RC_CONFIG_DIR/plugins/zipdownload/config.inc.php"
    
    # 设置 Roundcube 程序目录权限
    chown -R hestiamail:www "$RC_INSTALL_DIR"
    
    # 日志目录
    chown hestiamail:www "$RC_LOG"
    chmod 751 "$RC_LOG"
    
    # 数据库设置
    if [ -n "$(echo "$DB_SYSTEM" | grep -E 'mysql|pgsql')" ]; then
        host='localhost'
        database='roundcube'
        dbuser="$database"
        dbpass=$(gen_pass)
        charset='UTF8'
        
        sed -i "" "s/%password%/$dbpass/g" "$RC_CONFIG_DIR/config.inc.php"
        
        if [ -n "$(echo "$DB_SYSTEM" | grep -w 'mysql')" ]; then
            add_mysql_database
            # pkg 安装的 SQL 文件路径
            mysql_query "USE $database; $(cat "$RC_INSTALL_DIR/SQL/mysql.initial.sql")"
        fi
    fi
    
    # 生成加密密钥
    rcDesKey="$(openssl rand -base64 30 | tr -d "/" | cut -c1-24)"
    sed -i "" "s/%des_key%/$rcDesKey/g" "$RC_CONFIG_DIR/config.inc.php"
    
    # 更新服务器主机名
    sed -i "" "s/localhost/$(hostname)/g" "$RC_CONFIG_DIR/plugins/password/config.inc.php"
    
    # newsyslog 日志轮转配置
    if [ -f "$HESTIA/install/pkg/logrotate/roundcube" ]; then
        mkdir -p /usr/local/etc/newsyslog.conf.d
        cp -f "$HESTIA/install/pkg/logrotate/roundcube" /usr/local/etc/newsyslog.conf.d/roundcube.conf
        # 修改配置文件中的用户为 hestiamail:www
        sed -i "" 's/mailnull:www/hestiamail:www/g' /usr/local/etc/newsyslog.conf.d/roundcube.conf 2>/dev/null
    fi
    
    # 更新 hestia.conf
    if [ -z "$(grep WEBMAIL_SYSTEM "$HESTIA/conf/hestia.conf")" ]; then
        $BIN/v-change-sys-config-value 'WEBMAIL_SYSTEM' 'roundcube'
    else
        case "$WEBMAIL_SYSTEM" in
            *roundcube*) ;;
            *)
                if [ -n "$WEBMAIL_SYSTEM" ]; then
                    $BIN/v-change-sys-config-value 'WEBMAIL_SYSTEM' "roundcube,$WEBMAIL_SYSTEM"
                else
                    $BIN/v-change-sys-config-value 'WEBMAIL_SYSTEM' "roundcube"
                fi
                ;;
        esac
    fi
    
    # 启用 mcrypt（如果存在）
    if [ -f /usr/local/etc/php/ext-20-mcrypt.ini.sample ] && ! php -m | grep -q mcrypt; then
        cp /usr/local/etc/php/ext-20-mcrypt.ini.sample /usr/local/etc/php/ext-20-mcrypt.ini
        [ -f /usr/local/etc/rc.d/php_fpm ] && service php_fpm restart
    fi
    
else
    # UPDATE 模式
    echo "[ * ] Upgrading Roundcube..."
    
    # 下载新版并升级
    cd "$RC_INSTALL_DIR" || exit 1
    
    RC_FILE="roundcubemail-$rc_v-complete.tar.gz"
    RC_EXTRACT="roundcubemail-$rc_v"
    RC_URL="https://github.com/roundcube/roundcubemail/releases/download/$rc_v/$RC_FILE"
    
    [ ! -f "/tmp/$RC_FILE" ] && fetch -q -o "/tmp/$RC_FILE" "$RC_URL"
    bsdtar xf "/tmp/$RC_FILE" -C /tmp/
    
    if [ -f "/tmp/$RC_EXTRACT/bin/installto.sh" ]; then
        sh "/tmp/$RC_EXTRACT/bin/installto.sh" -y "$RC_INSTALL_DIR" > /dev/null 2>&1
    fi
    
    # 更新权限
    chown -R hestiamail:www "$RC_INSTALL_DIR"
    
    # 更新 newsyslog 配置
    if [ -f "$HESTIA/install/pkg/logrotate/roundcube" ] && [ ! -f /usr/local/etc/newsyslog.conf.d/roundcube.conf ]; then
        mkdir -p /usr/local/etc/newsyslog.conf.d
        cp -f "$HESTIA/install/pkg/logrotate/roundcube" /usr/local/etc/newsyslog.conf.d/roundcube.conf
        sed -i "" 's/mailnull:www/hestiamail:www/g' /usr/local/etc/newsyslog.conf.d/roundcube.conf 2>/dev/null
    fi
    
    # 清理
    rm -rf "/tmp/$RC_FILE" "/tmp/$RC_EXTRACT"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

write_config_value "DB_RC_ALIAS" "roundcube"

if [ "$UPDATE" = "yes" ]; then
    $BIN/v-log-action "system" "Info" "Plugins" "Roundcube updated (Version: $rc_v)."
else
    $BIN/v-log-action "system" "Info" "Plugins" "Roundcube installed (Version: $rc_v)."
fi

log_event "$OK" "$ARGUMENTS"

exit 0