#!/bin/sh
# info: list supported database types
# options: [FORMAT]
#
# example: v-list-database-types json
#
# This function for obtaining the list of database types.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
format=${1:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	objects=$(echo "$DB_SYSTEM" | tr ',' ' ' | wc -w | tr -d ' ')
	i=1
	echo '['
	for type in $(echo "$DB_SYSTEM" | tr ',' ' '); do
		echo -n "    \"$type\""
		if [ "$i" -lt "$objects" ]; then
			echo ','
		else
			echo ''
		fi
		i=$((i + 1))
	done
	echo ']'
}

# SHELL list function
shell_list() {
	echo "TYPE"
	echo "----"
	echo "$DB_SYSTEM" | tr ',' '\n'
}

# PLAIN list function
plain_list() {
	for type in $(echo "$DB_SYSTEM" | tr ',' ' '); do
		echo "$type"
	done
}

# CSV list function
csv_list() {
	echo "TYPE"
	for type in $(echo "$DB_SYSTEM" | tr ',' ' '); do
		echo "$type"
	done
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ -z "$DB_SYSTEM" ]; then
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
