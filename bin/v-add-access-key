#!/bin/bash
# info: generate API access key for a user
# options: USER [PERMISSIONS] [COMMENT] [FORMAT]
#
# Example: v-add-access-key admin purge-nginx-cache,mail-accounts "My API Key" json
#
# PERMISSIONS: Comma-separated list of API endpoints from /usr/local/hestia/data/api/
#              Leave empty for admin user to get all permissions (*)
#              Available permissions can be listed with: ls /usr/local/hestia/data/api/
#
# COMMENT: Optional description (no spaces allowed, use underscores)
# FORMAT: Output format (json, shell, plain), default: shell
#
# The PERMISSIONS argument is optional for admin user only.
# This function creates a key file in $HESTIA/data/access-keys/

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user="$1"
permissions="$2"
comment="$3"
format="${4:-shell}"

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [PERMISSIONS] [COMMENT] [FORMAT]'
is_format_valid 'user' 'comment' 'format'
is_object_valid 'user' 'USER' "$user"

if [ "$user" = "$ROOT_USER" ]; then
	if [ -z "$permissions" ] || [ "$permissions" = "*" ]; then
		permissions=$(ls "$HESTIA/data/api/" 2>/dev/null | tr '\n' ',' | sed 's/,$//')
	fi
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

keygen() {
	LENGTH=${1:-20}
	MATRIX='0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
	PASS=""
	N=1
	while [ $N -le "$LENGTH" ]; do
		RAND=$(od -An -N2 -i /dev/urandom 2>/dev/null | tr -d ' ')
		[ -z "$RAND" ] && RAND=$(date +%N | sed 's/^0*//')
		POS=$((RAND % ${#MATRIX}))
		PASS="${PASS}${MATRIX:$POS:1}"
		N=$((N + 1))
	done
	echo "$PASS"
}

access_key_id=$(keygen)
secret_access_key=$(keygen 40)

if [ ! -d "$HESTIA/data/access-keys/" ]; then
	mkdir -p "$HESTIA/data/access-keys/"
	chown root:root "$HESTIA/data/access-keys/"
	chmod 750 "$HESTIA/data/access-keys/"
fi

while [ -e "$HESTIA/data/access-keys/${access_key_id}" ]; do
	access_key_id=$(keygen)
done

if command -v cleanup_key_permissions >/dev/null 2>&1; then
	permissions=$(cleanup_key_permissions "$permissions")
fi

time_n_date=$(date +'%T %F')
time=$(echo "$time_n_date" | cut -d ' ' -f1)
date=$(echo "$time_n_date" | cut -d ' ' -f2)

# 写入密钥文件
{
	echo "SECRET_ACCESS_KEY='$secret_access_key'"
	echo "USER='$user'"
	echo "PERMISSIONS='${permissions:-}'"
	echo "COMMENT='${comment:-}'"
	echo "TIME='$time'"
	echo "DATE='$date'"
	echo "EXPIRES_IN=''"
	echo "IP=''"
} > "$HESTIA/data/access-keys/${access_key_id}"

chmod 640 "$HESTIA/data/access-keys/${access_key_id}"

case "$format" in
	json)
		echo '{'
		echo "    \"ACCESS_KEY_ID\": \"$access_key_id\","
		echo "    \"SECRET_ACCESS_KEY\": \"$secret_access_key\","
		echo "    \"USER\": \"$user\","
		echo "    \"PERMISSIONS\": [$(echo "$permissions" | sed 's/,/", "/g' | sed 's/^/"/;s/$/"/')],"
		echo "    \"COMMENT\": \"${comment:-}\","
		echo "    \"TIME\": \"$time\","
		echo "    \"DATE\": \"$date\""
		echo '}'
		;;
	shell)
		echo "ACCESS_KEY_ID:      $access_key_id"
		echo "SECRET_ACCESS_KEY:  $secret_access_key"
		echo "USER:               $user"
		echo "PERMISSIONS:        ${permissions:-}"
		echo "COMMENT:            ${comment:-}"
		echo "TIME:               $time"
		echo "DATE:               $date"
		;;
	plain)
		echo "$access_key_id:$secret_access_key"
		;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
log_history "Access key $access_key_id generated for user $user" "Warning" "$user" "API"
log_event "$OK" "$ARGUMENTS"

exit
