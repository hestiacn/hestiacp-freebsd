#!/bin/sh
# info: list dns domain
# options: USER DOMAIN [FORMAT]
#
# example: v-list-dns-domain alice wonderland.com
#
# This function of obtaining the list of dns domain parameters.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
domain=$2
format=${3:-shell}

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	echo '{'
	echo "    \"$DOMAIN\": {"
	echo "        \"IP\": \"$IP\","
	echo "        \"TPL\": \"$TPL\","
	echo "        \"TTL\": \"$TTL\","
	echo "        \"EXP\": \"$EXP\","
	echo "        \"SOA\": \"$SOA\","
	echo "        \"SERIAL\": \"$SERIAL\","
	echo "        \"DNSSEC\": \"$DNSSEC\","
	echo "        \"SRC\": \"$SRC\","
	echo "        \"RECORDS\": \"$RECORDS\","
	echo "        \"SUSPENDED\": \"$SUSPENDED\","
	echo "        \"TIME\": \"$TIME\","
	echo "        \"DATE\": \"$DATE\""
	echo "    }"
	echo '}'
}

# SHELL list function
shell_list() {
	echo "DOMAIN:         $DOMAIN"
	echo "IP:             $IP"
	echo "TEMPLATE:       $TPL"
	echo "TTL:            $TTL"
	echo "EXP:            $EXP"
	echo "SOA:            $SOA"
	echo "SERIAL:         $SERIAL"
	echo "DNSSEC:         $DNSSEC"
	echo "RECORDS:        $RECORDS"
	echo "SUSPENDED:      $SUSPENDED"
	echo "TIME:           $TIME"
	echo "DATE:           $DATE"
}

# PLAIN list function
plain_list() {
	printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
		"$DOMAIN" "$IP" "$TPL" "$TTL" "$EXP" "$SOA" "$SERIAL" "$DNSSEC" "$RECORDS" "$SUSPENDED" "$TIME" "$DATE"
}

# CSV list function
csv_list() {
	echo "DOMAIN,IP,TPL,TTL,EXP,SOA,SERIAL,DNSSEC,RECORDS,SUSPENDED,TIME,DATE"
	echo "$DOMAIN,$IP,$TPL,$TTL,$EXP,$SOA,$SERIAL,$DNSSEC,$RECORDS,$SUSPENDED,$TIME,$DATE"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER DOMAIN [FORMAT]'
is_format_valid 'user' 'domain'
is_object_valid 'user' 'USER' "$user"
is_object_valid 'dns' 'DOMAIN' "$domain"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing domain
domain_line=$(grep "DOMAIN='$domain'" "$USER_DATA/dns.conf")
if [ -z "$domain_line" ]; then
	echo "Error: DNS domain $domain not found for user $user"
	exit 3
fi
parse_object_kv_list "$domain_line"

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
