#!/bin/sh
# info: list user IPs
# options: USER [FORMAT]
#
# example: v-list-user-ips admin
#
# This function for obtaining the list of available IP addresses.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user="$1"
format="${2:-shell}"

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# JSON list function
json_list() {
	echo '{'
	ip_count=$(echo "$ips" | wc -w | tr -d ' ')
	i=1
	for IP in $ips; do
		source_conf "$HESTIA/data/ips/$IP"
		echo -n "    \"$IP\": {"
		echo -n "\"OWNER\": \"$OWNER\", "
		echo -n "\"STATUS\": \"$STATUS\", "
		echo -n "\"NAME\": \"$NAME\", "
		echo "\"NAT\": \"$NAT\"}"
		if [ "$i" -lt "$ip_count" ]; then
			echo ","
		else
			echo ""
		fi
		i=$((i + 1))
	done
	echo '}'
}

# SHELL list function
shell_list() {
	printf "%-16s %-8s %-10s %-8s %-10s\n" "IP" "NAT" "OWNER" "STATUS" "NAME"
	printf "%-16s %-8s %-10s %-8s %-10s\n" "--" "---" "-----" "------" "----"
	for IP in $ips; do
		source_conf "$HESTIA/data/ips/$IP"
		[ -z "$NAT" ] && NAT='no'
		[ -z "$NAME" ] && NAME='no'
		printf "%-16s %-8s %-10s %-8s %-10s\n" "$IP" "$NAT" "$OWNER" "$STATUS" "$NAME"
	done
}

# PLAIN list function
plain_list() {
	for IP in $ips; do
		source_conf "$HESTIA/data/ips/$IP"
		printf "%s\t%s\t%s\t%s\t%s\n" "$IP" "$OWNER" "$STATUS" "$NAME" "$NAT"
	done
}

# CSV list function
csv_list() {
	echo "IP,OWNER,STATUS,NAME,NAT"
	for IP in $ips; do
		source_conf "$HESTIA/data/ips/$IP"
		echo "$IP,$OWNER,$STATUS,$NAME,$NAT"
	done
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '1' "$#" 'USER [FORMAT]'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

owner="$ROOT_USER"

owner_ips=""
if [ -d "$HESTIA/data/ips" ]; then
	for ip_file in "$HESTIA/data/ips"/*; do
		[ -f "$ip_file" ] || continue
		if grep -q "OWNER='$owner'" "$ip_file" && grep -q "STATUS='shared'" "$ip_file"; then
			ip_name=$(basename "$ip_file")
			owner_ips="${owner_ips} ${ip_name}"
		fi
	done
fi

user_ips=""
if [ -d "$HESTIA/data/ips" ]; then
	for ip_file in "$HESTIA/data/ips"/*; do
		[ -f "$ip_file" ] || continue
		if grep -q "OWNER='$user'" "$ip_file"; then
			ip_name=$(basename "$ip_file")
			user_ips="${user_ips} ${ip_name}"
		fi
	done
fi

ips=$(printf "%s\n%s\n" "$user_ips" "$owner_ips" | sort -u | sed '/^$/d' | tr '\n' ' ' | sed 's/ $//')

if [ -z "$ips" ]; then
	case $format in
		json) echo "{}" ;;
		shell) echo "No IPs found for user $user" ;;
		plain) ;;
		csv) echo "IP,OWNER,STATUS,NAME,NAT" ;;
	esac
	exit 0
fi

# Listing data
case $format in
	json) json_list ;;
	plain) plain_list ;;
	csv) csv_list ;;
	shell) shell_list ;;
esac

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
