#!/bin/bash
# info: open file
# options: USER FILE
#
# example: v-open-fs-file admin README.md
#
# This function opens/reads files on the file system

user=$1
src_file=$2

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
	passwd="/etc/passwd"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
	passwd="/etc/master.passwd"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'USER FILE'
is_format_valid 'user'
is_object_valid 'user' 'USER' "$user"

# Checking user homedir
homedir=$(grep "^$user:" "$passwd" | cut -f 6 -d :)
if [ -z "$homedir" ]; then
	echo "Error: user home directory doesn't exist"
	exit 12
fi

# Checking path
if [ -n "$src_file" ]; then
	rpath=$(readlink -f "$src_file")
	if [ -z "$(echo "$rpath" | grep -E "^/tmp|^$homedir")" ]; then
		echo "Error: invalid source path $src_file"
		exit 2
	fi

	if [ ! -f "$src_file" ]; then
		echo "Error: file not found $src_file"
		exit 2
	fi
fi

# Reading file
user_exec cat "$src_file" 2>/dev/null
if [ $? -ne 0 ]; then
	echo "Error: file $src_file was not opened"
	exit 3
fi

# Exiting
exit
