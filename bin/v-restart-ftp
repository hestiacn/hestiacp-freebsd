#!/bin/bash
# info: restart ftp service
# options: NONE
#
# example: v-restart-ftp
#
# This function tells ftp server to reread its configuration.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
restart_type=$1

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
	HESTIA_CONF="/etc/hestiacp/hestia.conf"
	SED_OPTS="-i"
else
	HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
	SED_OPTS="-i ''"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

send_email_report() {
	email=$(grep CONTACT "$HESTIA/data/users/$ROOT_USER/user.conf")
	email=$(echo "$email" | cut -f 2 -d "'")
	tmpfile=$(mktemp)
	subj="$(hostname): $FTP_SYSTEM restart failed"
	service "$FTP_SYSTEM" configtest >> "$tmpfile" 2>&1
	service "$FTP_SYSTEM" restart >> "$tmpfile" 2>&1
	cat "$tmpfile" | $SENDMAIL -s "$subj" "$email"
	rm -f "$tmpfile"
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

is_format_valid 'restart'

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Exit
if [ -z "$FTP_SYSTEM" ] || [ "$FTP_SYSTEM" = 'remote' ]; then
	exit
fi

if [ "$restart_type" = "no" ]; then
	exit
fi

# Schedule restart
if [ "$restart_type" = 'scheduled' ] || { [ -z "$restart_type" ] && [ "$SCHEDULED_RESTART" = 'yes' ]; }; then
	eval "sed $SED_OPTS \"/\/$SCRIPT now/d\" \"$HESTIA/data/queue/restart.pipe\""
	echo "$BIN/$SCRIPT now" >> "$HESTIA/data/queue/restart.pipe"
	exit
fi

# Restart system
$BIN/v-restart-service "$FTP_SYSTEM" "$restart_type" > /dev/null 2>&1
if [ $? -ne 0 ]; then
	send_email_report
	check_result "$E_RESTART" "$FTP_SYSTEM restart failed"
fi

# Update restart queue
if [ -e "$HESTIA/data/queue/restart.pipe" ]; then
	eval "sed $SED_OPTS \"/\/$SCRIPT now/d\" \"$HESTIA/data/queue/restart.pipe\""
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
