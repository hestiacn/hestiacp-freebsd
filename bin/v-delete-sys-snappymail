#!/bin/sh
# info: Delete SnappyMail webmail client
# options: None
#
# This function removes the SnappyMail webmail client.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

if [ -f /etc/redhat-release ] || [ -f /etc/debian_version ]; then
    HESTIA_CONF="/etc/hestiacp/hestia.conf"
else
    HESTIA_CONF="/usr/local/etc/hestiacp/hestia.conf"
fi

# Includes
# shellcheck source=/etc/hestiacp/hestia.conf
source "$HESTIA_CONF"
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# upgrade config file
source "$HESTIA/install/upgrade/upgrade.conf"
# Folder paths
SM_INSTALL_DIR="/usr/local/www/snappymail"
SM_CONFIG_DIR="/usr/local/etc/snappymail"
SM_LOG="/var/log/snappymail"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Checking root permissions
if [ "x$(id -u)" != 'x0' ]; then
    echo "ERROR: v-delete-sys-snappymail can only be executed by the root user"
    exit 10
fi

# Ensure that $HESTIA (/usr/local/hestia/) and other variables are valid.
if [ -z "$HESTIA" ]; then
    HESTIA="/usr/local/hestia"
fi

if [ -z "$HOMEDIR" ] || [ -z "$HESTIA_INSTALL_DIR" ]; then
    echo "ERROR: Environment variables not present, uninstallation aborted."
    exit 2
fi

case "$DB_SYSTEM" in
    *mysql*)
        ;;
    *)
        echo "ERROR: Mysql not available. Uninstallation aborted"
        exit 2
        ;;
esac

# Get current version
if [ -f "$SM_INSTALL_DIR/data/VERSION" ]; then
    version=$(cat "$SM_INSTALL_DIR/data/VERSION")
else
    echo "Error: SnappyMail is not installed"
    exit 2
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Remove directories
rm -rf "$SM_INSTALL_DIR"
rm -rf "$SM_CONFIG_DIR"
rm -f ~/.snappymail

if [ -f '/usr/local/bin/mariadb' ] || [ -f '/usr/bin/mariadb' ]; then
    mariadb -e "DROP DATABASE snappymail" 2>/dev/null
    mariadb -e "DROP USER snappymail@localhost" 2>/dev/null
else
    mysql -e "DROP DATABASE snappymail" 2>/dev/null
    mysql -e "DROP USER snappymail@localhost" 2>/dev/null
fi

# Updating hestia.conf
if [ -n "$WEBMAIL_SYSTEM" ]; then
    new_webmail=$(echo "$WEBMAIL_SYSTEM" | sed 's/snappymail//g' | sed 's/,,*/,/g' | sed 's/^,//' | sed 's/,$//')
    $BIN/v-change-sys-config-value 'WEBMAIL_SYSTEM' "$new_webmail"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

$BIN/v-log-action "system" "Info" "Plugins" "SnappyMail removed (Version: $version)."

log_event "$OK" "$ARGUMENTS"

exit 0
