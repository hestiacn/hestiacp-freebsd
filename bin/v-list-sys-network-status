#!/bin/bash
# info: list system network status
# options:
#
# example: v-list-sys-network-status
#
# This function lists network status

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Displaying network stats
if command -v ss >/dev/null 2>&1; then
	ss -s
else
	netstat
fi
printf -- "\n---------------------------------------------"
printf -- "---------------------------------------------\n\n"

# Displaying network usage
if command -v lsof >/dev/null 2>&1; then
	lsof -iudp -itcp -n -P
else
	lsof -i -n -P | sed -E 's/IPv4 0x[0-9a-f]+/IPv4/g; s/IPv6 0x[0-9a-f]+/IPv6/g'
fi
printf -- "\n---------------------------------------------"
printf -- "---------------------------------------------\n\n"

# Displaying network interfaces
if command -v ip >/dev/null 2>&1; then
	ip addr list
else
	ifconfig -a
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
